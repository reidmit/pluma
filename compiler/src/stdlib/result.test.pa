use core.test
use core.result as res
use core.assert

# Helpers. `checked` returns ok for positives, err for non-positives.
def checked = fun n {
	if n > 0 is true {
		ok n
	} else {
		err "non-positive"
	}
}

def doubled = fun n {
	ok (n * 2)
}

# `err "..."` on its own has unknown `ok` type; pin to `result int
# string` so the assertions below have something concrete to unify
# against.
def bad-boom :: result int string = err "boom"

def bad-skip :: result int string = err "skip"

def bad-early :: result int string = err "early"

def try-pipe = fun {
	try x = ok 4
	try y = checked x
	ok (y * 2)
}

def try-pipe-err = fun {
	try _x = bad-early
	ok 42
}

def tests :: test.suite = [
	test.case "then on ok runs the continuation" fun {
		# --- then on `ok` ---

		when res.then (ok 3) doubled is ok n {
			assert.equals n 6
		} is err _e {
			assert.is-true false
		}
	},
	test.case "then can change the ok type" fun {
		when res.then (ok 5) fun n { ok (to-string n) } is ok s {
			assert.equals s "5"
		} is err _e {
			assert.is-true false
		}
	},
	test.case "then can flip ok into err" fun {
		when res.then (ok (-3)) checked is ok _n {
			assert.is-true false
		} is err e {
			assert.equals e "non-positive"
		}
	},
	test.case "then on err stays err" fun {
		# --- then on `err` ---

		when res.then bad-boom doubled is ok _n {
			assert.is-true false
		} is err e {
			assert.equals e "boom"
		}
	},
	test.case "then on err does not call the continuation" fun {
		let counter = ref.new 0
		let bump-and-double = fun n {
			ref.update counter fun c {
				c + 1
			}
			ok (n * 2)
		}
		assert.all [
			when res.then bad-skip bump-and-double is ok _n {
				assert.is-true false
			} is err e {
				assert.equals e "skip"
			},
			assert.equals (ref.get counter) 0,
		]
	},
	test.case "two-step then composes" fun {
		# --- chained then ---

		let r = res.then (ok 4) fun n {
			res.then (checked n) doubled
		}
		when r is ok n {
			assert.equals n 8
		} is err _e {
			assert.is-true false
		}
	},
	test.case "try desugars to then on ok" fun {
		when try-pipe () is ok n {
			assert.equals n 8
		} is err _e {
			assert.is-true false
		}
	},
	test.case "try short-circuits on err" fun {
		when try-pipe-err () is ok _n {
			assert.is-true false
		} is err e {
			assert.equals e "early"
		}
	},
	test.case "or-else on ok returns the payload" fun {
		# --- or-else (the recovering dual of then; `??` desugars to it) ---

		assert.equals (res.or-else (ok 7) fun { 0 }) 7
	},
	test.case "or-else on err runs the fallback (error discarded)" fun {
		assert.equals (res.or-else bad-boom fun { 99 }) 99
	},
	test.case "or-else does not evaluate the fallback on ok" fun {
		let counter = ref.new 0
		let fallback = fun {
			ref.update counter fun c {
				c + 1
			}
			0
		}
		assert.all [
			assert.equals (res.or-else (ok 9) fallback) 9,
			assert.equals (ref.get counter) 0,
		]
	},
	test.case "?? desugars to or-else on result" fun {
		assert.all [assert.equals (ok 5 ?? 0) 5, assert.equals (bad-boom ?? 0) 0]
	},
	test.case "map transforms an ok" fun {
		# --- map ---

		when res.map (ok 4) fun n { n * 2 } is ok n {
			assert.equals n 8
		} is err _e {
			assert.is-true false
		}
	},
	test.case "map passes an err through untouched" fun {
		when res.map bad-boom fun n { n * 2 } is ok _n {
			assert.is-true false
		} is err e {
			assert.equals e "boom"
		}
	},
	test.case "map-err transforms an err" fun {
		# --- map-err ---

		when res.map-err bad-boom fun e { e ++ "!" } is ok _n {
			assert.is-true false
		} is err e {
			assert.equals e "boom!"
		}
	},
	test.case "map-err leaves an ok alone" fun {
		when res.map-err (ok 4) fun e { e ++ "!" } is ok n {
			assert.equals n 4
		} is err _e {
			assert.is-true false
		}
	},
	test.case "is-ok and is-err on ok" fun {
		# --- is-ok / is-err ---

		assert.all [assert.is-true (res.is-ok (ok 1)), assert.is-false (res.is-err (ok 1))]
	},
	test.case "is-ok and is-err on err" fun {
		assert.all [assert.is-true (res.is-err bad-boom), assert.is-false (res.is-ok bad-boom)]
	},
	test.case "to-option keeps the ok value" fun {
		# --- to-option / error ---

		assert.is-some (res.to-option (ok 4))
	},
	test.case "to-option drops the err" fun { assert.is-none (res.to-option bad-boom) },
	test.case "error keeps the err value" fun {
		when res.error bad-boom is some e {
			assert.equals e "boom"
		} is none {
			assert.is-true false
		}
	},
	test.case "error is none on ok" fun { assert.is-none (res.error (ok 4)) },
]
