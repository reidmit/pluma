use core.test
use core.option as opt
use core.assert

# Helpers that wrap an int or return none, so `then` has something
# to do.
def positive = fun n {
	if n > 0 is true {
		some n
	} else {
		none
	}
}

def doubled = fun n {
	some (n * 2)
}

# `try x = expr` desugars to opt.then, so the two should agree.
def try-pipe = fun {
	try x = some 4
	try y = positive x
	some (y * 2)
}

def try-pipe-none = fun {
	try x = none
	some (x + 1)
}

def tests :: test.suite = [
	# --- then on `some` ---

	test.case "then on some runs the continuation" (fun {
		when opt.then (some 3) doubled is some n {
			assert.equals n 6
		} is none {
			assert.is-true false
		}
	}),

	test.case "then can change the inner type" (fun {
		when opt.then (some 5) fun n { some (to-string n) } is some s {
			assert.equals s "5"
		} is none {
			assert.is-true false
		}
	}),

	test.case "then can short-circuit a some into a none" (fun {
		when opt.then (some (-3)) positive is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}),

	# --- then on `none` ---

	test.case "then on none stays none" (fun {
		when opt.then none doubled is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}),

	test.case "then on none does not call the continuation" (fun {
		let counter = ref.new 0
		let bump-and-double = fun n {
			ref.update counter fun c {
				c + 1
			}
			some (n * 2)
		}
		assert.all [
			when opt.then none bump-and-double is some _n {
				assert.is-true false
			} is none {
				assert.is-true true
			},
			assert.equals (ref.get counter) 0,
		]
	}),

	# --- chained then ---

	test.case "two-step then composes" (fun {
		let r = opt.then (some 4) fun n {
			opt.then (positive n) doubled
		}
		when r is some n {
			assert.equals n 8
		} is none {
			assert.is-true false
		}
	}),

	test.case "try desugars to then on some" (fun {
		when try-pipe () is some n {
			assert.equals n 8
		} is none {
			assert.is-true false
		}
	}),

	test.case "try short-circuits on none" (fun {
		when try-pipe-none () is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}),

	# --- or-else (the recovering dual of then; `??` desugars to it) ---

	test.case "or-else on some returns the payload" (fun {
		assert.equals (opt.or-else (some 7) fun { 0 }) 7
	}),

	test.case "or-else on none runs the fallback" (fun {
		assert.equals (opt.or-else none fun { 42 }) 42
	}),

	test.case "or-else does not evaluate the fallback on some" (fun {
		let counter = ref.new 0
		let fallback = fun {
			ref.update counter fun c {
				c + 1
			}
			0
		}
		assert.all [
			assert.equals (opt.or-else (some 9) fallback) 9,
			assert.equals (ref.get counter) 0,
		]
	}),

	test.case "?? desugars to or-else on option" (fun {
		assert.all [assert.equals (some 5 ?? 0) 5, assert.equals (none ?? 0) 0]
	}),

	# --- map ---

	test.case "map transforms a some" (fun {
		when opt.map (some 4) fun n { n * 2 } is some n {
			assert.equals n 8
		} is none {
			assert.is-true false
		}
	}),

	test.case "map leaves a none alone" (fun {
		when opt.map none fun n { n * 2 } is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}),

	test.case "map can change the inner type" (fun {
		when opt.map (some 5) fun n { to-string n } is some s {
			assert.equals s "5"
		} is none {
			assert.is-true false
		}
	}),

	# --- is-some / is-none ---

	test.case "is-some and is-none on some" (fun {
		assert.all [assert.is-true (opt.is-some (some 1)), assert.is-false (opt.is-none (some 1))]
	}),

	test.case "is-some and is-none on none" (fun {
		assert.all [assert.is-true (opt.is-none none), assert.is-false (opt.is-some none)]
	}),

	# --- filter ---

	test.case "filter keeps a passing some" (fun {
		when opt.filter (some 4) fun n { n > 0 } is some n {
			assert.equals n 4
		} is none {
			assert.is-true false
		}
	}),

	test.case "filter drops a failing some" (fun {
		when opt.filter (some (-1)) fun n { n > 0 } is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}),

	test.case "filter leaves a none as none" (fun {
		when opt.filter none fun n { n > 0 } is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}),

	# --- flatten ---

	test.case "flatten collapses some (some x)" (fun {
		when opt.flatten (some (some 4)) is some n {
			assert.equals n 4
		} is none {
			assert.is-true false
		}
	}),

	test.case "flatten turns some none into none" (fun {
		when opt.flatten (some none) is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}),

	# --- to-result ---

	test.case "to-result wraps some in ok" (fun {
		when opt.to-result (some 4) "missing" is ok n {
			assert.equals n 4
		} is err _e {
			assert.is-true false
		}
	}),

	test.case "to-result turns none into err" (fun {
		when opt.to-result none "missing" is ok _n {
			assert.is-true false
		} is err e {
			assert.equals e "missing"
		}
	}),
]
