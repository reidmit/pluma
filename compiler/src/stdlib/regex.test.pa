use core.testing
use core.regex as re
use core.list
use core.dict
use core.assert

def tests :: testing.suite = fun t {
	# --- matches ---

	t.case "matches finds a substring" fun { assert.is-true (re.matches `"hello"` "hello, world!") }

	t.case "matches on non-match" fun { assert.is-false (re.matches `"hello"` "goodbye!") }

	t.case "matches on empty input" fun { assert.is-false (re.matches `"hello"` "") }

	t.case "matches anchored pattern" fun {
		assert.all [
			assert.is-true (re.matches `^ "ab" $` "ab"),
			assert.is-false (re.matches `^ "ab" $` "ab "),
		]
	}

	# --- find ---

	t.case "find returns the first match" fun {
		when re.find `digit+` "abc 123 def" is some m {
			assert.all [assert.equals m.text "123", assert.equals m.start 4, assert.equals m.end 7]
		} is none {
			assert.is-true false
		}
	}

	t.case "find on no match is none" fun {
		when re.find `digit+` "no digits" is some _m {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "find populates named captures" fun {
		when re.find `<x: digit+> "," <y: digit+>` "(3,7)" is some m {
			assert.all [
				when dict.lookup m.groups "x" is some s {
					assert.equals s "3"
				} is none {
					assert.is-true false
				},
				when dict.lookup m.groups "y" is some s {
					assert.equals s "7"
				} is none {
					assert.is-true false
				},
			]
		} is none {
			assert.is-true false
		}
	}

	# --- find-all ---

	t.case "find-all returns every match" fun {
		let ms = re.find-all `digit+` "a 1 b 22 c 333"
		assert.all [
			assert.equals (list.length ms) 3,
			assert.equals (list.map ms fun m { m.text }) ["1", "22", "333"],
		]
	}

	t.case "find-all on no match is empty" fun {
		let ms = re.find-all `digit+` "no numbers"
		assert.equals (list.length ms) 0
	}

	# --- named-capture ---

	t.case "named-capture returns some on a hit" fun {
		when re.named-capture `<k: letter+> "=" <v: digit+>` "size=42" "v" is some s {
			assert.equals s "42"
		} is none {
			assert.is-true false
		}
	}

	t.case "named-capture returns none for an unknown name" fun {
		when re.named-capture `<k: letter+> "=" <v: digit+>` "size=42" "nope" is some _s {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "named-capture returns none on no match" fun {
		when re.named-capture `<k: letter+> "=" <v: digit+>` "no equals here" "k" is some _s {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	# --- replace / replace-first ---

	t.case "replace substitutes every match" fun {
		assert.equals (re.replace `digit+` "a1b22c333" "N") "aNbNcN"
	}

	t.case "replace uses named-capture interpolation" fun {
		assert.equals (re.replace `<x: digit+> "," <y: digit+>` "(1,2) (3,4)" "[${x}-${y}]") "([1-2]) ([3-4])"
	}

	t.case "replace with no match passes through" fun {
		assert.equals (re.replace `digit+` "no nums" "N") "no nums"
	}

	t.case "replace-first only replaces the leftmost" fun {
		assert.equals (re.replace-first `digit+` "1 2 3" "N") "N 2 3"
	}

	t.case "replace-first with no match passes through" fun {
		assert.equals (re.replace-first `digit+` "no nums" "N") "no nums"
	}

	# --- split ---

	t.case "split on a delimiter" fun { assert.equals (re.split `","` "a,b,c") ["a", "b", "c"] }

	t.case "split collapses whitespace" fun {
		assert.equals (re.split `whitespace+` "  a   b\tc  ") ["", "a", "b", "c", ""]
	}

	t.case "split with no match returns the whole input" fun {
		assert.equals (re.split `","` "abc") ["abc"]
	}
}
