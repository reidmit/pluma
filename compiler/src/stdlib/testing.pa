# core.testing â€” build a tree of tests that `pluma test` runs.
#
# A test file (`*.test.pa`) exports a single suite named `tests`. The
# runner threads in a registrar `t`; call its methods to register cases
# and groups. Each case body returns a `result` â€” `ok ()` to pass, an
# `err` to fail â€” which is exactly what the `core.assert` checks produce.
#
#     use core.testing
#     use core.assert
#
#     def tests :: testing.suite = fun t {
#         t.case "adds" (fun { assert.equals (2 + 3) 5 })
#
#         t.group "edge cases" (fun {
#             t.case "zero" (fun { assert.equals (0 + 0) 0 })
#             t.skip (fun { t.case "flaky" (fun { assert.is-true false }) })
#         })
#
#         t.todo "handles overflow"
#     }

# How a case was marked when it was registered. Internal â€” you set these
# through the registrar's `skip`/`focus`/`todo`; the runner reads them.
# `pending` is a `todo` (a name with no body to run).
enum run-status {
	normal
	skipped
	focused
	pending
}

# One registered case, as handed back to the runner by `drain`. `path`
# is the enclosing group names, outermost first.
alias entry {
	path :: list string,
	name :: string,
	status :: run-status,
	body :: fun nothing -> result nothing string,
}

# The handle threaded into a suite. `case`/`group`/`skip`/`focus`/`todo`
# build the tree by registering into the handle; `drain` hands the
# collected cases to the runner.
alias registrar {
	case :: fun string (fun nothing -> result nothing string) -> nothing,
	group :: fun string (fun nothing -> nothing) -> nothing,
	skip :: fun (fun nothing -> nothing) -> nothing,
	focus :: fun (fun nothing -> nothing) -> nothing,
	todo :: fun string -> nothing,
	drain :: fun nothing -> list entry,
}

# The type of a suite: a function the runner calls with a fresh
# registrar. This is what `def tests :: testing.suite` annotates.
alias suite fun registrar -> nothing

# Build a fresh registrar. The runner calls this, threads the result
# into the module's `tests`, then `drain`s the registered cases. All the
# structural bookkeeping (group paths, skip/focus scoping) lives here in
# Pluma; the registrar holds it in `ref`s.
def new :: fun nothing -> registrar = fun {
	let entries = ref.new []
	let path = ref.new []
	let stat = ref.new normal

	let push = fun e {
		ref.set entries [...ref.get entries, e]
	}

	# Run `thunk` with `seg` pushed onto the current path, then restore.
	let scoped = fun seg thunk {
		let saved = ref.get path
		ref.set path [...saved, seg]
		thunk ()
		ref.set path saved
	}

	# Run `thunk` under status `s`, then restore the previous status.
	let with-status = fun s thunk {
		let saved = ref.get stat
		ref.set stat s
		thunk ()
		ref.set stat saved
	}

	{
		case: fun name body { push {path: ref.get path, name, status: ref.get stat, body} },
		group: fun name thunk { scoped name thunk },
		skip: fun thunk { with-status skipped thunk },
		focus: fun thunk { with-status focused thunk },
		todo: fun name { push {path: ref.get path, name, status: pending, body: fun { ok () }} },
		drain: fun { ref.get entries },
	}
}
