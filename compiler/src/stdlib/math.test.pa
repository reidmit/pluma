use core.math
use core.assert

# --- conversions ---

test "to-float promotes ints" {
	assert.equals (math.to-float 0) 0.0
	assert.equals (math.to-float 42) 42.0
	assert.equals (math.to-float (-7)) (-7.0)
}

test "to-int truncates toward zero" {
	assert.equals (math.to-int 3.0) 3
	assert.equals (math.to-int 3.9) 3
	assert.equals (math.to-int (-3.9)) (-3)
	assert.equals (math.to-int 0.0) 0
}

# --- abs ---

test "abs of positive is itself" {
	assert.equals (math.abs 5) 5
}

test "abs of negative is positive" {
	assert.equals (math.abs (-5)) 5
}

test "abs of zero is zero" {
	assert.equals (math.abs 0) 0
}

# --- floor / ceil / round ---

test "floor rounds down" {
	assert.equals (math.floor 3.7) 3
	assert.equals (math.floor 3.0) 3
	assert.equals (math.floor (-3.2)) (-4)
}

test "ceil rounds up" {
	assert.equals (math.ceil 3.2) 4
	assert.equals (math.ceil 3.0) 3
	assert.equals (math.ceil (-3.7)) (-3)
}

test "round is half-away-from-zero" {
	assert.equals (math.round 3.4) 3
	assert.equals (math.round 3.5) 4
	assert.equals (math.round (-3.5)) (-4)
	assert.equals (math.round (-3.4)) (-3)
}

# --- sqrt ---

test "sqrt of perfect squares" {
	assert.equals (math.sqrt 0.0) 0.0
	assert.equals (math.sqrt 1.0) 1.0
	assert.equals (math.sqrt 4.0) 2.0
	assert.equals (math.sqrt 9.0) 3.0
}

# --- log / exp ---
# Only boundary cases that are exact in IEEE 754. Approximate
# results (log 2.0, exp 1.0, etc.) skip exact-equality checks.

test "log 1.0 is 0.0" {
	assert.equals (math.log 1.0) 0.0
}

test "log10 of powers of 10" {
	assert.equals (math.log10 1.0) 0.0
	assert.equals (math.log10 10.0) 1.0
	assert.equals (math.log10 100.0) 2.0
}

test "log2 of powers of 2" {
	assert.equals (math.log2 1.0) 0.0
	assert.equals (math.log2 2.0) 1.0
	assert.equals (math.log2 8.0) 3.0
}

test "exp 0.0 is 1.0" {
	assert.equals (math.exp 0.0) 1.0
}

# --- trig ---

test "sin 0 is 0" {
	assert.equals (math.sin 0.0) 0.0
}

test "cos 0 is 1" {
	assert.equals (math.cos 0.0) 1.0
}

test "tan 0 is 0" {
	assert.equals (math.tan 0.0) 0.0
}

# --- constants ---

test "pi rounds to 3" {
	assert.equals (math.round math.pi) 3
}

test "e rounds to 3" {
	assert.equals (math.round math.e) 3
}
