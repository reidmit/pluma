use core.testing
use core.hex
use core.assert

def tests :: testing.suite = fun t {
	# --- encode ---

	t.case "encode of empty bytes" fun { assert.equals (hex.encode '') "" }

	t.case "encode of ASCII bytes" fun { assert.equals (hex.encode 'ABC') "414243" }

	t.case "encode of high bytes" fun { assert.equals (hex.encode '\x00\xff\x10') "00ff10" }

	t.case "encode of single byte" fun { assert.equals (hex.encode '\n') "0a" }

	# --- decode ---

	t.case "decode of empty string" fun {
		when hex.decode "" is ok b {
			assert.equals b ''
		} is err _msg {
			assert.is-true false
		}
	}

	t.case "decode round-trips lowercase" fun {
		when hex.decode "414243" is ok b {
			assert.equals b 'ABC'
		} is err _msg {
			assert.is-true false
		}
	}

	t.case "decode accepts uppercase" fun {
		when hex.decode "FF" is ok b {
			assert.equals b '\xff'
		} is err _msg {
			assert.is-true false
		}
	}

	t.case "decode accepts mixed case" fun {
		when hex.decode "AbCdEf" is ok b {
			assert.equals b '\xab\xcd\xef'
		} is err _msg {
			assert.is-true false
		}
	}

	t.case "decode fails on odd length" fun {
		when hex.decode "abc" is ok _b {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	}

	t.case "decode fails on non-hex digit" fun {
		when hex.decode "zz" is ok _b {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	}

	t.case "decode rejects 0x prefix" fun {
		when hex.decode "0xff" is ok _b {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	}

	t.case "decode rejects whitespace" fun {
		when hex.decode "ab cd" is ok _b {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	}

	# --- round-trip ---

	t.case "encode then decode" fun {
		when hex.decode (hex.encode '\x89PNG\r\n\x1a\n') is ok b {
			assert.equals b '\x89PNG\r\n\x1a\n'
		} is err _msg {
			assert.is-true false
		}
	}
}
