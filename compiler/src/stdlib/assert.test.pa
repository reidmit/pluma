use core.assert

# `none` and bare `err "..."` need pinning so the assertion sees a
# concrete option/result type at the call site.
def n :: option int = none

def bad :: result int string = err "boom"

# --- is-some / is-none ---

test "is-some passes on some" {
	assert.is-some (some 7)
}

test "is-some passes on some with non-int payload" {
	assert.is-some (some "hello")
}

test "is-none passes on none" {
	assert.is-none n
}

# --- is-ok / is-err ---

test "is-ok passes on ok" {
	assert.is-ok (ok 42)
}

test "is-ok passes on ok with non-int payload" {
	let r :: result string int = ok "hi"
	assert.is-ok r
}

test "is-err passes on err" {
	assert.is-err bad
}

test "is-err passes on err with non-string error" {
	let r :: result int int = err 7
	assert.is-err r
}
