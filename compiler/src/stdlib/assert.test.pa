use core.testing
use core.assert

# `none` and bare `err "..."` need pinning so the assertion sees a
# concrete option/result type at the call site.
def n :: option int = none

def bad :: result int string = err "boom"

def tests :: testing.suite = fun t {
	# --- is-some / is-none ---

	t.case "is-some passes on some" fun { assert.is-some (some 7) }

	t.case "is-some passes on some with non-int payload" fun { assert.is-some (some "hello") }

	t.case "is-none passes on none" fun { assert.is-none n }

	# --- is-ok / is-err ---

	t.case "is-ok passes on ok" fun { assert.is-ok (ok 42) }

	t.case "is-ok passes on ok with non-int payload" fun {
		let r :: result string int = ok "hi"
		assert.is-ok r
	}

	t.case "is-err passes on err" fun { assert.is-err bad }

	t.case "is-err passes on err with non-string error" fun {
		let r :: result int int = err 7
		assert.is-err r
	}
}
