use core.json
use core.list
use core.dict
use core.assert

# --- parse: primitives ---

test "parse null" {
	when json.parse "null" is ok v { assert.is-true (json.is-null v) }
	is err _e { assert.is-true false }
}

test "parse true" {
	when json.parse "true" is ok v {
		when json.get-bool v is some b { assert.is-true b }
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

test "parse false" {
	when json.parse "false" is ok v {
		when json.get-bool v is some b { assert.is-false b }
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

test "parse int" {
	when json.parse "42" is ok v {
		when json.get-int v is some n { assert.equals n 42 }
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

test "parse negative int" {
	when json.parse "-7" is ok v {
		when json.get-int v is some n { assert.equals n -7 }
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

test "parse float" {
	when json.parse "3.14" is ok v {
		when json.get-float v is some x { assert.equals x 3.14 }
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

test "parse string" {
	when json.parse "\"hi\"" is ok v {
		when json.get-string v is some s { assert.equals s "hi" }
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

# --- parse: compound ---

test "parse empty array" {
	when json.parse "[]" is ok v {
		when json.get-array v is some xs { assert.equals (list.length xs) 0 }
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

test "parse array of ints" {
	when json.parse "[1, 2, 3]" is ok v {
		when json.get-array v is some xs {
			assert.equals (list.length xs) 3
		}
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

test "parse empty object" {
	when json.parse "{}" is ok v {
		when json.get-object v is some o { assert.equals (dict.size o) 0 }
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

# --- parse: errors ---

test "parse error on malformed input" {
	when json.parse "{bad json" is ok _v { assert.is-true false }
	is err _e { assert.is-true true }
}

test "parse error carries line and col" {
	when json.parse "{bad" is ok _v { assert.is-true false }
	is err e {
		assert.equals e.line 1
		assert.equals e.col 2
	}
}

test "parse error on trailing garbage" {
	when json.parse "42 extra" is ok _v { assert.is-true false }
	is err _e { assert.is-true true }
}

# --- stringify ---

test "stringify null" {
	assert.equals (json.stringify json.value.null) "null"
}

test "stringify true" {
	assert.equals (json.stringify (json.value.bool true)) "true"
}

test "stringify int" {
	assert.equals (json.stringify (json.value.int 42)) "42"
}

test "stringify string" {
	assert.equals (json.stringify (json.value.string "hi")) "\"hi\""
}

test "stringify round-trip via parse" {
	when json.parse "[1,2,3]" is ok v {
		assert.equals (json.stringify v) "[1,2,3]"
	}
	is err _e { assert.is-true false }
}

# --- is-null ---

test "is-null on null variant" {
	assert.is-true (json.is-null json.value.null)
}

test "is-null on non-null" {
	assert.is-false (json.is-null (json.value.int 0))
	assert.is-false (json.is-null (json.value.bool false))
	assert.is-false (json.is-null (json.value.string ""))
}

# --- get-field ---

test "get-field returns some on a hit" {
	when json.parse "{\"a\": 1}" is ok v {
		when json.get-field v "a" is some inner {
			when json.get-int inner is some n { assert.equals n 1 }
			is none { assert.is-true false }
		}
		is none { assert.is-true false }
	}
	is err _e { assert.is-true false }
}

test "get-field returns none for missing key" {
	when json.parse "{\"a\": 1}" is ok v {
		when json.get-field v "missing" is some _inner { assert.is-true false }
		is none { assert.is-true true }
	}
	is err _e { assert.is-true false }
}

test "get-field on non-object returns none" {
	when json.get-field (json.value.int 5) "a" is some _inner { assert.is-true false }
	is none { assert.is-true true }
}

# --- get-* type filters ---

test "get-int on a string is none" {
	when json.get-int (json.value.string "x") is some _n { assert.is-true false }
	is none { assert.is-true true }
}

test "get-float on an int is none" {
	when json.get-float (json.value.int 42) is some _x { assert.is-true false }
	is none { assert.is-true true }
}

test "get-number promotes int to float" {
	when json.get-number (json.value.int 42) is some x { assert.equals x 42.0 }
	is none { assert.is-true false }
}

test "get-number passes float through" {
	when json.get-number (json.value.float 3.5) is some x { assert.equals x 3.5 }
	is none { assert.is-true false }
}

test "get-number on a string is none" {
	when json.get-number (json.value.string "x") is some _x { assert.is-true false }
	is none { assert.is-true true }
}

test "get-bool on a non-bool is none" {
	when json.get-bool (json.value.int 1) is some _b { assert.is-true false }
	is none { assert.is-true true }
}

test "get-string on a non-string is none" {
	when json.get-string (json.value.int 1) is some _s { assert.is-true false }
	is none { assert.is-true true }
}

test "get-array on a non-array is none" {
	when json.get-array (json.value.int 1) is some _xs { assert.is-true false }
	is none { assert.is-true true }
}

test "get-object on a non-object is none" {
	when json.get-object (json.value.int 1) is some _o { assert.is-true false }
	is none { assert.is-true true }
}
