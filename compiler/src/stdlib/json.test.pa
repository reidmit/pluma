use core.testing
use core.json
use core.list
use core.dict
use core.assert

def tests :: testing.suite = fun t {
	# --- parse: primitives ---

	t.case "parse null" fun {
		when json.parse "null" is ok v {
			assert.is-true (json.is-null v)
		} is err _e {
			assert.is-true false
		}
	}

	t.case "parse true" fun {
		when json.parse "true" is ok v {
			when json.get-bool v is some b {
				assert.is-true b
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "parse false" fun {
		when json.parse "false" is ok v {
			when json.get-bool v is some b {
				assert.is-false b
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "parse int" fun {
		when json.parse "42" is ok v {
			when json.get-int v is some n {
				assert.equals n 42
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "parse negative int" fun {
		when json.parse "-7" is ok v {
			when json.get-int v is some n {
				assert.equals n (-7)
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "parse float" fun {
		when json.parse "3.14" is ok v {
			when json.get-float v is some x {
				assert.equals x 3.14
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "parse string" fun {
		when json.parse "\"hi\"" is ok v {
			when json.get-string v is some s {
				assert.equals s "hi"
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	# --- parse: compound ---

	t.case "parse empty array" fun {
		when json.parse "[]" is ok v {
			when json.get-array v is some xs {
				assert.equals (list.length xs) 0
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "parse array of ints" fun {
		when json.parse "[1, 2, 3]" is ok v {
			when json.get-array v is some xs {
				assert.equals (list.length xs) 3
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "parse empty object" fun {
		when json.parse "{}" is ok v {
			when json.get-object v is some o {
				assert.equals (dict.size o) 0
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	# --- parse: errors ---

	t.case "parse error on malformed input" fun {
		when json.parse "{bad json" is ok _v {
			assert.is-true false
		} is err _e {
			assert.is-true true
		}
	}

	t.case "parse error carries line and col" fun {
		when json.parse "{bad" is ok _v {
			assert.is-true false
		} is err e {
			assert.all [assert.equals e.line 1, assert.equals e.col 2]
		}
	}

	t.case "parse error on trailing garbage" fun {
		when json.parse "42 extra" is ok _v {
			assert.is-true false
		} is err _e {
			assert.is-true true
		}
	}

	# --- stringify ---

	t.case "stringify null" fun { assert.equals (json.stringify json.value.null) "null" }

	t.case "stringify true" fun { assert.equals (json.stringify (json.value.bool true)) "true" }

	t.case "stringify int" fun { assert.equals (json.stringify (json.value.int 42)) "42" }

	t.case "stringify string" fun {
		assert.equals (json.stringify (json.value.string "hi")) "\"hi\""
	}

	t.case "stringify round-trip via parse" fun {
		when json.parse "[1,2,3]" is ok v {
			assert.equals (json.stringify v) "[1,2,3]"
		} is err _e {
			assert.is-true false
		}
	}

	# --- is-null ---

	t.case "is-null on null variant" fun { assert.is-true (json.is-null json.value.null) }

	t.case "is-null on non-null" fun {
		assert.all [
			assert.is-false (json.is-null (json.value.int 0)),
			assert.is-false (json.is-null (json.value.bool false)),
			assert.is-false (json.is-null (json.value.string "")),
		]
	}

	# --- get-field ---

	t.case "get-field returns some on a hit" fun {
		when json.parse "{\"a\": 1}" is ok v {
			when json.get-field v "a" is some inner {
				when json.get-int inner is some n {
					assert.equals n 1
				} is none {
					assert.is-true false
				}
			} is none {
				assert.is-true false
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "get-field returns none for missing key" fun {
		when json.parse "{\"a\": 1}" is ok v {
			when json.get-field v "missing" is some _inner {
				assert.is-true false
			} is none {
				assert.is-true true
			}
		} is err _e {
			assert.is-true false
		}
	}

	t.case "get-field on non-object returns none" fun {
		when json.get-field (json.value.int 5) "a" is some _inner {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	# --- get-* type filters ---

	t.case "get-int on a string is none" fun {
		when json.get-int (json.value.string "x") is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "get-float on an int is none" fun {
		when json.get-float (json.value.int 42) is some _x {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "get-number promotes int to float" fun {
		when json.get-number (json.value.int 42) is some x {
			assert.equals x 42.0
		} is none {
			assert.is-true false
		}
	}

	t.case "get-number passes float through" fun {
		when json.get-number (json.value.float 3.5) is some x {
			assert.equals x 3.5
		} is none {
			assert.is-true false
		}
	}

	t.case "get-number on a string is none" fun {
		when json.get-number (json.value.string "x") is some _x {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "get-bool on a non-bool is none" fun {
		when json.get-bool (json.value.int 1) is some _b {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "get-string on a non-string is none" fun {
		when json.get-string (json.value.int 1) is some _s {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "get-array on a non-array is none" fun {
		when json.get-array (json.value.int 1) is some _xs {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "get-object on a non-object is none" fun {
		when json.get-object (json.value.int 1) is some _o {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}
}
