use core.testing
use core.string
use core.bytes
use core.assert

def tests :: testing.suite = fun t {
	# --- length / is-empty ---

	t.case "length of empty string" fun {
		assert.equals (string.length "") 0
	}

	t.case "length counts characters" fun {
		assert.all [
			assert.equals (string.length "hello") 5,
			assert.equals (string.length "a b c") 5,
			assert.equals (string.length "héllo") 5,
		]
	}
	# "é" is two UTF-8 bytes but one character.

	t.case "is-empty on empty string" fun {
		assert.is-true (string.is-empty "")
	}

	t.case "is-empty on non-empty string" fun {
		assert.is-false (string.is-empty "x")
	}

	t.case "byte-length counts bytes, not characters" fun {
		assert.all [
			assert.equals (string.byte-length "") 0,
			assert.equals (string.byte-length "hello") 5,
			assert.equals (string.byte-length "héllo") 6,
		]
	}
	# "é" is one character but two UTF-8 bytes, so byte-length exceeds length.

	# --- chars ---

	t.case "chars splits into single-character strings" fun {
		assert.equals (string.chars "hello") ["h", "e", "l", "l", "o"]
	}

	t.case "chars keeps multi-byte characters whole" fun {
		assert.equals (string.chars "héllo") ["h", "é", "l", "l", "o"]
	}

	t.case "chars of empty string is empty" fun {
		assert.equals (string.chars "") []
	}

	# --- slice / drop / char-at ---

	t.case "slice takes a character range" fun {
		assert.all [
			assert.equals (string.slice "hello world" 0 5) "hello",
			assert.equals (string.slice "hello world" 6 11) "world",
		]
	}

	t.case "slice clamps out-of-range indices" fun {
		assert.all [
			assert.equals (string.slice "hi" 0 100) "hi",
			assert.equals (string.slice "hi" 5 10) "",
			assert.equals (string.slice "hi" 1 0) "",
		]
	}

	t.case "slice respects character boundaries" fun {
		# Two-byte "é" is one character: slicing never splits it.
		assert.all [
			assert.equals (string.slice "héllo" 0 2) "hé",
			assert.equals (string.slice "héllo" 1 2) "é",
		]
	}

	t.case "drop removes leading characters" fun {
		assert.all [
			assert.equals (string.drop "hello world" 6) "world",
			assert.equals (string.drop "hi" 0) "hi",
			assert.equals (string.drop "hi" 9) "",
			assert.equals (string.drop "héllo" 1) "éllo",
		]
	}

	t.case "char-at returns the character at an index" fun {
		assert.all [
			when string.char-at "hello" 1 is some c {
				assert.equals c "e"
			} is none {
				assert.is-true false
			},
			when string.char-at "héllo" 1 is some c {
				assert.equals c "é"
			} is none {
				assert.is-true false
			},
		]
	}

	t.case "char-at is none out of bounds" fun {
		assert.all [
			assert.is-none (string.char-at "hi" 5),
			assert.is-none (string.char-at "hi" (-1)),
		]
	}

	# --- to-upper / to-lower ---

	t.case "to-upper uppercases ASCII" fun {
		assert.equals (string.to-upper "hello") "HELLO"
	}

	t.case "to-upper leaves digits and punctuation alone" fun {
		assert.equals (string.to-upper "hi, 123!") "HI, 123!"
	}

	t.case "to-lower lowercases ASCII" fun {
		assert.equals (string.to-lower "HELLO") "hello"
	}

	t.case "to-lower on already-lower is unchanged" fun {
		assert.equals (string.to-lower "hello") "hello"
	}

	# --- trim ---

	t.case "trim strips both ends" fun {
		assert.equals (string.trim "  hello  ") "hello"
	}

	t.case "trim leaves inner whitespace alone" fun {
		assert.equals (string.trim "  a b c  ") "a b c"
	}

	t.case "trim of all whitespace is empty" fun {
		assert.equals (string.trim "   ") ""
	}

	t.case "trim of empty is empty" fun {
		assert.equals (string.trim "") ""
	}

	# --- contains / starts-with / ends-with ---

	t.case "contains a substring" fun {
		assert.is-true (string.contains "abcdef" "cde")
	}

	t.case "contains misses a non-substring" fun {
		assert.is-false (string.contains "abcdef" "xyz")
	}

	t.case "contains empty needle is true" fun {
		assert.is-true (string.contains "abc" "")
	}

	t.case "starts-with a prefix" fun {
		assert.is-true (string.starts-with "hello world" "hello")
	}

	t.case "starts-with a non-prefix" fun {
		assert.is-false (string.starts-with "hello world" "world")
	}

	t.case "starts-with empty is true" fun {
		assert.is-true (string.starts-with "abc" "")
	}

	t.case "ends-with a suffix" fun {
		assert.is-true (string.ends-with "hello world" "world")
	}

	t.case "ends-with a non-suffix" fun {
		assert.is-false (string.ends-with "hello world" "hello")
	}

	t.case "ends-with empty is true" fun {
		assert.is-true (string.ends-with "abc" "")
	}

	# --- join / split ---

	t.case "join with comma" fun {
		assert.equals (string.join ["a", "b", "c"] ",") "a,b,c"
	}

	t.case "join with empty separator" fun {
		assert.equals (string.join ["a", "b", "c"] "") "abc"
	}

	t.case "join of singleton omits separator" fun {
		assert.equals (string.join ["only"] ",") "only"
	}

	t.case "join of empty list is empty" fun {
		assert.equals (string.join [] ",") ""
	}

	t.case "split on comma" fun {
		assert.equals (string.split "a,b,c" ",") ["a", "b", "c"]
	}

	t.case "split with adjacent separators" fun {
		assert.equals (string.split "a,,b" ",") ["a", "", "b"]
	}

	t.case "split with no occurrences is single element" fun {
		assert.equals (string.split "abc" ",") ["abc"]
	}

	t.case "split-then-join round-trip" fun {
		assert.equals (string.join (string.split "a-b-c" "-") "-") "a-b-c"
	}

	# --- replace ---

	t.case "replace every occurrence" fun {
		assert.equals (string.replace "a-b-c" "-" "_") "a_b_c"
	}

	t.case "replace with empty replacement" fun {
		assert.equals (string.replace "abc-def" "-" "") "abcdef"
	}

	t.case "replace with no match passes through" fun {
		assert.equals (string.replace "abc" "x" "y") "abc"
	}

	# --- to-int / to-float ---

	t.case "to-int parses an integer" fun {
		when string.to-int "42" is ok n {
			assert.equals n 42
		} is err _msg {
			assert.is-true false
		}
	}

	t.case "to-int parses a negative integer" fun {
		when string.to-int "-7" is ok n {
			assert.equals n (-7)
		} is err _msg {
			assert.is-true false
		}
	}

	t.case "to-int fails on non-numeric input" fun {
		when string.to-int "hello" is ok _n {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	}

	t.case "to-int fails on a float" fun {
		when string.to-int "3.14" is ok _n {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	}

	t.case "to-float parses a float" fun {
		when string.to-float "3.14" is ok x {
			assert.equals x 3.14
		} is err _msg {
			assert.is-true false
		}
	}

	t.case "to-float parses an integer literal" fun {
		when string.to-float "42" is ok x {
			assert.equals x 42.0
		} is err _msg {
			assert.is-true false
		}
	}

	t.case "to-float fails on non-numeric input" fun {
		when string.to-float "hello" is ok _x {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	}

	# --- to-bytes ---

	t.case "to-bytes round-trips through bytes.to-string" fun {
		let b = string.to-bytes "hello"
		when bytes.to-string b is ok s {
			assert.equals s "hello"
		} is err _msg {
			assert.is-true false
		}
	}
}
