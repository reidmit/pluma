use core.list
use core.assert

# `list.sort` dispatches on `ord a`, so the empty-list sort case needs
# a concrete element type — codegen can't pick an `ord` dictionary
# from a free type var. Other empty-list calls infer fine from the
# surrounding args.
def empty-ints :: list int = []

# --- length / is-empty ---

test "length of empty list" {
	assert.equals (list.length []) 0
}

test "length counts elements" {
	assert.equals (list.length [1, 2, 3]) 3
	assert.equals (list.length ["a", "b"]) 2
}

test "is-empty on empty list" {
	assert.is-true (list.is-empty [])
}

test "is-empty on non-empty list" {
	assert.is-false (list.is-empty [1])
}

# --- reverse ---

test "reverse swaps order" {
	assert.equals (list.reverse [1, 2, 3]) [3, 2, 1]
}

test "reverse of empty is empty" {
	assert.equals (list.reverse []) []
}

test "reverse of singleton is itself" {
	assert.equals (list.reverse [42]) [42]
}

# --- concat ---

test "concat joins two lists" {
	assert.equals (list.concat [1, 2] [3, 4]) [1, 2, 3, 4]
}

test "concat with empty left" {
	assert.equals (list.concat [] [1, 2]) [1, 2]
}

test "concat with empty right" {
	assert.equals (list.concat [1, 2] []) [1, 2]
}

# --- contains ---

test "contains finds an element" {
	assert.is-true (list.contains [1, 2, 3] 2)
}

test "contains misses a non-element" {
	assert.is-false (list.contains [1, 2, 3] 99)
}

test "contains on empty is always false" {
	assert.is-false (list.contains [] 1)
}

# --- map ---

test "map applies fn to each element" {
	assert.equals (list.map [1, 2, 3] fun n { n * 2 }) [2, 4, 6]
}

test "map can change element type" {
	assert.equals (list.map [1, 2, 3] to-string) ["1", "2", "3"]
}

test "map on empty is empty" {
	assert.equals (list.map [] fun n { n + 1 }) []
}

# --- filter ---

test "filter keeps matching elements" {
	assert.equals (list.filter [1, 2, 3, 4] fun n { n > 2 }) [3, 4]
}

test "filter that matches nothing" {
	assert.equals (list.filter [1, 2, 3] fun n { n > 100 }) []
}

test "filter that matches everything" {
	assert.equals (list.filter [1, 2, 3] fun _n { true }) [1, 2, 3]
}

# --- fold ---

test "fold sums a list" {
	assert.equals (list.fold [1, 2, 3, 4] 0 fun acc n { acc + n }) 10
}

test "fold on empty returns init" {
	assert.equals (list.fold [] 42 fun acc n { acc + n }) 42
}

test "fold is left-to-right" {
	assert.equals (list.fold [1, 2, 3] "" fun acc n { "$(acc)$(to-string n)" }) "123"
}

# --- head / tail ---

test "head of non-empty is some" {
	when list.head [1, 2, 3] is some n { assert.equals n 1 }
	is none { assert.is-true false }
}

test "head of empty is none" {
	when list.head [] is some _n { assert.is-true false }
	is none { assert.is-true true }
}

test "tail of non-empty is some rest" {
	when list.tail [1, 2, 3] is some rest { assert.equals rest [2, 3] }
	is none { assert.is-true false }
}

test "tail of singleton is some empty" {
	when list.tail [1] is some rest { assert.equals rest [] }
	is none { assert.is-true false }
}

test "tail of empty is none" {
	when list.tail [] is some _rest { assert.is-true false }
	is none { assert.is-true true }
}

# --- take / drop ---

test "take returns the prefix" {
	assert.equals (list.take [1, 2, 3, 4, 5] 3) [1, 2, 3]
}

test "take more than length returns whole list" {
	assert.equals (list.take [1, 2, 3] 10) [1, 2, 3]
}

test "take zero is empty" {
	assert.equals (list.take [1, 2, 3] 0) []
}

test "drop returns the suffix" {
	assert.equals (list.drop [1, 2, 3, 4, 5] 2) [3, 4, 5]
}

test "drop more than length is empty" {
	assert.equals (list.drop [1, 2, 3] 10) []
}

test "drop zero is whole list" {
	assert.equals (list.drop [1, 2, 3] 0) [1, 2, 3]
}

# --- find ---

test "find returns first match" {
	when list.find [1, 2, 3, 4] fun n { n > 2 } is some n { assert.equals n 3 }
	is none { assert.is-true false }
}

test "find on no match is none" {
	when list.find [1, 2, 3] fun n { n > 100 } is some _n { assert.is-true false }
	is none { assert.is-true true }
}

# --- any / all ---

test "any with a match" {
	assert.is-true (list.any [1, 2, 3] fun n { n > 2 })
}

test "any without a match" {
	assert.is-false (list.any [1, 2, 3] fun n { n > 100 })
}

test "any on empty is false" {
	assert.is-false (list.any [] fun n { n > 0 })
}

test "all with every match" {
	assert.is-true (list.all [1, 2, 3] fun n { n > 0 })
}

test "all with one failure" {
	assert.is-false (list.all [1, 2, 3] fun n { n > 1 })
}

test "all on empty is vacuously true" {
	assert.is-true (list.all [] fun n { n > 0 })
}

# --- sort ---

test "sort ints ascending" {
	assert.equals (list.sort [3, 1, 4, 1, 5, 9, 2, 6] ord.compare) [1, 1, 2, 3, 4, 5, 6, 9]
}

test "sort strings lexicographically" {
	assert.equals (list.sort ["banana", "apple", "cherry"] ord.compare) ["apple", "banana", "cherry"]
}

test "sort descending via swapped comparator" {
	assert.equals (list.sort [1, 2, 3] fun a b { ord.compare b a }) [3, 2, 1]
}

test "sort empty is empty" {
	assert.equals (list.sort empty-ints ord.compare) empty-ints
}
