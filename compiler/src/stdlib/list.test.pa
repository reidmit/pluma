use core.testing
use core.list
use core.assert

def tests :: testing.suite = fun t {
	# --- length / is-empty ---

	t.case "length of empty list" fun { assert.equals (list.length []) 0 }

	t.case "length counts elements" fun {
		assert.all [
			assert.equals (list.length [1, 2, 3]) 3,
			assert.equals (list.length ["a", "b"]) 2,
		]
	}

	t.case "is-empty on empty list" fun { assert.is-true (list.is-empty []) }

	t.case "is-empty on non-empty list" fun { assert.is-false (list.is-empty [1]) }

	# --- reverse ---

	t.case "reverse swaps order" fun { assert.equals (list.reverse [1, 2, 3]) [3, 2, 1] }

	t.case "reverse of empty is empty" fun { assert.equals (list.reverse []) [] }

	t.case "reverse of singleton is itself" fun { assert.equals (list.reverse [42]) [42] }

	# --- concat ---

	t.case "concat joins two lists" fun { assert.equals (list.concat [1, 2] [3, 4]) [1, 2, 3, 4] }

	t.case "concat with empty left" fun { assert.equals (list.concat [] [1, 2]) [1, 2] }

	t.case "concat with empty right" fun { assert.equals (list.concat [1, 2] []) [1, 2] }

	# --- contains ---

	t.case "contains finds an element" fun { assert.is-true (list.contains [1, 2, 3] 2) }

	t.case "contains misses a non-element" fun { assert.is-false (list.contains [1, 2, 3] 99) }

	t.case "contains on empty is always false" fun { assert.is-false (list.contains [] 1) }

	# --- map ---

	t.case "map applies fn to each element" fun {
		assert.equals (list.map [1, 2, 3] fun n { n * 2 }) [2, 4, 6]
	}

	t.case "map can change element type" fun {
		assert.equals (list.map [1, 2, 3] to-string) ["1", "2", "3"]
	}

	t.case "map on empty is empty" fun { assert.equals (list.map [] fun n { n + 1 }) [] }

	# --- filter ---

	t.case "filter keeps matching elements" fun {
		assert.equals (list.filter [1, 2, 3, 4] fun n { n > 2 }) [3, 4]
	}

	t.case "filter that matches nothing" fun {
		assert.equals (list.filter [1, 2, 3] fun n { n > 100 }) []
	}

	t.case "filter that matches everything" fun {
		assert.equals (list.filter [1, 2, 3] fun _n { true }) [1, 2, 3]
	}

	# --- fold ---

	t.case "fold sums a list" fun {
		assert.equals (list.fold [1, 2, 3, 4] 0 fun acc n { acc + n }) 10
	}

	t.case "fold on empty returns init" fun {
		assert.equals (list.fold [] 42 fun acc n { acc + n }) 42
	}

	t.case "fold is left-to-right" fun {
		assert.equals (list.fold [1, 2, 3] "" fun acc n { "$(acc)$(to-string n)" }) "123"
	}

	# --- head / tail ---

	t.case "head of non-empty is some" fun {
		when list.head [1, 2, 3] is some n {
			assert.equals n 1
		} is none {
			assert.is-true false
		}
	}

	t.case "head of empty is none" fun {
		when list.head [] is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	t.case "tail of non-empty is some rest" fun {
		when list.tail [1, 2, 3] is some rest {
			assert.equals rest [2, 3]
		} is none {
			assert.is-true false
		}
	}

	t.case "tail of singleton is some empty" fun {
		when list.tail [1] is some rest {
			assert.equals rest []
		} is none {
			assert.is-true false
		}
	}

	t.case "tail of empty is none" fun {
		when list.tail [] is some _rest {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	# --- take / drop ---

	t.case "take returns the prefix" fun { assert.equals (list.take [1, 2, 3, 4, 5] 3) [1, 2, 3] }

	t.case "take more than length returns whole list" fun {
		assert.equals (list.take [1, 2, 3] 10) [1, 2, 3]
	}

	t.case "take zero is empty" fun { assert.equals (list.take [1, 2, 3] 0) [] }

	t.case "drop returns the suffix" fun { assert.equals (list.drop [1, 2, 3, 4, 5] 2) [3, 4, 5] }

	t.case "drop more than length is empty" fun { assert.equals (list.drop [1, 2, 3] 10) [] }

	t.case "drop zero is whole list" fun { assert.equals (list.drop [1, 2, 3] 0) [1, 2, 3] }

	# --- find ---

	t.case "find returns first match" fun {
		when list.find [1, 2, 3, 4] fun n { n > 2 } is some n {
			assert.equals n 3
		} is none {
			assert.is-true false
		}
	}

	t.case "find on no match is none" fun {
		when list.find [1, 2, 3] fun n { n > 100 } is some _n {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	}

	# --- any / all ---

	t.case "any with a match" fun { assert.is-true (list.any [1, 2, 3] fun n { n > 2 }) }

	t.case "any without a match" fun { assert.is-false (list.any [1, 2, 3] fun n { n > 100 }) }

	t.case "any on empty is false" fun { assert.is-false (list.any [] fun n { n > 0 }) }

	t.case "all with every match" fun { assert.is-true (list.all [1, 2, 3] fun n { n > 0 }) }

	t.case "all with one failure" fun { assert.is-false (list.all [1, 2, 3] fun n { n > 1 }) }

	t.case "all on empty is vacuously true" fun { assert.is-true (list.all [] fun n { n > 0 }) }

	# --- sort ---

	t.case "sort ints ascending" fun {
		assert.equals (list.sort [3, 1, 4, 1, 5, 9, 2, 6] ord.compare) [1, 1, 2, 3, 4, 5, 6, 9]
	}

	t.case "sort strings lexicographically" fun {
		assert.equals (list.sort ["banana", "apple", "cherry"] ord.compare) [
			"apple",
			"banana",
			"cherry",
		]
	}

	t.case "sort descending via swapped comparator" fun {
		assert.equals (list.sort [1, 2, 3] fun a b { ord.compare b a }) [3, 2, 1]
	}

	t.case "sort empty is empty" fun {
		# `list.sort` dispatches on `ord a`, so the empty-list case needs
		# a concrete element type — codegen can't pick an `ord` dictionary
		# from a free type var.
		let empty :: list int = []
		assert.equals (list.sort empty ord.compare) empty
	}
}
