use core.testing
use core.assert

# `ref` is auto-imported in every module — no `use core.ref` needed.

def tests :: testing.suite = fun t {
	# --- new / get ---

	t.case "new + get round-trips an int" fun {
		let r = ref.new 42
		assert.equals (ref.get r) 42
	}

	t.case "new + get round-trips a string" fun {
		let r = ref.new "hello"
		assert.equals (ref.get r) "hello"
	}

	t.case "new + get round-trips a list" fun {
		let r = ref.new [1, 2, 3]
		assert.equals (ref.get r) [1, 2, 3]
	}

	# --- set ---

	t.case "set overwrites the cell" fun {
		let r = ref.new 1
		ref.set r 99
		assert.equals (ref.get r) 99
	}

	t.case "set is visible through a shared binding" fun {
		let r = ref.new 0
		let shared = r
		ref.set shared 100
		assert.equals (ref.get r) 100
	}

	# --- update ---

	t.case "update reads, applies fn, writes" fun {
		let r = ref.new 10
		ref.update r fun n {
			n + 5
		}
		assert.equals (ref.get r) 15
	}

	t.case "update can be called multiple times" fun {
		let r = ref.new 0
		ref.update r fun n {
			n + 1
		}
		ref.update r fun n {
			n + 1
		}
		ref.update r fun n {
			n + 1
		}
		assert.equals (ref.get r) 3
	}

	# --- identity ---

	t.case "same cell compares equal to itself" fun {
		let r = ref.new 42
		assert.equals r r
	}

	t.case "aliased cells compare equal" fun {
		let r = ref.new 42
		let shared = r
		assert.equals r shared
	}

	t.case "distinct cells with the same contents are not equal" fun {
		let a = ref.new 100
		let b = ref.new 100
		assert.not-equals a b
	}
}
