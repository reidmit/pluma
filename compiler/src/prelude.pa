# The prelude: the handful of types and behaviors that are always in
# scope. You never `use` this module -- everything in it is available in
# every Pluma program automatically.
#
# It defines the three enums the language leans on everywhere -- `option`
# (a value that might be missing), `result` (an action that might fail),
# and `ordering` (how two things compare) -- plus the rules that let
# options and results be compared, sorted, and used as dict keys.
#
# (Note for contributors: this file is baked into the compiler and
# analyzed before any user code. The `numeric` / `ord` / `hash` traits and
# their primitive instances live here, with `built-in "â€¦"` method bodies.
# Still seeded separately in the compiler: the `print` / `debug` /
# `to-string` builtins, and the `wire` trait â€” `wire` is auto-derived
# structurally rather than dispatched through a method dict.)

# A value that might be there, or might not. `some x` holds a value;
# `none` holds nothing. It's how Pluma says "this could be missing"
# without a null that blows up when you forget to check for it -- the
# type makes you handle the empty case.
#
# Lookups hand you an option: `list.head` on a possibly-empty list,
# `dict.lookup` for a key that might not be there.
#
#     when list.head xs is some first { use first } is none { "empty" }
#
# To pull the value out with a fallback for `none`, use `??`:
#
#     list.head xs ?? 0   # the first element, or 0 if xs is empty
public enum option a {
	some a
	none
}

# The outcome of something that can fail. `ok x` is success carrying a
# value; `err e` is failure carrying an error (often a message saying
# what went wrong). Like `option`, it makes the failure case impossible
# to ignore by accident.
#
# Parsing and I/O return results: `string.to-int` on text that might not
# be a number, `fs.read-file` on a path that might not exist.
#
#     when string.to-int s is ok n { n } is err msg { io.print msg }
#
#     string.to-int "42"     # => ok 42
#     string.to-int "nope"   # => err "invalid digit found in string"
public enum result a b {
	ok a
	err b
}

# A computation that, when run, will eventually produce an `a` (or fail,
# or be cancelled). A `task a` is *cold*: building one does nothing;
# awaiting it with `try`, spawning it into a `scope`, or `task.start`ing
# it runs it. Tasks are re-runnable recipes -- awaiting the same task
# twice runs it twice -- so `task.retry`/polling can take a plain task.
#
# It's the third `try` carrier alongside `option` and `result`: inside a
# function that returns a `task`, `try x = some-task` awaits it, and the
# whole function is itself a `task`. The `task.*` helpers (in `std.task`,
# auto-imported) build and combine them; `scope` (a keyword) runs them
# concurrently.
#
# The type has no surface constructors -- you never write `task.mk`; you
# make one with `task.return` / `task.sleep` / an async function call.
public enum task a {
}

# The handle bound by `scope as s` (the fail-fast form) -- your control surface
# for the tasks the scope owns. You never construct one (no surface
# constructors); the `scope` keyword hands you one inside the block. Its
# methods: `s.spawn t` starts a task (of *any* type -- a fail-fast scope's
# children are heterogeneous, awaited individually via `try`), `s.cancel ()`
# cancels the scope, and `s.cancel-after d` arms a deadline. There's no
# `s.next` here (that would need one shared child type) -- see
# `manual-scope-handle` for the queue-style drain.
public enum scope-handle {
}

# The handle bound by `manual scope as s` -- same runtime object as a
# `scope-handle`, but the type carries the children's element type `a`. That
# parameter exists for one reason: `s.next ()` drains completions one at a time
# (yielding `some (result a e)` per completion, then `none`), so it needs a
# single child type to return -- which is why a manual scope's children are
# homogeneous, where a `scope-handle`'s are heterogeneous (awaited individually,
# so no shared type is needed). That drain is what `race` / `any` / `pool` are
# built on. Also supports `s.spawn t`, `s.cancel ()`, `s.cancel-after d`.
public enum manual-scope-handle a {
}

# The answer to "how do these two compare?" -- `lt` (the first is
# smaller), `eq` (they're equal), or `gt` (the first is bigger). Compare
# functions return one of these, and `list.sort` uses them to decide the
# order.
#
#     ord.compare 1 2   # => lt
#     ord.compare 5 5   # => eq
#     ord.compare 9 3   # => gt
public enum ordering {
	lt
	eq
	gt
}

# Why a `wire` decode failed. The `wire` codec
# turns any data-shaped value into compact binary and back; decoding bytes
# that don't match the expected type surfaces one of these through the
# `result` that `wire.decode` returns. (Encoding can't fail â€” a value always
# matches its own type.)
#
#   unexpected-end    ran out of bytes mid-decode
#   invalid-tag n     an enum tag with no matching variant
#   invalid-utf8      a string field wasn't valid UTF-8
#   trailing-bytes n  n bytes left over after a complete decode
#   malformed         a length/varint was structurally broken
public enum wire-error {
	unexpected-end
	invalid-tag int
	invalid-utf8
	trailing-bytes int
	malformed
}

# The runtime reification of a `wire a` dictionary: a tree describing a
# type's structure so the `wire-encode` / `wire-decode` builtins can drive a
# positional binary encoding (the type *is* the schema). You
# almost never write one by hand; the compiler synthesizes it from the type
# whenever you call `wire.encode` / `wire.decode`. It's public so those synthesized
# values have a named home.
public enum wire-schema {
	s-int
	s-float
	s-bool
	s-string
	s-bytes
	s-duration
	s-nothing
	s-list wire-schema
	s-dict wire-schema wire-schema
	s-enum-ref string
	s-tuple (list wire-schema)
	s-record (list (string, wire-schema))
	s-enum string (list (string, (list wire-schema)))
}

# The runtime reification of a backtick regex literal: the pattern's shape
# as a tree the pure-Pluma regex engine (`std.regex`) walks to match. You
# never write one by hand; the compiler synthesizes it from the `` `...` ``
# literal. It's public so those synthesized values have a named home.
#
# `p-repeat inner min max` covers every quantifier: `+` is `(_, 1, -1)`,
# `*` is `(_, 0, -1)`, `?` is `(_, 0, 1)`, `{n}` is `(_, n, n)`, and so on
# (`max = -1` means unbounded). `p-class` names a character group
# (`"digit"`/`"letter"`/`"whitespace"`/`"word"`/`"any"`); `p-anchor` names
# a zero-width assertion (`"start"`/`"end"`/`"boundary"`).
public enum regex-pattern {
	p-literal bytes
	p-class string
	p-anchor string
	p-repeat regex-pattern int int
	p-sequence (list regex-pattern)
	p-alternation (list regex-pattern)
	p-capture string regex-pattern
}

# Transport metadata for a `remote` call: the headers a
# client attaches and the server reads. It is symmetric -- client and server
# share the one type. Identity is never a field here: a client presents
# credentials (a header/cookie), and the server validates them via a
# server-only query, so there is nothing to forge. It is a nominal type (not
# a bare record) so the endpoint checker can recognize an RPC `request`
# parameter by name. Build one with `request.new ()` and attach metadata with
# `request.header` (`std.request`); the single constructor stays an internal
# detail of that module.
public enum request {
	request-with (dict string string)
}

# Arithmetic over numbers. `+ - * /` and unary negate all dispatch
# through `numeric`; instances exist for the two number types only, so
# there's no implicit int/float mixing. The method bodies call straight
# into the backend's primitive operations.
public trait numeric a {
	add :: fun a a -> a
	sub :: fun a a -> a
	mul :: fun a a -> a
	div :: fun a a -> a
	negate :: fun a -> a
}

implement numeric int {
	def add = built-in "int-add"
	def sub = built-in "int-sub"
	def mul = built-in "int-mul"
	def div = built-in "int-div"
	def negate = built-in "int-negate"
}

implement numeric float {
	def add = built-in "float-add"
	def sub = built-in "float-sub"
	def mul = built-in "float-mul"
	def div = built-in "float-div"
	def negate = built-in "float-negate"
}

# How two values of the same type order. `compare` returns an `ordering`;
# `list.sort` and the comparison operators build on it. Concrete instances
# for the primitives; `option`/`result` get parametric ones below.
public trait ord a {
	compare :: fun a a -> ordering
}

implement ord int {
	def compare = built-in "int-compare"
}

implement ord float {
	def compare = built-in "float-compare"
}

implement ord string {
	def compare = built-in "string-compare"
}

implement ord bytes {
	def compare = built-in "bytes-compare"
}

# Turn a value into an int bucket so it can be a dict key. Concrete
# instances for the primitives; `option`/`result` get parametric ones below.
public trait hash a {
	hash :: fun a -> int
}

implement hash int {
	def hash = built-in "int-hash"
}

implement hash float {
	def hash = built-in "float-hash"
}

implement hash string {
	def hash = built-in "string-hash"
}

implement hash bytes {
	def hash = built-in "bytes-hash"
}

implement hash bool {
	def hash = built-in "bool-hash"
}

# The rules below teach `option` and `result` how to compare and hash,
# so that anything built out of them can be sorted or used as a dict key
# whenever the values they wrap can. An option compares by its contents,
# with `none` sorting before any `some`; a result likewise, with `ok`
# before any `err`.

implement ord (option a) where (ord a) {
	def compare = fun x y {
		when x is some xv {
			when y is some yv {
				compare xv yv
			} is none {
				ordering.gt
			}
		} is none {
			when y is some _v {
				ordering.lt
			} is none {
				ordering.eq
			}
		}
	}
}

implement ord (result a b) where (ord a, ord b) {
	def compare = fun x y {
		when x is ok xv {
			when y is ok yv {
				compare xv yv
			} is err _e {
				ordering.lt
			}
		} is err xe {
			when y is err ye {
				compare xe ye
			} is ok _v {
				ordering.gt
			}
		}
	}
}

implement hash (option a) where (hash a) {
	def hash = fun o {
		when o is some v {
			hash v
		} is none {
			0
		}
	}
}

implement hash (result a b) where (hash a, hash b) {
	def hash = fun r {
		when r is ok v {
			hash v
		} is err e {
			hash e
		}
	}
}
