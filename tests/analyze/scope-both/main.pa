# A fail-fast `scope` with two spawned children, awaited via `try`. Exercises
# scope typing (the block is a `task a`), the `scope as s` handle binding, and
# `s.spawn` method dispatch (lowered to the `task.scope-spawn` kernel builtin).
use std.task

def both = fun t1 t2 {
	scope as s {
		let h1 = s.spawn t1
		let h2 = s.spawn t2
		try a = h1
		try b = h2
		task.return (a, b)
	}
}

def main = fun {
	try pair = both (task.return 1) (task.return 2)
	task.return pair
}
