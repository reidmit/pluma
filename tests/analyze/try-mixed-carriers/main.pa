# Mixing carriers inside the same `try` chain. The outer `try` pins the
# carrier to `result`, so the continuation must also return a `result`.
# The inner `try` produces an `option` instead — the analyzer rejects
# the mismatch.

def safe-head = fun xs {
	when xs is [first, ...] { some first } else { none }
}

def lookup = fun id {
	if id > 0 is true { ok [id, id + 1] } else { err "bad id" }
}

def go = fun id {
	try ids = lookup id     # result (list int) string
	try first = safe-head ids  # option int — wrong carrier
	ok first
}
