# A `manual scope`: spawn everything, drain the first completion via `s.next`,
# then `s.cancel` the losers. Exercises manual-scope typing and the `s.next` /
# `s.cancel` handle methods, plus `s.spawn` inside a nested closure.
use std/list
use std/task

def race = fun ts {
	manual scope as s {
		let _ = list.map ts fun t {
			s.spawn t
		}
		try first = s.next ()
		s.cancel ()
		when first is some r {
			when r is ok v {
				task.ok v
			} is err e {
				task.err e
			}
		} is none {
			task.err "race: empty"
		}
	}
}

def main = fun {
	try winner = race [task.ok 10, task.ok 20]
	task.ok winner
}
