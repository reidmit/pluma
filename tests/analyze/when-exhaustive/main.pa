enum tree {
	empty
	node int tree tree
}

def by-all-variants = fun t {
	when t is tree.empty {
		0
	} is tree.node val _l _r {
		val
	}
}

def by-wildcard = fun t {
	when t is tree.empty {
		0
	} else {
		1
	}
}

def by-binding-catchall = fun t {
	when t is _something {
		0
	}
}

def bool-both = fun b {
	when b is true {
		0
	} is false {
		1
	}
}
