# With row polymorphism, `{name: n, ...rest}` binds `rest` to a record
# carrying whatever fields remain after `name` is matched.

def split-out-name = fun p {
	when p is {name: n, ...rest} {
		(n, rest)
	}
}

def main = fun {
	# input has {name, age, role}; rest infers to {age, role}.
	let (the-name, the-rest) = split-out-name {name: "reid", age: 28, role: "engineer"}
	print the-name
	print the-rest.role
}
