use std/assert
use std/task
use std/test
use std/sys/io

# Awaiting tasks with `try` (the third carrier): sequential awaits, a nested
# async-function call, an async closure that captures a local, and ordinary
# (trait-dispatched) arithmetic between awaits. The whole chain runs on the
# event loop the moment `main` (itself a task) is driven to completion.

def add-one = fun n {
	try x = task.ok n
	task.ok (x + 1)
}

def run = fun {
	let base = 100
	let bump = fun n {
		try y = task.ok (n + base)
		task.ok (y * 2)
	}
	try a = add-one 41
	try b = bump 5
	try task.sleep 1ms
	print (to-string a)
	print (to-string b)
	task.ok 0
}

def tests :: test.suite = [
	test.case "task-try-chain" fun {
		try cap = io.capture fun {
			try run ()
			task.ok ()
		}
		assert.matches cap.out """
			42
			210

			"""
	},
]
