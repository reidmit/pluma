use std/assert
use std/task
use std/test
use std/sys/io

enum color {
	red
	green
	blue
}

enum shape {
	circle int
	rect int int
}

def run = fun {
	print (to-string ())
	print (to-string 42)
	print (to-string 3.14)
	print (to-string true)
	print (to-string "hello")
	print (to-string (1, 2, "three"))
	print (to-string {name: "reid", age: 28})
	print (to-string color.red)
	print (to-string (shape.rect 3 4))
}

def tests :: test.suite = [
	test.case "to-string-shapes" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			()
			42
			3.14
			true
			hello
			(1, 2, three)
			{age: 28, name: reid}
			color.red
			shape.rect 3 4

			"""
	},
]
