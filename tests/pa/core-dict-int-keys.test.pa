use std/assert
use std/dict
use std/task
use std/test
use std/sys/io

def run = fun {
	let m = dict.empty ()
	let m = dict.insert m 1 "one"
	let m = dict.insert m 2 "two"
	let m = dict.insert m 3 "three"
	when dict.lookup m 2 is some s {
		print s
	} is none {
		print "?"
	}
	print (dict.size m)

	# Boolean keys exercise the bool hash instance.
	let b = dict.empty ()
	let b = dict.insert b true "yes"
	let b = dict.insert b false "no"
	when dict.lookup b true is some s {
		print s
	} is none {
		print "?"
	}
	when dict.lookup b false is some s {
		print s
	} is none {
		print "?"
	}
}

def tests :: test.suite = [
	test.case "core-dict-int-keys" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			two
			3
			yes
			no

			"""
	},
]
