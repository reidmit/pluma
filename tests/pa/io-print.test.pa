use std/assert
use std/task
use std/test
use std/sys/io

def run = fun {
	# print* adds a trailing newline; write* doesn't
	io.print "stdout line"
	io.print-err "stderr line"

	# build a line piece-by-piece on stdout, then terminate it
	io.write "no"
	io.write "-"
	io.write "newline"
	io.print ""

	# same on stderr
	io.write-err "err"
	io.write-err "-"
	io.write-err "raw"
	io.print-err ""
}

def tests :: test.suite = [
	test.case "io-print" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			stdout line
			no-newline

			"""
		assert.matches cap.err """
			stderr line
			err-raw

			"""
	},
]
