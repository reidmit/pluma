use std/assert
use std/task
use std/test
use std/sys/io

# A scope handle can be passed to a helper function — its signature names the
# param `manual-scope-handle a` / `scope-handle`, and the handle methods dispatch
# there just as they do inside the `scope` body. Previously a handle could only
# be used where it was bound.

def sleeper = fun ms n {
	try task.sleep ms
	task.return n
}

# Takes a *manual* handle as a parameter and drains it, summing the successes.
def drain-sum :: fun (manual-scope-handle int) int -> task int = fun s acc {
	try got = s.next ()
	when got is none {
		task.return acc
	} is some r {
		when r is ok v {
			drain-sum s (acc + v)
		} is err _e {
			drain-sum s acc
		}
	}
}

# Takes a *fail-fast* handle as a parameter, spawns two children into it, and
# pairs their results.
def spawn-pair :: fun scope-handle (task int) (task int) -> task (int, int) = fun s t1 t2 {
	let h1 = s.spawn t1
	let h2 = s.spawn t2
	try a = h1
	try b = h2
	task.return (a, b)
}

def collect = fun {
	manual scope as s {
		s.spawn (sleeper 1ms 10)
		s.spawn (sleeper 2ms 20)
		s.spawn (sleeper 1ms 12)
		drain-sum s 0
	}
}

def paired = fun {
	scope as s {
		try pair = spawn-pair s (sleeper 1ms 100) (sleeper 1ms 23)
		when pair is (a, b) {
			task.return (a + b)
		}
	}
}

def run = fun {
	try total = collect ()
	print "sum $(to-string total)"
	try p = paired ()
	print "paired $(to-string p)"
	task.return 0
}

def tests :: test.suite = [
	test.case "scope-handle-param" fun {
		try cap = io.capture fun {
			try run ()
			task.return ()
		}
		assert.matches cap.out """
			sum 42
			paired 123

			"""
	},
]
