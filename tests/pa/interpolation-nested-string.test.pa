use std/assert
use std/task
use std/test
use std/sys/io

def run = fun {
	let inner = "world"
	let mid = "hello $(inner)"
	print "outer says: $(mid)"
}

def tests :: test.suite = [
	test.case "interpolation-nested-string" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out "outer says: hello world\n"
	},
]
