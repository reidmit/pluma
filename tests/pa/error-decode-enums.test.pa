use std/assert
use std/error
use std/hex
use std/task
use std/test
use std/time
use std/sys/io

# The payoff of precise stdlib error enums: a caller can branch on *which*
# failure occurred (not scrape a string), and the same value erases into
# `std/error` -- with `error.is-a` still recovering the leaf through the framing.

# Branch on the precise decode failure. The two nested `err` arms combine to
# cover `err` (no wildcard) -- the exhaustiveness check recurses into the
# variant's argument rather than demanding a catch-all.
def classify-hex :: fun string -> string = fun s {
	when hex.decode s is ok _ {
		"ok"
	} is err hex.decode-error.odd-length {
		"odd length"
	} is err hex.decode-error.bad-digit {
		"bad digit"
	}
}

# A time field error erases into `error`, and `is-a` recovers which field kind.
def build :: fun nothing -> result instant error = fun {
	try t = time.make 2026 13 1 0 0 0 0
	ok t
}

def show :: fun bool -> string = fun b {
	if b {
		"yes"
	} else {
		"no"
	}
}

def run = fun {
	print (classify-hex "abc")
	print (classify-hex "zz")
	print (classify-hex "4142")
	when build () is ok _ {
		print "unexpected ok"
	} is err e {
		print (error.message e)
		print (show (error.is-a e (time.time-error.field-out-of-range "" 0 0 0)))
	}
}

def tests :: test.suite = [
	test.case "error-decode-enums" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out "odd length\nbad digit\nok\nerror-decode-enums.test:27: time: invalid date/time: month 13 is out of range 1..=12\nyes\n"
	},
]
