use std/assert
use std/task
use std/test
use std/sys/io

def make-adder = fun x {
	fun y {
		x + y
	}
}

def run = fun {
	let add5 = make-adder 5
	let add100 = make-adder 100
	print (add5 3)
	print (add100 23)
}

def tests :: test.suite = [
	test.case "closures" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			8
			123

			"""
	},
]
