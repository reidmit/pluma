use std/assert
use std/task
use std/test
use std/sys/io

# `else` works as the catch-all branch in `when` — sugar for `is _`.

def name-of = fun n {
	when n is 0 {
		"zero"
	} is 1 {
		"one"
	} is 2 {
		"two"
	} else {
		"many"
	}
}

def run = fun {
	print (name-of 0)
	print (name-of 1)
	print (name-of 2)
	print (name-of 99)

	# `else` after a single `is` arm
	let opt = some 7
	let v = when opt is some n {
		n
	} else {
		0
	}
	print v

	# `else` covers the boolean exhaustiveness too
	let flag = true
	let txt = when flag is true {
		"yes"
	} else {
		"no"
	}
	print txt
}

def tests :: test.suite = [
	test.case "when-else" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			zero
			one
			two
			many
			7
			yes

			"""
	},
]
