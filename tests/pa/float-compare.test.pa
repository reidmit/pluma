use std/assert
use std/task
use std/test
use std/sys/io

def run = fun {
	print (1.5 < 2.0)
	print (2.0 < 1.5)
	print (1.5 <= 1.5)
	print (3.14 > 2.71)
	print (3.14 >= 3.14)
	print (1.5 == 1.5)
	print (1.5 == 2.5)
}

def tests :: test.suite = [
	test.case "float-compare" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			true
			false
			true
			true
			true
			true
			false

			"""
	},
]
