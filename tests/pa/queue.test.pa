use std/assert
use std/list
use std/queue
use std/task
use std/test
use std/sys/io

# A FIFO queue (`std/queue`): a mutable two-list structure with amortized O(1)
# enqueue/dequeue. This exercises the back->front rebalance, interleaved churn,
# and the non-destructive snapshot.
def show :: fun (option int) -> string = fun o {
	if o is some x {
		"some $(to-string x)"
	} else {
		"none"
	}
}

def run = fun {
	let q = queue.empty ()
	queue.enqueue q 1
	queue.enqueue q 2
	queue.enqueue q 3
	print (to-string (queue.size q))
	# peek is non-destructive; dequeue returns oldest-first.
	print (show (queue.peek q))
	print (show (queue.dequeue q))
	print (show (queue.dequeue q))
	# enqueue after a partial drain spans front and back.
	queue.enqueue q 4
	print (to-string (queue.to-list q))
	print (to-string (queue.size q))
	print (show (queue.dequeue q))
	print (show (queue.dequeue q))
	print (show (queue.dequeue q))
	print (to-string (queue.is-empty q))
	# from-list keeps arrival order.
	let r = queue.from-list [10, 20, 30]
	print (to-string (queue.to-list r))
	print (show (queue.dequeue r))
	# interleaved churn forces several rebalances; drain into a list.
	let s = queue.empty ()
	let out = []
	queue.enqueue s 1
	queue.enqueue s 2
	queue.dequeue s
	queue.enqueue s 3
	queue.dequeue s
	queue.enqueue s 4
	queue.enqueue s 5
	while queue.dequeue s is some v { list.push out v }
	print (to-string out)
}

def tests :: test.suite = [
	test.case "queue" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			3
			some 1
			some 1
			some 2
			[3, 4]
			2
			some 3
			some 4
			none
			true
			[10, 20, 30]
			some 10
			[3, 4, 5]

			"""
	},
]
