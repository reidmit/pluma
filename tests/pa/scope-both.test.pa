use std/assert
use std/task
use std/test
use std/sys/io

# Fail-fast `scope`: spawn children, await their handles, block on exit. The
# values are deterministic regardless of how the children interleave.

def both = fun t1 t2 {
	scope as s {
		let h1 = s.spawn t1
		let h2 = s.spawn t2
		try a = h1
		try b = h2
		task.ok (a, b)
	}
}

# A child failing fails the whole scope (fail-fast); `??` recovers it.
def boom = fun {
	scope as s {
		let h1 = s.spawn (task.err "kaboom")
		let h2 = s.spawn (task.ok 2)
		try a = h1
		try b = h2
		task.ok (a + b)
	}
}

def run = fun {
	try pair = both (task.ok 1) (task.ok 2)
	print (to-string pair)
	try recovered = boom () ?? task.ok 999
	print (to-string recovered)
	task.ok 0
}

def tests :: test.suite = [
	test.case "scope-both" fun {
		try cap = io.capture fun {
			try run ()
			task.ok ()
		}
		assert.matches cap.out """
			(1, 2)
			999

			"""
	},
]
