use std/assert
use std/task
use std/test
use std/sys/io

def classify = fun b {
	when b is 'GET' {
		"get"
	} is 'POST' {
		"post"
	} else {
		"other"
	}
}

def run = fun {
	print (classify 'GET')
	print (classify 'POST')
	print (classify 'PUT')
}

def tests :: test.suite = [
	test.case "bytes-pattern" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			get
			post
			other

			"""
	},
]
