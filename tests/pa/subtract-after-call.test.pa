use std/assert
use std/task
use std/test
use std/sys/io

# Regression: a function-call result followed by ` - ` is binary
# subtraction, not a negated argument. `double 10 - triple 2` must read as
# `(double 10) - (triple 2)`, not `double 10 (-(triple 2))` (an arity error).
def double = fun x {
	x * 2
}

def triple = fun x {
	x * 3
}

def run = fun {
	print (double 10 - triple 2)
	print (double 10 - 5)
}

def tests :: test.suite = [
	test.case "subtract-after-call" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			14
			15

			"""
	},
]
