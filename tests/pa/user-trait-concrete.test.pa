use std/assert
use std/task
use std/test
use std/sys/io

trait showable a {
	show :: fun a -> string
}

implement showable int {
	def show = to-string
}

implement showable bool {
	def show = fun b {
		if b {
			"yes"
		} else {
			"no"
		}
	}
}

def run = fun {
	print (showable.show 42)
	print (showable.show true)
}

def tests :: test.suite = [
	test.case "user-trait-concrete" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out "42\nyes\n"
	},
]
