use std/assert
use std/task
use std/test
use std/sys/io
use visibility/lib

def run = fun {
	print (lib.double 21)
	let c :: lib.counter = lib.counter-of 7
	print (lib.value-of c)
}

def tests :: test.suite = [
	test.case "visibility" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			42
			7

			"""
	},
]
