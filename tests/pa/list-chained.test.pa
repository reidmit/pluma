use std/assert
use std/list
use std/task
use std/test
use std/sys/io

# A small pipeline: take numbers 1..5, square them, keep odd squares, sum.
def run = fun {
	let xs = [1, 2, 3, 4, 5]
	let squared = list.map xs fun n {
		n * n
	}
	let odd-squared = list.filter squared fun n {
		n % 2 == 1
	}
	let total = list.fold odd-squared 0 fun acc n {
		acc + n
	}
	print total
}

# squared = [1, 4, 9, 16, 25], odd = [1, 9, 25], sum = 35

def tests :: test.suite = [
	test.case "list-chained" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out "35\n"
	},
]
