use std/assert
use std/task
use std/test
use std/sys/io

def run = fun {
	print "tab:\there"
	print "newline:\nhere"
	print "quote: \"quoted\""
	print "backslash: \\"
}

def tests :: test.suite = [
	test.case "string-with-escapes" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out "tab:\there\nnewline:\nhere\nquote: \"quoted\"\nbackslash: \\\n"
	},
]
