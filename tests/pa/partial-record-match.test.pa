use std/assert
use std/task
use std/test
use std/sys/io

def get-name = fun r {
	when r is {name: n, ...} {
		n
	}
}

def run = fun {
	print (get-name {name: "reid", age: 28, role: "engineer"})
	print (get-name {name: "alice", level: 5})
}

def tests :: test.suite = [
	test.case "partial-record-match" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			reid
			alice

			"""
	},
]
