use std/assert
use std/task
use std/test
use std/sys/io

def get-name = fun person {
	when person is {name: n, ...} {
		n
	}
}

def get-age = fun person {
	when person is {age: a, ...} {
		a
	}
}

def run = fun {
	let reid = {name: "reid", age: 28}
	print (get-name reid)
	print (get-age reid)
}

def tests :: test.suite = [
	test.case "record-pattern" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			reid
			28

			"""
	},
]
