use std/assert
use std/task
use std/test
use std/sys/io

# Exact-length list patterns + literal element patterns.

def describe = fun xs {
	when xs is [] {
		"empty"
	} is [1, 2] {
		"one-then-two"
	} is [_, _] {
		"pair"
	} else {
		"many"
	}
}

def run = fun {
	print (describe [])
	print (describe [1, 2])
	print (describe [3, 4])
	print (describe [1])
	print (describe [1, 2, 3])
}

def tests :: test.suite = [
	test.case "list-pattern-exact" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			empty
			one-then-two
			pair
			many
			many

			"""
	},
]
