use std/assert
use std/local
use std/task
use std/test
use std/sys/io

# Tolerant entry: importing the scheduler (here via `std/local`) makes the whole
# program `is_async`, but `main` is sync — it returns `nothing`, not a task. The
# generated entry wrapper checks the result's runtime tag and only drives it when
# it's actually a `$task`, so this exits cleanly with no `task.return ()` ceremony.

def color :: local string = local.new "blue"

def run = fun {
	print (local.get color)
	print (to-string (local.get (local.new 7)))
}

def tests :: test.suite = [
	test.case "tolerant-entry" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			blue
			7

			"""
	},
]
