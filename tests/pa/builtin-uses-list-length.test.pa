use std/assert
use std/task
use std/test
use std/sys/io

# Define `length` as a thin `built-in` wrapper, then call it. The
# global slot holds `Value::Builtin(Builtin::ListLength)` directly —
# no thunk, no Pluma-side body.

def length :: fun (list a) -> int = built-in "list-length"

def run = fun {
	print (length [1, 2, 3])
}

def tests :: test.suite = [
	test.case "builtin-uses-list-length" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out "3\n"
	},
]
