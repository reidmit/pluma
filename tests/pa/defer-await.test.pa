use std/assert
use std/local
use std/task
use std/test
use std/sys/io

# A `defer` whose expression evaluates to a `task` is *awaited*: the runtime
# drives that task to completion as cleanup rather than building and dropping it.
# This pins the four properties of awaited async cleanup:
#   1. an async cleanup runs on the normal exit path,
#   2. it interleaves in LIFO order with plain (sync) defers,
#   3. it also runs on the `try`-failure path (here recovered with `attempt`), and
#   4. a task-local bound around the work is readable inside the async cleanup
#      (the cleanup drive inherits the binding — capture-at-drive).

def tag :: local string = local.new "-"

def async-cleanup :: fun string -> task nothing = fun name {
	try task.sleep 1ms
	print "async cleanup $(name) (tag=$(local.get tag))"
	task.return ()
}

# Three defers pushed A, B, C; they fire LIFO at exit: C, B, A.
def normal :: fun nothing -> task nothing = fun {
	defer async-cleanup "A"
	defer print "sync cleanup B"
	defer async-cleanup "C"
	try task.sleep 1ms
	print "normal body"
	task.return ()
}

# The cleanup fires on the failure path, before the failure propagates.
def failing :: fun nothing -> task nothing = fun {
	defer async-cleanup "fail-cleanup"
	try task.sleep 1ms
	try task.fail "boom"
	print "unreachable"
	task.return ()
}

def run = fun {
	try local.with tag "T" fun {
		try normal ()
		try task.attempt (failing ())
		task.return ()
	}
	print "done"
	task.return 0
}

def tests :: test.suite = [
	test.case "defer-await" fun {
		try cap = io.capture fun {
			try run ()
			task.return ()
		}
		assert.matches cap.out """
			normal body
			async cleanup C (tag=T)
			sync cleanup B
			async cleanup A (tag=T)
			async cleanup fail-cleanup (tag=T)
			done

			"""
	},
]
