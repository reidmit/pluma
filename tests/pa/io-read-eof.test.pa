use std/assert
use std/task
use std/test
use std/sys/io

# Under `pluma test` stdin is held at EOF, so every read returns err — this only
# covers the empty-input case.
#
# TODO: add a way to mock/inject stdin per test, so a case can feed real input and
# exercise the reading path (not just EOF). Not blocking on it now.
def run = fun {
	when io.read () is ok _ {
		print "unexpected ok"
	} is err msg {
		print "first read: $(msg)"
	}

	# still err on subsequent reads
	when io.read () is ok _ {
		print "unexpected ok"
	} is err msg {
		print "second read: $(msg)"
	}
}

def tests :: test.suite = [
	test.case "io-read-eof" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			first read: EOF
			second read: EOF

			"""
	},
]
