use std/assert
use std/task
use std/test
use std/sys/io

# `await` inside a `while` loop that *binds* the awaited result (`try d = ...`)
# and uses it later in the same iteration. Exercises the resume-value binding on
# a loop back-edge: each iteration suspends awaiting `double`, resumes with the
# bound `d`, folds it into the accumulator, and continues. Sum is 2+4+6 = 12.

def double = fun x {
	task.ok (x + x)
}

def run = fun {
	let acc = ref.new 0
	let cursor = ref.new [1, 2, 3]
	while ref.get cursor is [head, ...tail] {
		try d = double head
		ref.update acc fun n {
			n + d
		}
		ref.set cursor tail
	}
	print (to-string (ref.get acc))
	task.ok 0
}

def tests :: test.suite = [
	test.case "task-loop-bind" fun {
		try cap = io.capture fun {
			try run ()
			task.ok ()
		}
		assert.matches cap.out "12\n"
	},
]
