use std/assert
use std/dict
use std/task
use std/test
use std/sys/io

def run = fun {
	# from-entries materializes a dict from a list of (k, v) tuples.
	# Duplicate keys are right-wins.
	let m = dict.from-entries [("a", 1), ("b", 2), ("a", 99), ("c", 3)]
	print (dict.size m)
	when dict.lookup m "a" is some n {
		print n
	} is none {
		print (-1)
	}
	when dict.lookup m "b" is some n {
		print n
	} is none {
		print (-1)
	}
	when dict.lookup m "c" is some n {
		print n
	} is none {
		print (-1)
	}

	# entries round-trips back to the same shape (insertion order preserved).
	print (dict.entries m)
}

def tests :: test.suite = [
	test.case "core-dict-from-entries" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			3
			99
			2
			3
			[(b, 2), (c, 3), (a, 99)]

			"""
	},
]
