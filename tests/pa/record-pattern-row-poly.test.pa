use std/assert
use std/task
use std/test
use std/sys/io

# Row polymorphism: a function destructuring a few fields stays generic
# over the rest. Same function works on records of different shapes.

def get-name = fun r {
	when r is {name: n, ...} {
		n
	}
}

# Returning the rest keeps that genericity end-to-end: each call site
# uses its own row.
def drop-name = fun r {
	when r is {name: _, ...rest} {
		rest
	}
}

def run = fun {
	# Single-field records
	print (get-name {name: "reid"})
	# Two-field records
	print (get-name {name: "alice", age: 30})
	# Different extra fields entirely
	print (get-name {name: "bob", role: "eng", level: 99})

	# Same fun, but the result type differs per call site because the
	# row tail differs. Each result is used like its concrete record.
	let r1 = drop-name {name: "x", age: 28}
	print (to-string r1.age)
	let r2 = drop-name {name: "y", role: "qa", level: 3}
	print r2.role
	print (to-string r2.level)
}

def tests :: test.suite = [
	test.case "record-pattern-row-poly" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			reid
			alice
			bob
			28
			qa
			3

			"""
	},
]
