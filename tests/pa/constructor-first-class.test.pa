use std/assert
use std/list
use std/task
use std/test
use std/sys/io

# A variant constructor is a first-class value: referenced point-free (not
# immediately applied) it lowers to a forwarding closure, so it can be stored,
# passed to higher-order functions, and called later — not just applied inline.

enum shape {
	point
	circle int
}

# Point-free reference to a payload-carrying constructor.
def mk-circle :: fun int -> shape = shape.circle

def describe = fun s {
	when s is shape.circle r {
		"circle $(to-string r)"
	} is shape.point {
		"point"
	}
}

def run = fun {
	# Direct application still constructs inline (the fast path).
	print (describe (shape.circle 3))
	# Point-free def, applied through the closure.
	print (describe (mk-circle 5))
	# Constructor passed to a higher-order function.
	let circles = list.map [1, 2, 4] shape.circle
	print (to-string (list.length circles))
	# Bare prelude constructor (`some`) used the same way.
	let opts = list.map [7, 8] some
	print (to-string (list.length opts))
	# Stored in a local, then called.
	let f = shape.circle
	print (describe (f 9))
}

def tests :: test.suite = [
	test.case "constructor-first-class" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			circle 3
			circle 5
			3
			2
			circle 9

			"""
	},
]
