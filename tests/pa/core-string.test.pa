use std/assert
use std/string
use std/task
use std/test
use std/sys/io

def run = fun {
	print (string.length "hello")
	print (string.length "")
	print (string.is-empty "")
	print (string.is-empty "x")

	# byte-length vs length: "é" is one character, two bytes
	print (string.byte-length "héllo")
	print (string.length "héllo")
	"héllo" |> string.chars |> print

	print (string.to-upper "Hello, World!")
	print (string.to-lower "Hello, World!")
	print (string.trim "  spaced  ")

	print (string.contains "abcdef" "cde")
	print (string.contains "abcdef" "xyz")
	print (string.starts-with "hello world" "hello")
	print (string.ends-with "hello world" "world")

	# join + split, pipeline-friendly
	["a", "b", "c"] |> string.join "," |> print
	"a,b,c" |> string.split "," |> print

	# split with empty separator → individual chars
	"abc" |> string.split "" |> print

	print (string.replace "hello world" "world" "there")

	# round-trip: split then join
	let parts = string.split "1-2-3" "-"
	print (string.join parts ":")
}

def tests :: test.suite = [
	test.case "core-string" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			5
			0
			true
			false
			6
			5
			[h, é, l, l, o]
			HELLO, WORLD!
			hello, world!
			spaced
			true
			false
			true
			true
			a,b,c
			[a, b, c]
			[a, b, c]
			hello there
			1:2:3

			"""
	},
]
