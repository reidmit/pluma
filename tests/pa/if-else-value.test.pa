use std/assert
use std/task
use std/test
use std/sys/io

# `if X is P { ... } else { ... }` as a value expression: both branches must
# agree on type. Used here as a function's tail and as a sub-expression.

def clamp = fun n lo hi {
	if n < lo {
		lo
	} else if n > hi {
		hi
	} else {
		n
	}
}

def run = fun {
	print (clamp 5 0 10)
	print (clamp (0 - 3) 0 10)
	print (clamp 15 0 10)

	# As a sub-expression inside arithmetic
	let bonus = if 3 > 1 {
		100
	} else {
		0
	}
	print (bonus + 1)
}

def tests :: test.suite = [
	test.case "if-else-value" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			5
			0
			10
			101

			"""
	},
]
