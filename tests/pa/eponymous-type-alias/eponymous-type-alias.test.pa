use std/assert
use std/task
use std/test
use std/sys/io
use eponymous-type-alias/shapes/circle as disk

# The eponymous type rides the *alias*: `disk` is both the module namespace
# and the bare type, even though the enum is named `circle`.
def radius-of :: fun disk -> float = fun d {
	when d is disk.radius r {
		r
	}
}

def run = fun {
	let d = disk.radius 2.0
	print (radius-of d)
	print (disk.area d)
}

def tests :: test.suite = [
	test.case "eponymous-type-alias" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			2.0
			12.56

			"""
	},
]
