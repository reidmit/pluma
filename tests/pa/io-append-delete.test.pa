use std/assert
use std/task
use std/test
use std/sys/fs
use std/sys/io

def show-result = fun r {
	when r is ok _ {
		print "ok"
	} is err _ {
		# OS error messages aren't portable — just signal err
		print "err"
	}
}

def run = fun {
	let path = "target/pluma-io-append-delete.txt"

	# ensure known starting state: write empty (creates or truncates)
	show-result (fs.write-text-sync path "")

	# append three lines
	show-result (fs.append-text-sync path "one\n")
	show-result (fs.append-text-sync path "two\n")
	show-result (fs.append-text-sync path "three\n")

	# read it back
	when fs.read-text-sync path is ok contents {
		io.write contents
	} is err msg {
		print "read err: $(msg)"
	}

	# delete it
	show-result (fs.remove-sync path)
	print (fs.is-file-sync path)

	# deleting again should err
	show-result (fs.remove-sync path)
}

def tests :: test.suite = [
	test.case "io-append-delete" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			ok
			ok
			ok
			ok
			one
			two
			three
			ok
			false
			err

			"""
	},
]
