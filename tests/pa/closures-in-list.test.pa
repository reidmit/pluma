use std/assert
use std/task
use std/test
use std/sys/io

enum fn-list {
	empty
	cons (fun int -> int) fn-list
}

def apply-each = fun lst x {
	when lst is fn-list.empty {
		0
	} is fn-list.cons f rest {
		f x + apply-each rest x
	}
}

def run = fun {
	let inc = fun n {
		n + 1
	}
	let double = fun n {
		n * 2
	}
	let triple = fun n {
		n * 3
	}
	let fs = fn-list.cons inc (fn-list.cons double (fn-list.cons triple fn-list.empty))
	print (apply-each fs 10)
}

def tests :: test.suite = [
	test.case "closures-in-list" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out "61\n"
	},
]
