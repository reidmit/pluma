use std/assert
use std/task
use std/test
use std/sys/io

# Sibling nested patterns combine to cover a constructor with no wildcard: the
# exhaustiveness check recurses into a variant's arguments. `err (color.red)` and
# `err (color.green)` together exhaust `err`; deeper `option (option color)`
# nesting works the same way.
enum color {
	red
	green
}

def name :: fun (result int color) -> string = fun r {
	when r is ok v {
		"ok $(to-string v)"
	} is err color.red {
		"red"
	} is err color.green {
		"green"
	}
}

def deep :: fun (option (option color)) -> string = fun o {
	when o is some (some color.red) {
		"r"
	} is some (some color.green) {
		"g"
	} is some none {
		"sn"
	} is none {
		"n"
	}
}

def run = fun {
	print (name (ok 1))
	print (name (err color.red))
	print (name (err color.green))
	print (deep (some (some color.green)))
	print (deep (some none))
	print (deep none)
}

def tests :: test.suite = [
	test.case "pattern-nested-exhaustive" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			ok 1
			red
			green
			g
			sn
			n

			"""
	},
]
