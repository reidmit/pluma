use std/assert
use std/task
use std/test
use std/sys/io

# `defer` inside an async function runs at function exit on the normal path,
# LIFO, even across suspension points (`try`). The cleanups are anchored to
# the task frame and survive each await.

def run = fun {
	defer print "deferred A (last)"
	try task.sleep 1ms
	defer print "deferred B (first)"
	try task.sleep 1ms
	print "body"
	task.return 0
}

def tests :: test.suite = [
	test.case "task-defer" fun {
		try cap = io.capture fun {
			try run ()
			task.return ()
		}
		assert.matches cap.out """
			body
			deferred B (first)
			deferred A (last)

			"""
	},
]
