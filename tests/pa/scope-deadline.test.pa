use std/assert
use std/task
use std/test
use std/sys/io

# `s.cancel-after`: the scope self-cancels once the deadline elapses. Its child
# is cancelled mid-sleep (its `defer` runs), and the cancelled scope surfaces a
# recoverable failure, which `??` turns into a fallback.

def guarded = fun {
	scope as s {
		s.cancel-after 15ms
		let h = s.spawn (slow-child ())
		try v = h
		task.ok v
	}
}

def slow-child = fun {
	defer print "child-cleanup-ran"
	try task.sleep 5s
	task.ok 1
}

def run = fun {
	try v = guarded () ?? task.ok 7
	print (to-string v)
	task.ok 0
}

def tests :: test.suite = [
	test.case "scope-deadline" fun {
		try cap = io.capture fun {
			try run ()
			task.ok ()
		}
		assert.matches cap.out """
			child-cleanup-ran
			7

			"""
	},
]
