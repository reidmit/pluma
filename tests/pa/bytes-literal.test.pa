use std/assert
use std/task
use std/test
use std/sys/io

def run = fun {
	print 'hello'
	print ''
	print '\x89PNG\r\n\x1a\n'
}

def tests :: test.suite = [
	test.case "bytes-literal" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out "'hello'\n''\n'\\x89PNG\\x0d\\x0a\\x1a\\x0a'\n"
	},
]
