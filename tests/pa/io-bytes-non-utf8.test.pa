use std/assert
use std/bytes
use std/task
use std/test
use std/sys/fs
use std/sys/io

def show-write = fun r {
	when r is ok _ {
		print "wrote"
	} is err msg {
		print "write err: $(msg)"
	}
}

def run = fun {
	# Bytes that aren't valid UTF-8 — `fs.read-text-sync` (string version) would
	# fail on these; `read-file-bytes` should round-trip them just fine.
	let path = "target/pluma-io-bytes-invalid.bin"
	let bad = '\xff\xfe\x00\xc0\xc1'

	show-write (fs.write-bytes-sync path bad)

	when fs.read-bytes-sync path is ok b {
		print (to-string (bytes.length b))
		print (to-string (b == bad))
	} is err msg {
		print "read err: $(msg)"
	}

	# Decoding to a string should fail.
	when fs.read-bytes-sync path is ok b {
		when bytes.to-string b is ok _ {
			print "should not decode"
		} is err _ {
			print "decode failed (expected)"
		}
	} is err _ {
		print "read err"
	}
}

def tests :: test.suite = [
	test.case "io-bytes-non-utf8" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			wrote
			5
			true
			decode failed (expected)

			"""
	},
]
