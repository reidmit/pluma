use std/assert
use std/task
use std/test
use std/sys/io

# A `main` that returns `ok` succeeds quietly: the value is discarded and
# the program exits 0, exactly as a `main` returning `nothing` would.
def run = fun {
	print "working"
	ok 0
}

def tests :: test.suite = [
	test.case "main-returns-ok" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out "working\n"
	},
]
