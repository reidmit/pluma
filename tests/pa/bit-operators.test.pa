use std/assert
use std/task
use std/test
use std/sys/io

def run = fun {
	# the six infix operators and the prefix `~`
	print (12 & 10)
	print (12 | 10)
	print (12 ^ 10)
	print (1 << 4)
	print (256 >> 2)
	print (-1 >>> 60)
	print (~0)
	print (~5)
	# `>>` is arithmetic (sign-preserving); `>>>` is logical (zero-fill)
	print (-8 >> 1)
	print (-8 >>> 1)
	# precedence: bitwise binds tighter than comparison (no C footgun)
	print (12 & 10 == 8)
	# among themselves: shifts > & > ^ > | , all looser than +
	print (1 | 2 & 6)
	print (1 + 1 << 2)
	print (16 | 1 ^ 3 & 2)
	# `~` binds like negation (tighter than the infix bit ops)
	print (~0 & 5)
}

def tests :: test.suite = [
	test.case "bit-operators" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			8
			14
			6
			16
			64
			15
			-1
			-6
			-4
			9223372036854775804
			true
			3
			8
			19
			5

			"""
	},
]
