use std/assert
use std/task
use std/test
use std/sys/io

# Generic enum declared with space-separated type params, used at multiple
# instantiations.

enum pair a b {
	both a b
	left a
	right b
	neither
}

def run = fun {
	let p1 = pair.both 1 "one"
	when p1 is pair.both a b {
		print a
		print b
	} is pair.left _ {
		print "left"
		print "x"
	} is pair.right _ {
		print "right"
		print "x"
	} is pair.neither {
		print "neither"
		print "x"
	}

	let p2 = pair.left 42
	if p2 is pair.left a {
		print a
	} else {
		print 0
	}

	let p3 = pair.right "right-only"
	if p3 is pair.right b {
		print b
	} else {
		print "fallback"
	}

	let p4 = pair.neither
	if p4 is pair.neither {
		print "nothing"
	} else {
		print "something"
	}
}

def tests :: test.suite = [
	test.case "generic-enum" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			1
			one
			42
			right-only
			nothing

			"""
	},
]
