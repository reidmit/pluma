use std/assert
use std/task
use std/test
use std/sys/io

# Pluma functions are not curried; `def add5 add 5` would fail because
# `add` requires both args at once. Wrap in a closure to partially apply.

def add = fun a b {
	a + b
}

def add5 = fun y {
	add 5 y
}

def run = fun {
	print (add5 3)
	print (add 10 20)
}

def tests :: test.suite = [
	test.case "partial-application" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			8
			30

			"""
	},
]
