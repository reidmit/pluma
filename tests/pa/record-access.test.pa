use std/assert
use std/task
use std/test
use std/sys/io

# Repeated record field access.

def get-x = fun r {
	when r is {x: v, ...} {
		v
	}
}

def loop = fun n acc {
	if n is 0 {
		acc
	} else {
		loop (n - 1) (acc + get-x {x: n, y: 99, z: "filler"})
	}
}

def run = fun {
	print (to-string (loop 10000 0))
}

def tests :: test.suite = [
	test.case "record-access" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out "50005000\n"
	},
]
