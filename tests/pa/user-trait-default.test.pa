use std/assert
use std/task
use std/test
use std/sys/io

trait greeter a {
	name :: fun a -> string
	greet :: fun a -> string
	def greet = fun x { "hello, $(greeter.name x)" }
}

implement greeter int {
	def name = fun _x {
		"the number"
	}
}

implement greeter bool {
	def name = fun _x {
		"a flag"
	}
	def greet = fun b {
		"explicit: $(greeter.name b)"
	}
}

def run = fun {
	print (greeter.greet 7)
	print (greeter.greet true)
}

def tests :: test.suite = [
	test.case "user-trait-default" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out "hello, the number\nexplicit: a flag\n"
	},
]
