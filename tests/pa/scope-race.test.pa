use std/assert
use std/list
use std/task
use std/test
use std/sys/io

# `manual scope` + `s.next`: spawn everything, take the first to settle, cancel
# the losers. The 2ms sleeper wins; the loser's `defer` runs on cancellation.

def sleeper = fun ms n {
	try task.sleep ms
	task.ok n
}

# A slow child whose cleanup must run when it's cancelled as a race loser.
def slow = fun label {
	defer print label
	try task.sleep 5s
	task.ok 0
}

def race = fun ts {
	manual scope as s {
		list.map ts fun t {
			s.spawn t
		}
		try first = s.next ()
		s.cancel ()
		when first is some r {
			when r is ok v {
				task.ok v
			} is err e {
				task.err e
			}
		} is none {
			task.err "race: empty"
		}
	}
}

def run = fun {
	try w = race [slow "loser-cleanup-ran", sleeper 2ms 42]
	print (to-string w)
	task.ok 0
}

def tests :: test.suite = [
	test.case "scope-race" fun {
		try cap = io.capture fun {
			try run ()
			task.ok ()
		}
		assert.matches cap.out """
			loser-cleanup-ran
			42

			"""
	},
]
