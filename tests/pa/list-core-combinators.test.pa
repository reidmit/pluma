use std/assert
use std/list
use std/task
use std/test
use std/sys/io

# Core list combinators, with attention to the trait-constrained reductions
# (sum/product over `numeric`, min/max over `ord`) whose dict passing is the
# interesting case for WASM.

def run = fun {
	print (list.last [1, 2, 3])
	print (list.range 0 5)
	print (list.zip [1, 2, 3] [10, 20])
	let (firsts, seconds) = list.unzip [(1, 10), (2, 20), (3, 30)]
	print firsts
	print seconds
	print (list.flat-map [1, 2, 3] fun n {
		[n, n * 10]
	})
	print (list.flatten [[1, 2], [], [3, 4], [5]])
	print (list.find-index [10, 20, 30] fun n {
		n > 15
	})
	print (list.index-of ["a", "b", "c"] "b")
	print (list.count [1, 2, 3, 4, 5, 6] fun n {
		n % 2 == 0
	})
	print (list.min [3, 1, 4, 1, 5])
	print (list.max [3, 1, 4, 1, 5])
	print (list.sum [1, 2, 3, 4] ?? 0)
	print (list.product [1, 2, 3, 4] ?? 1)
	print (list.sum [1.5, 2.5, 3.0])
}

def tests :: test.suite = [
	test.case "list-core-combinators" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			option.some 3
			[0, 1, 2, 3, 4]
			[(1, 10), (2, 20)]
			[1, 2, 3]
			[10, 20, 30]
			[1, 10, 2, 20, 3, 30]
			[1, 2, 3, 4, 5]
			option.some 1
			option.some 1
			3
			option.some 1
			option.some 5
			10
			24
			option.some 7.0

			"""
	},
]
