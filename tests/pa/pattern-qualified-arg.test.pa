use std/assert
use std/task
use std/test
use std/sys/io

# A qualified variant works as a constructor argument without parens --
# `err color.red`, `err shapes.color.red` (module.enum.variant) -- mirroring how
# it already worked as a whole pattern (`is color.red`). A variant that itself
# takes arguments still needs parens (`ok (box.wrap n)`).
enum color {
	red
	green
}

enum box {
	wrap int
}

# nested qualified nullary variant as a constructor arg, no parens
def name-color :: fun (result int color) -> string = fun r {
	if r is err color.red {
		"red"
	} else if r is err color.green {
		"green"
	} else {
		"ok"
	}
}

# payload variant as an arg still uses parens
def unwrap :: fun (result box int) -> int = fun r {
	when r is ok (box.wrap n) {
		n
	} else {
		0 - 1
	}
}

def run = fun {
	print (name-color (err color.red))
	print (name-color (err color.green))
	print (name-color (ok 9))
	print (to-string (unwrap (ok (box.wrap 7))))
}

def tests :: test.suite = [
	test.case "pattern-qualified-arg" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out """
			red
			green
			ok
			7

			"""
	},
]
