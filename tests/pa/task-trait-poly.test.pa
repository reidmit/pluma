use std/assert
use std/task
use std/test
use std/sys/io

# A function that is BOTH async (it awaits via `try`) AND trait-polymorphic
# (its element type stays free, so `+`/`>` need a numeric/ord dict param). The
# constrained def must compile to an `AsyncFn` — calling it builds a cold task —
# not a plain closure that runs eagerly and hits `Await` outside the driver.
# Regression for the combination missing the async wrapper in
# `compile_constrained_thunk`. Exercised at int and float (per-call-site dicts)
# and with an ord dispatch.

def add-tasks :: fun (task a) (task a) -> task a = fun x y {
	try p = x
	try q = y
	task.ok (p + q)
}

def bigger :: fun (task a) (task a) -> task bool = fun x y {
	try p = x
	try q = y
	task.ok (p > q)
}

def run = fun {
	try i = add-tasks (task.ok 100) (task.ok 23)
	try f = add-tasks (task.ok 1.5) (task.ok 2.25)
	try b = bigger (task.ok 5) (task.ok 9)
	print (to-string i)
	print (to-string f)
	print (to-string b)
	task.ok 0
}

def tests :: test.suite = [
	test.case "task-trait-poly" fun {
		try cap = io.capture fun {
			try _outcome = task.attempt (run ())
			task.ok ()
		}
		assert.matches cap.out """
			123
			3.75
			false

			"""
	},
]
