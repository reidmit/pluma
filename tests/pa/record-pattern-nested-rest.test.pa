use std/assert
use std/task
use std/test
use std/sys/io

# Nested rest: a record inside another record's pattern, each with its
# own `...rest`. Confirms the row variables are independent.
def run = fun {
	let r = {outer: 1, inner: {a: 10, b: 20, c: 30}, tag: "hi"}

	# Destructure outer, then pattern-match inner via `when`.
	when r is {inner: i, ...outer-rest} {
		# outer-rest carries the non-`inner` fields
		print (to-string outer-rest.outer)
		print outer-rest.tag

		# Now match against the inner record
		when i is {a: av, ...inner-rest} {
			print (to-string av)
			print (to-string inner-rest.b)
			print (to-string inner-rest.c)
		}
	}

	# `let` also threads through nested rests irrefutably.
	let {inner: {a: aa, ...inner-rest2}, ...outer-rest2} = r
	print (to-string aa)
	print (to-string inner-rest2.b)
	print outer-rest2.tag
}

def tests :: test.suite = [
	test.case "record-pattern-nested-rest" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			1
			hi
			10
			20
			30
			10
			20
			hi

			"""
	},
]
