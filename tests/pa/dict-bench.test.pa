use std/assert
use std/dict
use std/task
use std/test
use std/sys/io

# Dict stress: insert N string-keyed entries, then look every one back up and
# sum the values. Exercises the pure-Pluma hash dict (string hashing, bucket
# probing) on both insert and lookup paths.

def fill = fun m n {
	if n is 0 {
		m
	} else {
		fill (dict.insert m (to-string n) n) (n - 1)
	}
}

def sum-lookups = fun m n acc {
	if n is 0 {
		acc
	} else {
		let v = dict.lookup m (to-string n) ?? 0
		sum-lookups m (n - 1) (acc + v)
	}
}

def run = fun {
	let m = fill (dict.empty ()) 600
	print (to-string (sum-lookups m 600 0))
}

def tests :: test.suite = [
	test.case "dict-bench" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out "180300\n"
	},
]
