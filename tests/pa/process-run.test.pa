use std/assert
use std/list
use std/string
use std/task
use std/test
use std/sys/io
use std/sys/process

# Exercises the std/sys/process subprocess surface against small, portable commands (echo /
# cat / sh) so the output is stable across platforms. Each line names what it checks:
#   - run captures stdout, a clean exit is status 0
#   - a nonzero exit is a *successful* run carrying that code, not a task failure
#   - run-with pipes stdin through `cat`
#   - check yields stdout on success
#   - shell runs a /bin/sh command line
#   - exec inherits the terminal (status only; no captured output)
#   - which / pid / env-all are checked for shape only, since paths, ids, and the ambient
#     environment vary by machine.

def run = fun {
	try r = process.run "echo" ["hello", "world"]
	print "run: status=$(to-string r.status) out=$(string.trim r.stdout) ok=$(to-string (process.succeeded r))"
	try f = process.run "sh" ["-c", "echo boom 1>&2; exit 3"]
	print "nonzero: status=$(to-string f.status) stderr=$(string.trim f.stderr) ok=$(to-string (process.succeeded f))"
	try c = process.run-with {cmd: "cat", args: [], cwd: none, env: [], stdin: "piped"}
	print "stdin: $(string.trim c.stdout)"
	try h = process.check "echo" ["checked"]
	print "check: $(string.trim h)"
	try s = process.shell "echo one && echo two"
	print "shell: $(string.trim s.stdout)"
	try code = process.exec "sh" ["-c", "exit 7"]
	print "exec: status=$(to-string code)"
	when process.which "sh" is some _ {
		print "which: sh found"
	} is none {
		print "which: sh missing"
	}
	when process.which "pluma-no-such-binary-xyz" is some _ {
		print "which: bogus found"
	} is none {
		print "which: bogus missing"
	}
	print "pid: positive=$(to-string (process.pid () > 0))"
	let envs = process.env-all ()
	let named = list.all envs fun e {
		string.length e.key > 0
	}
	print "env-all: non-empty=$(to-string (list.length envs > 0)) all-named=$(to-string named)"
	task.ok ()
}

def tests :: test.suite = [
	test.case "process-run" fun {
		try cap = io.capture fun {
			try _outcome = task.attempt (run ())
			task.ok ()
		}
		assert.matches cap.out """
			run: status=0 out=hello world ok=true
			nonzero: status=3 stderr=boom ok=false
			stdin: piped
			check: checked
			shell: one
			two
			exec: status=7
			which: sh found
			which: bogus missing
			pid: positive=true
			env-all: non-empty=true all-named=true

			"""
	},
]
