use std/assert
use std/task
use std/test
use std/sys/io

# Float stress: approximate pi with the Leibniz series, tail-recursively. Pure
# float arithmetic (+ - / and int->float) in a tight loop.

def leibniz = fun n acc sign k {
	when n is 0 {
		acc
	} else {
		leibniz (n - 1) (acc + sign / k) (0.0 - sign) (k + 2.0)
	}
}

def run = fun {
	print (to-string (leibniz 8000 0.0 4.0 1.0))
}

def tests :: test.suite = [
	test.case "float-bench" fun {
		try cap = io.capture fun {
			run ()
			task.return ()
		}
		assert.matches cap.out "3.141467653590268\n"
	},
]
