use std/assert
use std/regex
use std/task
use std/test
use std/sys/io

def hello = `"hello"`

def run = fun {
	print (regex.matches hello "hello, world!")
	print (regex.matches hello "goodbye, world!")
	print (regex.matches hello "hello")
	print (regex.matches hello "")
}

def tests :: test.suite = [
	test.case "regex-matches" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			true
			false
			true
			false

			"""
	},
]
