use std/assert
use std/task
use std/test
use std/sys/io

def double = fun x {
	x + x
}

def quadruple = fun x {
	double (double x)
}

def run = fun {
	print (quadruple 5)
	print (quadruple 1.5)
}

def tests :: test.suite = [
	test.case "quadruple-forwarding" fun {
		try cap = io.capture fun {
			run ()
			task.ok ()
		}
		assert.matches cap.out """
			20
			6.0

			"""
	},
]
