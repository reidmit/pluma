# The formatter canonicalizes `is true` to the bare form for `if`/`while`,
# while leaving every other pattern (`is 0`, `is ok x`) untouched.

def report = fun n {
	if n > 0 is true {
		print "positive"
	} else if n is 0 {
		print "zero"
	} else {
		print "negative"
	}

	let r = ok n
	if r is ok x {
		print (to-string x)
	}

	while n > 0 is true {
		print "spin"
	}
}
