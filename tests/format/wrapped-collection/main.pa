# A collection literal too wide for one line wraps one item per line, keeps
# its commas (Pluma list/record/tuple literals are comma-separated in either
# layout), and gets a trailing comma on the last item. Lists, records, and
# tuples all behave the same. The format harness re-parses the output, so a
# dropped comma here would fail the test, not just change the snapshot.
def wide-list = [100, 200, 300, 400, 500, 600, 700, 800, 900, 1000, 1100, 1200, 1300, 1400, 1500, 1600, 1700]

def wide-record = {alpha: 1, bravo: 2, charlie: 3, delta: 4, echo: 5, foxtrot: 6, golf: 7, hotel: 8, india: 9}

def wide-tuple = (1000000, 2000000, 3000000, 4000000, 5000000, 6000000, 7000000, 8000000, 9000000, 10000000)

def short-stays-flat = [1, 2, 3]
