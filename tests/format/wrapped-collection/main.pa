# A collection literal too wide for one line wraps one item per line — and
# must keep its commas (Pluma list/record literals are comma-separated in
# either layout). The format harness re-parses the output, so a dropped
# comma here would fail the test, not just change the snapshot.
def wide-list = [100, 200, 300, 400, 500, 600, 700, 800, 900, 1000, 1100, 1200, 1300, 1400, 1500, 1600, 1700]

def wide-record = {alpha: 1, bravo: 2, charlie: 3, delta: 4, echo: 5, foxtrot: 6, golf: 7, hotel: 8, india: 9}
