use std.list

# A `fun` literal in argument position needs no wrapping parens: its `{...}`
# body delimits where the lambda ends, so the formatter strips them. The
# multi-line body stays attached to the call (Pluma application is
# newline-terminated; the body's line breaks live inside its own braces).
def sum-plus-one = fun xs {
	list.fold xs 0 (fun acc x {
		let y = x + 1
		acc + y
	})
}

# Nested: parens are stripped around each `fun`, but the parens around the
# inner `list.filter` call — itself an argument to `list.map` — are kept.
def doubled-evens = fun xs {
	list.map (list.filter xs (fun x { x % 2 == 0 })) (fun x {
		x * 2
	})
}
