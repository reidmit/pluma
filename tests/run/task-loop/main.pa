# `await` inside a `while` loop. A task `try` is type-transparent to its
# continuation, so it can sit in a loop body (which stays `nothing`-typed) while
# still suspending each iteration; the function is async because its tail is a
# task (`task.return`). On the frame-snapshot runtime the whole frame (loop IP +
# locals) is saved at each suspension; the CPS pass flattens the loop's back-edge
# into the dispatch loop and threads the loop-carried `ref`s/binds through state.
use std/task

def main = fun {
	let total = ref.new 0
	let cursor = ref.new [1, 2, 3, 4]
	while ref.get cursor is [head, ...tail] {
		try task.sleep 1ms
		ref.update total fun n {
			n + head
		}
		ref.set cursor tail
	}
	print (to-string (ref.get total))
	task.return 0
}
