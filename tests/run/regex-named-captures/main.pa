use std.regex

# Named captures compile to `(?P<name>...)`. The captured substrings
# are surfaced through `regex.find` (see regex-find fixture) — this
# fixture pins the matching behavior.
def coord = `"(" <x: digit+> "," <y: digit+> ")"`

def main = fun {
	print (regex.matches coord "(3,7)")
	print (regex.matches coord "(12,99)")
	print (regex.matches coord "(a,b)")
	print (regex.matches coord "(3,)")
}
