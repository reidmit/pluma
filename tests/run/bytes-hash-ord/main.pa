use core.map

def main = fun {
	# bytes as map keys — exercises hash bytes
	let m = map.empty ()
	let m = map.insert m 'GET' 1
	let m = map.insert m 'POST' 2
	let m = map.insert m 'PUT' 3
	when (map.lookup m 'POST') is some v { print v } is none { print -1 }
	when (map.lookup m 'GET') is some v { print v } is none { print -1 }
	when (map.lookup m 'DELETE') is some v { print v } is none { print -1 }

	# ord bytes — exercise compare
	print (compare 'abc' 'abd')
	print (compare 'abc' 'abc')
	print (compare 'abd' 'abc')
	print (compare '' 'a')
}
