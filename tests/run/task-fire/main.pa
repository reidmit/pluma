# `task.fire t f` = `spawn (map t f)`: run `t` detached, hand its result to `f`.
# Fire two tasks into a ref, yield so the detached fibers settle, then read it.
use std/task

def main = fun {
	let log = ref.new []
	task.fire (task.return 42) fun n {
		ref.set log [...ref.get log, n]
	}
	task.fire (task.return 7) fun n {
		ref.set log [...ref.get log, n]
	}
	# Let the spawned fibers run before we read the result.
	try _ = task.yield ()
	print (to-string (ref.get log))
	task.return 0
}
