# A view that uses the full handler surface (on-input/on-change/on-submit
# reference the relocated `std/event` builtins) and renders to an HTML string.
# Guards that the server-renderable view path links and renders: handlers are
# dropped, text/attrs escaped, void elements self-close, properties become attrs.

use std/view
use std/sys/io

def field :: fun nothing -> view = fun {
	using view {
		.form [.on-submit fun { io.print "submit" }] [
			.input [
				.input-type "text",
				.property "value" "a & b",
				.placeholder "name <here>",
				.on-input io.print,
				.on-change io.print,
			] [],
			.button [.on-click fun { io.print "go" }] [.text "Save"],
		]
	}
}

def main = fun {
	io.print (view.to-string (field ()))
}
