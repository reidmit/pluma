# `rpc.with-headers` attaches scoped outbound headers to the calls inside it —
# the one thing the old `request` argument bought at a call site, now ambient. A
# fake transport (installed with `rpc.configure`) records the headers of each call
# so we can see what `call-unary` sent: a bare call carries only the route
# fingerprint; a call inside `with-headers` also carries the scoped header; nested
# scopes merge with the inner key winning; and once the scope ends the header is
# gone again. The header travels through a task-local, so it survives the `try`
# inside the call without threading through any signature.
use std/dict
use std/rpc
use std/string
use std/task

# Records the headers of the most recent call; echoes the body back unchanged.
def captured :: ref (dict string string) = ref.new (dict.empty ())

def fake :: rpc.sender = fun _route body headers {
	let _ = ref.set captured headers
	task.return body
}

def header-of :: fun string -> string = fun key {
	when dict.lookup (ref.get captured) key is some v {
		v
	} is none {
		"<absent>"
	}
}

def call :: fun string -> task bytes = fun fp {
	rpc.call-unary "api.echo" fp (string.to-bytes "x")
}

def main = fun {
	let _ = rpc.configure fake

	# A bare call: only the fingerprint header is attached.
	try _ = call "fp-1"
	let bare-trace = header-of "x-trace-id"
	let bare-fp = header-of "x-rpc-fingerprint"
	print "bare trace -> $(bare-trace)"
	print "bare fp -> $(bare-fp)"
	try _ = rpc.with-headers [("x-trace-id", "abc")] fun {
		# Inside with-headers: the scoped header rides along, fingerprint still there.
		call "fp-2"
	}
	let scoped-trace = header-of "x-trace-id"
	let scoped-fp = header-of "x-rpc-fingerprint"
	print "scoped trace -> $(scoped-trace)"
	print "scoped fp -> $(scoped-fp)"
	try _ = rpc.with-headers [("x-trace-id", "outer")] fun {
		# Nested scopes merge; the inner binding wins for a shared key.

		rpc.with-headers [("x-trace-id", "inner")] fun {
			call "fp-3"
		}
	}
	let nested-trace = header-of "x-trace-id"
	print "nested trace -> $(nested-trace)"
	try _ = call "fp-4"
	let after-trace = header-of "x-trace-id"
	print "after trace -> $(after-trace)"
	task.return 0
}

# Back outside every scope: the binding is gone again.

