def main = fun {
	# Positional element access `.N` on a concrete tuple, across element types.
	let t = (10, 20, 30)
	print (to-string (t.0 + t.1 + t.2))

	let pair = ("hello", 42)
	print pair.0
	print (to-string pair.1)

	# Nested tuples — chained positional access parses directly (`nested.0.0`).
	# The parenthesized form `(nested.0).0` is equivalent and the formatter
	# canonicalizes it to the chained spelling.
	let nested = ((1, 2), (3, 4))
	print (to-string (nested.0.0 + nested.1.1))
	print (to-string (nested.0.0 + nested.1.1))

	# Chaining nests arbitrarily deep.
	let deep = (((100, 200), 0), 0)
	print (to-string deep.0.0.1)
}
