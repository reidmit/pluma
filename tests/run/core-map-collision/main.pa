use core.map

# All variants hash to the same int — every key lands in the same
# bucket, so insert / lookup / remove must walk the collision chain.
enum color {
	red
	green
	blue
}

implement hash color {
	def hash = fun _c { 42 }
}

def main = fun {
	let m = map.empty ()
	let m = map.insert m red "r"
	let m = map.insert m green "g"
	let m = map.insert m blue "b"
	print (map.size m)
	when (map.lookup m red)   is some s { print s } is none { print "?" }
	when (map.lookup m green) is some s { print s } is none { print "?" }
	when (map.lookup m blue)  is some s { print s } is none { print "?" }
	# Remove the middle entry; the others must still resolve.
	let m = map.remove m green
	print (map.size m)
	print (map.contains-key m green)
	when (map.lookup m red)  is some s { print s } is none { print "?" }
	when (map.lookup m blue) is some s { print s } is none { print "?" }
}
