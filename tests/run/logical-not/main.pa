# `!` is the prefix logical-not operator.

def main = fun {
	print (to-string (!true))
	print (to-string (!false))

	# Composes with comparison and in `if` subjects.
	let x = 5
	print (to-string (!x == 5))
	if !x > 10 {
		print "x is not big"
	} else {
		print "x is big"
	}

	# Double negation.
	print (to-string (!!true))
}
