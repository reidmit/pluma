# Structured-log rendering: both formats, every field constructor, and the
# level labels. Drives the pure `log.render` seam with a fixed instant so the
# output is deterministic (the live `log.info`/`emit` path stamps `time.now`).
use std/json
use std/time
use std/sys/log

# 2024-05-25T14:30:00Z
def at :: instant = time.from-unix 1716647400

def fields :: list log.field = [
	log.str "path" "/docs",
	log.int "status" 200,
	log.float "ratio" 0.5,
	log.bool "cache-hit" true,
	log.raw "tags" (json.value.array [json.value.string "a", json.value.string "b"]),
]

def main = fun {
	# text form: a bare message, then one carrying every field type
	print (log.render log.format.text at log.level.info "starting up" [])
	print (log.render log.format.text at log.level.warn "served page" fields)

	# json form: one object per line, scalars keep their JSON type
	print (log.render log.format.json at log.level.info "starting up" [])
	print (log.render log.format.json at log.level.error "served page" fields)

	# every level label / name renders
	print (log.render log.format.text at log.level.debug "d" [])
	print (log.render log.format.json at log.level.debug "d" [])
}
