# `manual scope` + `s.next`: spawn everything, take the first to settle, cancel
# the losers. The 2ms sleeper wins; the loser's `defer` runs on cancellation.
use std/list
use std/task

def sleeper = fun ms n {
	try task.sleep ms
	task.return n
}

# A slow child whose cleanup must run when it's cancelled as a race loser.
def slow = fun label {
	defer print label
	try task.sleep 5s
	task.return 0
}

def race = fun ts {
	manual scope as s {
		list.map ts fun t {
			s.spawn t
		}
		try first = s.next ()
		s.cancel ()
		when first is some r {
			when r is ok v {
				task.return v
			} is err e {
				task.fail e
			}
		} is none {
			task.fail "race: empty"
		}
	}
}

def main = fun {
	try w = race [slow "loser-cleanup-ran", sleeper 2ms 42]
	print (to-string w)
	task.return 0
}
