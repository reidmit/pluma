# The schema fingerprint: a stable structural
# hash of a type's wire schema. Identical shapes hash identically; any drift
# (reordered/added/renamed/retyped fields or variants) changes the hash, so a
# stale client decoding a new server's bytes can be rejected up front instead
# of silently decoding garbage.

enum status-v1 {
	active
	suspended
	banned
}

enum status-v2 {
	banned
	suspended
	active
}

def main = fun {
	# Same shape (recomputed) → same fingerprint; drift → different.
	let a = wire.fingerprint {id: 1, name: "x"}
	let b = wire.fingerprint {id: 2, name: "y"}
	print "same shape agrees: $(to-string (a == b))"

	let v1 = wire.fingerprint status-v1.active
	let v2 = wire.fingerprint status-v2.active
	print "reordered enum differs: $(to-string (v1 == v2))"

	if v1 == v2 {
		print "match -> decode"
	} else {
		print "skew -> reject (reload)"
	}
}
