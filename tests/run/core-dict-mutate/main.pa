# A dict is mutable: insert/remove change it in place, and two bindings to
# the same dict are two views of one thing (like a `ref`).

use core.dict

def main = fun {
	let d = dict.empty ()
	dict.insert d "x" 1
	dict.insert d "y" 2
	# `alias` and `d` are the same dict — a write through one shows in the other.
	let view = d
	dict.insert view "z" 3
	print (dict.size d)
	# 3 — the insert through `view` is visible here
	print (dict.keys d)
	# [x, y, z] — insertion order preserved

	# Replacing a key updates in place; size is unchanged.
	dict.insert d "x" 99
	print (dict.size d)
	# 3
	print (dict.lookup d "x" ?? 0)
	# 99

	# Remove mutates in place.
	dict.remove d "y"
	print (dict.size d)
	# 2
	print (dict.keys d)
	# [x, z]
	print (dict.contains-key d "y")
	# false

	# map/filter are non-destructive — they build a new dict, `d` is untouched.
	let doubled = dict.map d fun v {
		v * 2
	}
	print (dict.values doubled)
	# [198, 6]
	print (dict.values d)
	# [99, 3] — unchanged

	# `update` is a single-probe read-modify-write: f sees the current value
	# (or none), and returns the new one. The counter idiom:
	let counts = dict.empty ()
	let bump = fun w {
		dict.update counts w fun cur {
			(cur ?? 0) + 1
		}
	}
	let _ = bump "a"
	let _ = bump "b"
	let _ = bump "a"
	let _ = bump "a"
	print (dict.lookup counts "a" ?? 0)
	# 3
	print (dict.lookup counts "b" ?? 0)
	# 1
	print (dict.size counts)
	# 2

	# `clear` empties in place.
	dict.clear counts
	print (dict.size counts)
	# 0
	print (dict.contains-key counts "a")
}

# false

