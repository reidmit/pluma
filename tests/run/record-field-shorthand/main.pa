# Field shorthand in record literals and patterns.
#
# `{a, b}` in an expression means `{a: a, b: b}` — the value of each
# field comes from the in-scope binding of the same name.
#
# `{a, b}` in a pattern binds variables `a` and `b` to the matching
# field values — same as `{a: a, b: b}`.

def make-person = fun name age {
	{name, age}
}

def main = fun {
	# shorthand literal
	let reid = make-person "reid" 28
	print reid.name
	print (to-string reid.age)

	# mixing shorthand and explicit
	let role = "engineer"
	let team = "platform"
	let p = {role, team, level: 3}
	print p.role
	print p.team
	print (to-string p.level)

	# shorthand in a let pattern
	let {name, age} = reid
	print name
	print (to-string age)

	# shorthand in a when pattern, with `...` to ignore extras
	when p is {role, ...} {
		print role
	}

	# mix shorthand + explicit binding in a pattern
	when p is {role: r, team, ...} {
		print r
		print team
	}
}
