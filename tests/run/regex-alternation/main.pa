def yes-or-no /"yes" | "no"/

def label-then-color /"color: " ("red" | "green" | "blue")/

def main fun {
  print (to-string (matches yes-or-no "yes"))
  print (to-string (matches yes-or-no "no"))
  print (to-string (matches yes-or-no "maybe"))

  print (to-string (matches label-then-color "color: red"))
  print (to-string (matches label-then-color "color: blue"))
  print (to-string (matches label-then-color "color: purple"))
}
