use core.bytes
use core.io

def show-write = fun r {
	when r is ok _ { print "wrote" }
	is err msg { print "write err: $(msg)" }
}

def main = fun {
	let path = "target/pluma-io-bytes-roundtrip.bin"
	let payload = '\x89PNG\r\n\x1a\n\x00\x01\x02'

	show-write (io.write-file-bytes path payload)

	when (io.read-file-bytes path) is ok b {
		print (to-string (bytes.length b))
		print (to-string b)
		print (to-string (b == payload))
	} is err msg {
		print "read err: $(msg)"
	}
}
