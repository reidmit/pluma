def color enum {
  red
  green
  blue
}

def main fun {
  # primitives
  print (to-string ("hello" == "hello"))
  print (to-string ("hello" == "world"))
  print (to-string (true == true))
  print (to-string (true == false))

  # nothing
  print (to-string (() == ()))

  # tuples (structural)
  print (to-string ((1, "a") == (1, "a")))
  print (to-string ((1, "a") == (1, "b")))

  # records (field order doesn't matter)
  print (to-string ({x: 1, y: 2} == {x: 1, y: 2}))
  print (to-string ({y: 2, x: 1} == {x: 1, y: 2}))
  print (to-string ({x: 1, y: 2} == {x: 1, y: 3}))

  # enum variants
  print (to-string (color.red == color.red))
  print (to-string (color.red == color.blue))

  # lists
  print (to-string ([1, 2, 3] == [1, 2, 3]))
  print (to-string ([1, 2, 3] == [1, 2]))
  print (to-string ([1, 2, 3] == [1, 2, 4]))
}
