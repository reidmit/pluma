# Recursive types on the wire. A recursive enum can't
# expand to a finite schema tree, so the codec cuts back-edges with a by-name
# `s-enum-ref` and resolves them against the enclosing inline definition as it
# descends — the value's finite depth drives termination.

use std.hex

enum tree {
	leaf int
	node tree tree
}

# Recursion through a list, plus multiple recursive variants.
enum json {
	jnull
	jnum int
	jstr string
	jarr (list json)
}

def sum-tree :: fun tree -> int = fun t {
	when t is tree.leaf n {
		n
	} is tree.node l r {
		sum-tree l + sum-tree r
	}
}

def main = fun {
	let t = tree.node (tree.node (tree.leaf 1) (tree.leaf 2)) (tree.leaf 3)
	let encoded = wire.encode t
	print "tree bytes: $(hex.encode encoded)"
	let back :: result tree wire-error = wire.decode encoded
	when back is ok t2 {
		print "tree sum: $(to-string (sum-tree t2))"
	} is err _e {
		print "tree failed"
	}

	let j = json.jarr [json.jnum 1, json.jstr "hi", json.jarr [json.jnull, json.jnum 2]]
	let j2 :: result json wire-error = wire.decode (wire.encode j)
	when j2 is ok v {
		print "json round-trips: $(to-string (v == j))"
	} is err _e {
		print "json failed"
	}
}
