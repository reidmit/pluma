# Async fs over the BlockingPool. The `std.sys.fs` ops run on a host worker
# thread rather than the single scheduler thread: each parks its fiber on the I/O reactor
# while `std::fs` runs off-thread, then settles the produced `result`. A write -> append ->
# read roundtrip exercises the bytes-through-scratch offload path end to end, `stat` and
# `is-file` the metadata/query path, and a read of a missing file the error path (the OS
# message arrives on the `err` side).
use std/task
use std/sys/fs

def main = fun {
	let path = "target/pluma-offload-fs-test.txt"
	try _ = fs.write-text path "hello "
	try _ = fs.append-text path "worker thread"
	try text = fs.read-text path
	print text
	try info = fs.stat path
	print (to-string info.size)
	try yes = fs.is-file path
	print yes
	try _ = fs.remove path
	# a read of a missing file fails the task; reify it with `task.attempt`
	try missing = task.attempt (fs.read-text "target/no-such-offload-file-xyz.txt")
	when missing is ok _ {
		print "unexpected ok"
	} is err _ {
		print "read missing: err"
	}
	task.return 0
}
