# Regression: a function-call result followed by ` - ` is binary
# subtraction, not a negated argument. `double 10 - triple 2` must read as
# `(double 10) - (triple 2)`, not `double 10 (-(triple 2))` (an arity error).
def double = fun x { x * 2 }

def triple = fun x { x * 3 }

def main = fun {
	print (double 10 - triple 2)
	print (double 10 - 5)
}
