use std/list
use std/string
use std/sys/fs

# Write a couple of temp files into `target/`, list the directory back
# (filtered to our prefix so other build artifacts don't perturb the
# snapshot), then clean up. Also exercises `is-dir` and the err path.

def mine = fun name {
	string.starts-with name "pluma-rdtest-"
}

def main = fun {
	let a = "target/pluma-rdtest-1.txt"
	let b = "target/pluma-rdtest-2.txt"
	let _w1 = fs.write-text-sync a "one"
	let _w2 = fs.write-text-sync b "two"

	print (fs.is-dir-sync "target")
	print (fs.is-dir-sync a)

	when fs.read-dir-sync "target" is ok entries {
		let ours = list.filter entries mine
		let _ = list.each ours fun e {
			print e
		}
	} is err msg {
		print "read-dir err: $(msg)"
	}

	when fs.read-dir-sync "target/no-such-dir-xyz" is ok _ {
		print "unexpected ok"
	} is err _ {
		print "err on missing dir"
	}

	let _d1 = fs.remove-sync a
	let _d2 = fs.remove-sync b
	print "done"
}
