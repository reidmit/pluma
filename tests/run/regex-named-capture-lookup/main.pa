use core.regex as re

# `named-capture` is the shortcut for "first match → group by name".
# Skips materializing the whole match record.

def pair = `<k: letter+> "=" <v: digit+>`

def show = fun o {
	when o is some s { print s } is none { print "—" }
}

def main = fun {
	show (re.named-capture pair "size=42 height=10" "k")
	show (re.named-capture pair "size=42 height=10" "v")

	# Missing name — `none`, not an error.
	show (re.named-capture pair "size=42" "nope")

	# No match — also `none`.
	show (re.named-capture pair "size = 42" "k")
}
