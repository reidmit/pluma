# An HTTP/1.1 request/response over loopback, all in one process: a real
# std/sys/http server (its accept/read/parse/serialize/write loop) talks to a
# hand-written client that sends a raw GET and reads the raw reply. The
# server runs under a scope that's cancelled once the exchange is done.
# Output is the (deterministic) status line and body the client received.
use std/bytes
use std/list
use std/string
use std/task
use std/sys/http
use std/sys/net

def handler :: fun http.request -> task http.response = fun req {
	task.return (http.text 200 ("you asked for " ++ req.path))
}

# Read from the connection until the server closes it (Connection: close). The raw
# `std/sys/net` reads carry their failure inside the task (`task (result …)`), so
# `task.unwrap` joins it onto this task's own failure channel and the loop reads linearly.
def drain :: fun net.connection bytes -> task bytes string = fun conn acc {
	try chunk = task.unwrap (net.read conn 4096)
	if bytes.is-empty chunk {
		task.return acc
	} else {
		drain conn (bytes.concat acc chunk)
	}
}

def client :: fun string -> task string = fun addr {
	try conn = task.unwrap (net.connect addr)
	try _ = task.unwrap (net.write conn (string.to-bytes "GET /hello HTTP/1.1\r\nHost: x\r\n\r\n"))
	try raw = drain conn (string.to-bytes "")
	let _ = net.close conn
	task.return (bytes.to-string raw ?? "<bad utf8>")
}

def main = fun {
	if net.listen "127.0.0.1:0" is ok server {
		if net.local-addr server is ok addr {
			scope as s {
				let _ = s.spawn (http.serve-on server handler)
				try raw = client addr
				let status = list.head (string.split raw "\r\n") ?? ""
				let body = list.head (list.drop (string.split raw "\r\n\r\n") 1) ?? ""
				print status
				print body
				s.cancel ()
				task.return 0
			}
		} else {
			print "local-addr failed"
			task.return 1
		}
	} else {
		print "listen failed"
		task.return 1
	}
}
