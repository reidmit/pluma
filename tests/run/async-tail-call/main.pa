# Tail-calling an async function from the ENTRY region of a CPS-lowered function —
# i.e. a branch that reaches a tail-position async call without first suspending,
# in a function that is async because *another* branch awaits. This used to trap:
# `lower` emits the tail call as a frame-reusing `return_call`, but in the poll fn
# the result is wrapped in a `ready`/`pending` variant, so the `return_call` skipped
# the wrapping and handed the callee's raw task to the driver (which trapped casting
# it). The CPS pass now downgrades tail calls in poll fns to ordinary calls.
use std.task

def helper :: fun int -> task int = fun n {
	task.return (n * 10)
}

# `if`/`else`: the `else` arm tail-calls `helper` with no preceding suspension; the
# `if` arm awaits first. Both must work.
def via-if :: fun bool -> task int = fun suspend-first {
	if suspend-first {
		try _ = task.sleep 1ms
		helper 1
	} else {
		helper 2
	}
}

# `when` arms over an enum: the non-suspending arm tail-calls an async fn.
enum choice {
	now
	later
}

def via-when :: fun choice -> task int = fun c {
	when c is choice.now {
		helper 3
	} is choice.later {
		try _ = task.sleep 1ms
		helper 4
	}
}

# Tail-call to a captured async *closure* from the entry region.
def via-closure :: fun bool -> task int = fun suspend-first {
	let g = fun n {
		try _ = task.sleep 1ms
		task.return (n + 100)
	}
	if suspend-first {
		try _ = task.sleep 1ms
		g 5
	} else {
		g 6
	}
}

# Async self-recursion whose recursive call sits in a tail-position arm reached
# after a suspension (the working continuation case) — still correct post-fix.
def count-down :: fun int -> task int = fun n {
	if n > 0 {
		try _ = task.sleep 1ms
		count-down (n - 1)
	} else {
		task.return 42
	}
}

def main = fun {
	try a = via-if false
	try b = via-if true
	print "via-if: $(to-string a) $(to-string b)"
	try c = via-when choice.now
	try d = via-when choice.later
	print "via-when: $(to-string c) $(to-string d)"
	try e = via-closure false
	try f = via-closure true
	print "via-closure: $(to-string e) $(to-string f)"
	try g = count-down 3
	print "count-down: $(to-string g)"
	task.return 0
}
