# `local.with` binds a cell for the dynamic extent of its body, and a nested
# `with` shadows it within its own subtree. Each binding is restored on the way
# out — by the `defer`'d teardown — so reads before/inside/after see default,
# bound, shadowed, bound-again, default. Reads survive the `try` suspensions.
use std/local
use std/task

def trace :: local string = local.new "-"

def show :: fun string -> task nothing = fun label {
	try _ = task.sleep 1ms
	print "$(label): $(local.get trace)"
	task.return ()
}

def main = fun {
	try _ = show "before"
	try _ = local.with trace "outer" fun {
		try _ = show "inside"
		try _ = local.with trace "inner" fun {
			try _ = show "nested"
			task.return ()
		}
		try _ = show "back"
		task.return ()
	}
	try _ = show "after"
	task.return ()
}
