# A propagation chain built by hand with `error.context`: each layer names
# what it was doing, the leaf the root cause. `message` renders the chain on
# one line; `trace` gives the frames as a list.
use std/error

def root :: fun nothing -> error = fun {
	error.new "connection refused"
}

def main = fun {
	let e = error.context "loading user 7" (error.context "querying db" (root ()))
	print (error.message e)
	print (to-string (error.trace e))
}
