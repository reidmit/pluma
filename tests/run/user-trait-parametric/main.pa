trait showable a {
	show :: fun a -> string
}

implement showable int {
	def show = fun x { to-string x }
}

implement showable (option a) where (showable a) {
	def show = fun o {
		when o is some v { "some $(showable.show v)" }
		is none { "none" }
	}
}

def main = fun {
	print (showable.show 42)
	print (showable.show (some 7))
	print (showable.show (some (some 99)))
}
