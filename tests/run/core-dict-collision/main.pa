use std/dict

# Enum keys with a user `hash` instance — exercises enum keys through
# insert / lookup / remove (the backend keys on the structural `__hash`).
enum color {
	red
	green
	blue
}

implement hash color {
	def hash = fun _c {
		42
	}
}

def main = fun {
	let m = dict.empty ()
	let m = dict.insert m color.red "r"
	let m = dict.insert m color.green "g"
	let m = dict.insert m color.blue "b"
	print (dict.size m)
	when dict.lookup m color.red is some s {
		print s
	} is none {
		print "?"
	}
	when dict.lookup m color.green is some s {
		print s
	} is none {
		print "?"
	}
	when dict.lookup m color.blue is some s {
		print s
	} is none {
		print "?"
	}

	# Remove the middle entry; the others must still resolve.
	let m = dict.remove m color.green
	print (dict.size m)
	print (dict.contains-key m color.green)
	when dict.lookup m color.red is some s {
		print s
	} is none {
		print "?"
	}
	when dict.lookup m color.blue is some s {
		print s
	} is none {
		print "?"
	}
}
