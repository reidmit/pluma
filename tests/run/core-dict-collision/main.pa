use core.dict

# All variants hash to the same int — every key lands in the same
# bucket, so insert / lookup / remove must walk the collision chain.
enum color {
	red
	green
	blue
}

implement hash color {
	def hash = fun _c {
		42
	}
}

def main = fun {
	let m = dict.empty ()
	let m = dict.insert m red "r"
	let m = dict.insert m green "g"
	let m = dict.insert m blue "b"
	print (dict.size m)
	when (dict.lookup m red) is some s {
		print s
	} is none {
		print "?"
	}
	when (dict.lookup m green) is some s {
		print s
	} is none {
		print "?"
	}
	when (dict.lookup m blue) is some s {
		print s
	} is none {
		print "?"
	}

	# Remove the middle entry; the others must still resolve.
	let m = dict.remove m green
	print (dict.size m)
	print (dict.contains-key m green)
	when (dict.lookup m red) is some s {
		print s
	} is none {
		print "?"
	}
	when (dict.lookup m blue) is some s {
		print s
	} is none {
		print "?"
	}
}
