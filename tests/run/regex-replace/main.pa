use std/regex as re

def coord = `"(" <x: digit+> "," <y: digit+> ")"`

def num = `digit+`

def main = fun {
	# replace: all matches, with ${name} interpolation of captures.
	print (re.replace coord "from (1,2) to (3,4)" "<${x},${y}>")

	# replace-first: only the leftmost.
	print (re.replace-first coord "(1,2) (3,4) (5,6)" "X")

	# replace with no captures referenced.
	print (re.replace num "abc 1 def 22 ghi 333" "N")

	# no match — input passes through unchanged.
	print (re.replace coord "no coords" "*")

	# literal $ in replacement requires $$.
	print (re.replace num "x 1 y" "$$${0}")
}
