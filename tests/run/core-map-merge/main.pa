use core.map

def main = fun {
	let a = map.from-entries [("x", 1), ("y", 2)]
	let b = map.from-entries [("y", 22), ("z", 3)]
	# merge is right-wins on overlapping keys; left keys keep their slot
	# in insertion order, right-only keys appear after.
	let m = map.merge a b
	print (map.size m)
	print (map.entries m)
	when (map.lookup m "y") is some n { print n } is none { print -1 }
}
