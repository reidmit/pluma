# Per-route version-skew protection. The synthesized `rpc.dispatch` checks each
# request's `x-rpc-fingerprint` header against the route's own fingerprint (over
# its argument + result wire shapes), rejecting a mismatch — a stale client built
# from drifted endpoint types — with a clean 409, never a corrupt positional
# decode. A hand-written probe over a real loopback socket sends a wrong
# fingerprint, a missing one, and the correct one; the first two are rejected
# with 409, the last round-trips to 200 with the decoded result.
#
# The correct value is the route fingerprint for `add :: fun int int -> task int`
# (the build bakes the identical value into the client stub and this dispatcher);
# if the fingerprint algorithm changes, update it here and re-accept the snapshot.
use std/dict
use std/task
use std/sys/http
use std/sys/net
use std/sys/rpc
use api

def route-fp :: string = "3046392278730166848"

# POST encoded args to the dispatcher with the given headers; report the status.
def probe :: fun string (dict string string) -> task int = fun url headers {
	try resp = task.attempt (http.fetch url http.method.post headers (wire.encode (2, 3)))
	when resp is ok r {
		task.ok r.status
	} is err _e {
		task.ok 0
	}
}

def main = fun {
	if net.listen "127.0.0.1:0" is ok server {
		if net.local-addr server is ok addr {
			scope as s {
				s.spawn (http.serve-on server rpc.dispatch)
				let url = "http://" ++ addr ++ "/_rpc/api.add"
				try wrong = probe url (dict.from-entries [("x-rpc-fingerprint", "0")])
				print "wrong fingerprint -> $(to-string wrong)"
				try missing = probe url (dict.empty ())
				print "missing fingerprint -> $(to-string missing)"
				try ok-status = probe url (dict.from-entries [("x-rpc-fingerprint", route-fp)])
				print "correct fingerprint -> $(to-string ok-status)"
				s.cancel ()
				task.ok 0
			}
		} else {
			print "local-addr failed"
			task.ok 1
		}
	} else {
		print "listen failed"
		task.ok 1
	}
}
