# Byte-substrate + hex stress: hex-encode a byte buffer to a string and decode it
# back, repeatedly. Exercises the bytes value substrate and the pure-Pluma hex
# codec (codepoint walks, byte building).

use core.bytes
use core.hex

def loop = fun data n acc {
	when n is 0 {
		acc
	} else {
		let h = hex.encode data
		let back = hex.decode h ?? data
		loop data (n - 1) (acc + bytes.length back)
	}
}

def main = fun {
	let data = bytes.build 500 fun i {
		i % 256
	}
	print (to-string (loop data 80 0))
}
