# `??` on `option`: `some` yields its payload, `none` yields the
# default. Desugars to `option.or-else value (fun { default })`.

def main = fun {
	# bare option values
	print (some 7 ?? 0)
	print (none ?? 0)

	# the default can be any expression of the payload type
	print (some "hi" ?? "fallback")
	print (none ?? "fallback")

	# nested in a larger expression
	print ((some 10 ?? 0) + (none ?? 5))
}
