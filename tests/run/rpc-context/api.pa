# A `remote def` whose contract is the pure logical signature `fun int int ->
# task int` — no `request` parameter — yet whose handler reads an ambient request
# header through `std.rpc.context` (bound per-invocation by the synthesized
# dispatcher) and authorizes the call in-handler with `rpc.reject`: an anonymous
# caller gets 401, a non-admin 403, an admin the sum. Its wire shape is exactly a
# plain `fun int int -> task int`, so it reuses that route fingerprint.
use std.rpc
use std.task
use std.rpc.context

public remote def guarded-add :: fun int int -> task int = fun a b {
	when context.header "x-role" is some role {
		if role == "admin" {
			task.return (a + b)
		} else {
			rpc.reject 403
		}
	} is none {
		rpc.reject 401
	}
}
