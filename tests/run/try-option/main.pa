# `try` on option. Each `try` desugars to `option.then expr fun pattern { rest }`.
# `none` short-circuits past every following expression.

def take-two = fun {
	try a = some 1
	try b = some 2
	some (a + b)
}

def take-none = fun {
	try a = some 1
	try none
	some a
}

def main = fun {
	let r1 = take-two ()
	when r1 is some v {
		print v
	} is none {
		print (0 - 1)
	}

	let r2 = take-none ()
	when r2 is some v {
		print v
	} is none {
		print (0 - 1)
	}
}
