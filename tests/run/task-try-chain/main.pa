# Awaiting tasks with `try` (the third carrier): sequential awaits, a nested
# async-function call, an async closure that captures a local, and ordinary
# (trait-dispatched) arithmetic between awaits. The whole chain runs on the
# event loop the moment `main` (itself a task) is driven to completion.
use std/task

def add-one = fun n {
	try x = task.return n
	task.return (x + 1)
}

def main = fun {
	let base = 100
	let bump = fun n {
		try y = task.return (n + base)
		task.return (y * 2)
	}
	try a = add-one 41
	try b = bump 5
	try _ = task.sleep 1ms
	print (to-string a)
	print (to-string b)
	task.return 0
}
