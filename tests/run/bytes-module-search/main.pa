use std/bytes

def main = fun {
	print (bytes.contains 'hello world' 'world')
	print (bytes.contains 'hello world' 'xyz')
	print (bytes.contains 'anything' '')
	print (bytes.starts-with '\x89PNG' '\x89')
	print (bytes.starts-with 'PNG' '\x89')
	print (bytes.ends-with 'hello\n' '\n')
	print (bytes.ends-with 'hello' '\n')
}
