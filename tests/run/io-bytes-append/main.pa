use std.bytes
use std.sys.fs

def show-write = fun r {
	when r is ok _ {
		print "wrote"
	} is err msg {
		print "write err: $(msg)"
	}
}

def main = fun {
	let path = "target/pluma-io-bytes-append.bin"

	show-write (fs.write-bytes-sync path '\x01\x02')
	show-write (fs.append-bytes-sync path '\x03\x04')
	show-write (fs.append-bytes-sync path '\x05')

	when fs.read-bytes-sync path is ok b {
		print (to-string b)
		print (to-string (bytes.length b))
	} is err msg {
		print "read err: $(msg)"
	}
}
