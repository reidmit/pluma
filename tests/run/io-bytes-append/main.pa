use std.bytes
use std.sys.io

def show-write = fun r {
	when r is ok _ {
		print "wrote"
	} is err msg {
		print "write err: $(msg)"
	}
}

def main = fun {
	let path = "target/pluma-io-bytes-append.bin"

	show-write (io.write-file-bytes path '\x01\x02')
	show-write (io.append-file-bytes path '\x03\x04')
	show-write (io.append-file-bytes path '\x05')

	when io.read-file-bytes path is ok b {
		print (to-string b)
		print (to-string (bytes.length b))
	} is err msg {
		print "read err: $(msg)"
	}
}
