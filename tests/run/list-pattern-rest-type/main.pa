# `[...rest]` and `[a, ...rest]` rest bindings preserve the element type.
# `let [...all]` works in `let` because there are no required items.

use std.list

def main = fun {
	# `let [...all] = xs` is irrefutable
	let [...all] = [1, 2, 3]
	print (to-string (list.length all))

	# rest preserves element type — used with list ops downstream
	when [10, 20, 30, 40] is [first, ...tail] {
		print (to-string first)
		print (to-string (list.length tail))
		# tail has the same element type, can be re-summed
		let doubled = list.map tail fun n {
			n * 2
		}
		each-print doubled
	} else {
		print "unreachable"
	}

	# Multi-element heads with rest
	when [1, 2, 3, 4, 5] is [a, b, c, ...rest] {
		print "$(to-string a) $(to-string b) $(to-string c) | $(to-string (list.length rest))"
	} else {
		print "unreachable"
	}

	# An empty rest is the empty list
	when [99] is [_, ...rest] {
		print "rest len: $(to-string (list.length rest))"
	} else {
		print "unreachable"
	}
}

def each-print = fun xs {
	when xs is [] {
		print "."
	} is [n, ...rest] {
		print (to-string n)
		each-print rest
	}
}
