# `defer` schedules cleanup to run when the enclosing function exits, by any
# path. Multiple defers run LIFO; a defer that was never reached never runs.

def get = fun ok-it {
	if ok-it {
		ok 5
	} else {
		err "boom"
	}
}

# Cleanup runs on the normal-return path *and* on the `try`-failure path.
# The `try` continuation (everything after `try`) only runs on success, so
# "got value" prints only when `get` succeeds — but the defers fire either way.
def run-it = fun ok-it {
	defer print "cleanup A"
	defer print "cleanup B"
	try x = get ok-it
	print "got value"
	ok x
}

# A defer inside a branch only fires if that branch actually executed.
def cond = fun flag {
	defer print "always"
	if flag {
		defer print "only-when-true"
		print "true branch"
	} else {
		print "false branch"
	}
	print "after if"
}

def main = fun {
	let _ = run-it true
	print "---"
	let _ = run-it false
	print "==="
	cond true
	print "---"
	cond false
}
