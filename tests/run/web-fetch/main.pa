# The browser HTTP transport (`std/web/fetch`). A web
# client can't open raw sockets, so its RPC stubs ride the host `fetch`
# (`fetch.post`) instead of `std/sys/net`. This exercises that transport's
# plumbing end-to-end under V8: marshal a request, hand it to the `web-fetch`
# host call, and shape the reply.
#
# We POST to a closed port, so the exchange fails deterministically with a
# connection error — proving the request marshals, the host attempt runs, and
# the failure surfaces as `err` through the stub's `task` (never a corrupt
# decode). A *successful* round-trip can't be an in-process loopback: a
# blocking `fetch` and a co-resident async server on the one wasm thread would
# deadlock (the server can't accept while the thread is parked in the fetch).
# The happy path is the browser example driven under `pluma dev`; the
# full RPC round-trip over the sys transport is `rpc-loopback`.
use std/dict
use std/string
use std/task
use std/web/fetch

def main = fun {
	# a closed port fails the task; reify it with `task.attempt`
	try resp = task.attempt (fetch.post "http://127.0.0.1:1/_rpc/echo" (dict.empty ()) (string.to-bytes "ping"))
	when resp is ok r {
		print "unexpected ok (status $(to-string r.status))"
		task.return 1
	} is err _e {
		print "web-fetch to a closed port failed as expected (err)"
		task.return 0
	}
}
