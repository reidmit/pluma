# std/path: the pure path-manipulation helpers (deterministic, no filesystem), plus a
# find-up roundtrip over a real directory tree to exercise the project-root walk (the
# relative result keeps the snapshot stable; project-root itself starts from the absolute
# cwd, so it's exercised by hand, not here).
use std/path
use std/sys/fs

def main = fun {
	# join / join-all
	print (path.join "/a/b" "c.txt")
	print (path.join "a/" "b")
	print (path.join "/a" "/b")
	print (path.join-all ["src", "std", "path.pa"])
	# parent / filename
	print (path.parent "/a/b/c.pa")
	print (path.parent "/a")
	print (path.parent "rel")
	print (path.filename "/a/b/c.pa")
	# extension / stem / with-extension
	print (path.stem "/a/b.tar.gz")
	print (path.extension "main.pa" ?? "<none>")
	print (path.extension ".bashrc" ?? "<none>")
	print (path.with-extension "src/main.pa" "wasm")
	# normalize
	print (path.normalize "/a/b/../c/./d")
	print (path.normalize "a/../../b")
	print (path.is-absolute "/x")
	print (to-string (path.segments "/a//b/"))

	# find-up over a real tree: marker at the root, search from a nested dir.
	let root = "target/pluma-path-fixture"
	let _ = fs.make-dir-sync "$(root)/a/b"
	let _ = fs.write-text-sync "$(root)/pluma.pa" ""
	when fs.find-up "$(root)/a/b" "pluma.pa" is some found {
		print found
	} is none {
		print "<not found>"
	}
	when fs.find-up "$(root)/a/b" "no-such-marker" is some _ {
		print "unexpected"
	} is none {
		print "<not found>"
	}
	let _ = fs.remove-all-sync root
}
