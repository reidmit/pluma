def main fun {
  print (to-string (1.5 + 2.5))
  print (to-string (10.0 - 3.5))
  print (to-string (2.0 * 3.5))
  print (to-string (7.0 / 2.0))
  print (to-string (7.5 % 3.0))
  print (to-string (-3.14))

  # float div by zero -> IEEE inf/nan, not a runtime error
  print (to-string (1.0 / 0.0))
  print (to-string (0.0 / 0.0))
}
