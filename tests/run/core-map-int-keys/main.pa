use core.map

def main = fun {
	let m = map.empty ()
	let m = map.insert m 1 "one"
	let m = map.insert m 2 "two"
	let m = map.insert m 3 "three"
	when (map.lookup m 2) is some s {
		print s
	} is none {
		print "?"
	}
	print (map.size m)

	# Boolean keys exercise the bool hash instance.
	let b = map.empty ()
	let b = map.insert b true "yes"
	let b = map.insert b false "no"
	when (map.lookup b true) is some s {
		print s
	} is none {
		print "?"
	}
	when (map.lookup b false) is some s {
		print s
	} is none {
		print "?"
	}
}
