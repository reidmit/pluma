# Exercises the `core.test` runner itself — `flatten` (groups, skip, todo),
# case execution, the printed tree, and the summary — as a normal program, so
# conformance cross-checks the runner under V8 against the VM oracle. Color is
# off (a clean snapshot); every runnable case passes, so `run-all` returns `ok`.

use core.test
use core.assert

def tests :: test.suite = [
	test.case "adds" (fun { assert.equals (2 + 3) 5 }),
	test.case "concats" (fun { assert.equals ("a" ++ "b") "ab" }),

	test.group "nested" [
		test.case "zero" (fun { assert.equals (0 + 0) 0 }),
		test.group "deeper" [
			test.case "true holds" (fun { assert.is-true true }),
		],
		test.skip (test.case "intentionally skipped" (fun { assert.is-true false })),
	],

	test.todo "later",
]

def main = fun {
	test.run-all false [{name: "demo", tests: tests}]
}
