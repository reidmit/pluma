# Shared RPC endpoints. Each `remote def` is the contract the compiler turns
# into a client stub and a server dispatch entry; the body is the server-side
# handler. These cover the three argument shapes the synthesized code handles:
# zero, one, and several arguments (the contract is the pure logical signature,
# no transport `request`).
use std/task

# Zero arguments.
public remote def ping :: fun nothing -> task string = fun {
	task.return "pong"
}

# One argument.
public remote def greet :: fun string -> task string = fun name {
	task.return ("hello, " ++ name)
}

# Several arguments (sent as an encoded tuple).
public remote def add :: fun int int -> task int = fun a b {
	task.return (a + b)
}
