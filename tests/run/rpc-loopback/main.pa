# In-process endpoint test (RPC.md §7a). In a server-context build (`pluma run`/
# `test`), a `remote def` has its *real* body — so calling `api.add 2 3` runs the
# handler directly, in process, with no socket, transport, or fingerprint. This
# is the regression guard for the contract surface (drop-the-`request`-param and
# the handler bodies); the wire path (encode → dispatch → decode, fingerprint
# guard) is exercised by `rpc-skew`, and the dual-build client/server split by
# `examples/fullstack`.
use std.task
use api

def main = fun {
	try greeting = api.ping ()
	print greeting
	try msg = api.greet "world"
	print msg
	try sum = api.add 2 3
	print "2 + 3 = $(to-string sum)"
	task.return 0
}
