# std.router's dispatch, driven in-process: build a handler from a list of
# routes and feed it hand-made requests, so the routing logic (method + path
# matching, first-match-wins ordering, the 404 fallback) is exercised without a
# socket. `serve` over a real connection is covered separately by `router-serve`.
use std.router
use std.sys.http
use std.task
use std.dict
use std.string
use std.bytes

# A bare request with the given method and path.
def req :: fun http.method string -> http.request = fun m p {
	{
		method: m,
		path: p,
		query: "",
		headers: dict.empty (),
		body: string.to-bytes "",
	}
}

# Run one request through the handler and print "<status> <body>".
def hit :: fun (fun http.request -> task http.response) http.method string -> task nothing = fun app m p {
	try resp = app (req m p)
	print "$(to-string resp.status) $(bytes.to-string resp.body ?? "<bad utf8>")"
	task.return ()
}

def main = fun {
	let app = router.handler [
		# An exact route placed before an overlapping prefix: first match wins,
		# so "/static/index.html" hits this, not the prefix below.
		router.get "/static/index.html" (fun _rq {
			task.return (http.text 200 "the index")
		}),
		router.get "/" (fun _rq { task.return (http.text 200 "home") }),
		router.get "/health" (fun _rq { task.return (http.text 200 "ok") }),
		router.post "/users" (fun _rq { task.return (http.text 201 "created") }),
		# A duplicate path: the first one wins, the second is never reached.
		router.get "/dup" (fun _rq { task.return (http.text 200 "first") }),
		router.get "/dup" (fun _rq { task.return (http.text 200 "second") }),
		router.prefix "/static" (fun rq {
			task.return (http.text 200 ("file " ++ rq.path))
		}),
	]

	try _ = hit app http.method.get "/"                    # 200 home
	try _ = hit app http.method.get "/health"              # 200 ok
	try _ = hit app http.method.post "/users"              # 201 created
	try _ = hit app http.method.get "/dup"                 # 200 first  (earlier route wins)
	try _ = hit app http.method.get "/static/index.html"   # 200 the index  (exact before prefix)
	try _ = hit app http.method.get "/static/app.css"      # 200 file /static/app.css  (prefix)
	try _ = hit app http.method.get "/users"               # 404  (path exists, wrong method)
	try _ = hit app http.method.post "/"                   # 404  (path exists, wrong method)
	try _ = hit app http.method.get "/missing"             # 404  (no route)
	task.return 0
}
