def color enum {
  red
  green
  blue
}

def shape enum {
  circle int
  rect int int
}

def main fun {
  print (to-string ())
  print (to-string 42)
  print (to-string 3.14)
  print (to-string true)
  print (to-string "hello")
  print (to-string (1, 2, "three"))
  print (to-string {name: "reid", age: 28})
  print (to-string color.red)
  print (to-string (shape.rect 3 4))
}
