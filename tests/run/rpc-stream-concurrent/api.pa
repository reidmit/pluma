# Two streaming endpoints of the same wire shape (`fun int -> stream int`, so
# they share one route fingerprint). `slow` sleeps between elements to force the
# two subscriptions to interleave on the wire.
use std/stream
use std/task

public remote def ticks :: fun int -> stream int = fun n {
	stream.from-seed 0 fun i {
		if i < n {
			task.ok (some (i, i + 1))
		} else {
			task.ok none
		}
	}
}

public remote def slow :: fun int -> stream int = fun n {
	stream.from-seed 0 fun i {
		if i < n {
			try task.sleep 3ms
			task.ok (some (i, i + 1))
		} else {
			task.ok none
		}
	}
}
