# Sort stress: build a scrambled list with a cheap index hash, then sort it
# with the pure-Pluma stable merge sort via `ord.compare`.

use core.list

def main = fun {
	let xs = list.build 1000 fun i {
		i * 2654435761 % 10007
	}
	let sorted = list.sort xs ord.compare
	print (to-string (list.length sorted))
	print (to-string (list.sum sorted ?? 0))
}
