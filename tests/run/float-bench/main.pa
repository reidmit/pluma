# Float stress: approximate pi with the Leibniz series, tail-recursively. Pure
# float arithmetic (+ - / and int->float) in a tight loop — the floating-point
# ALU comparison between the two backends.

def leibniz = fun n acc sign k {
	when n is 0 {
		acc
	} else {
		leibniz (n - 1) (acc + (sign / k)) (0.0 - sign) (k + 2.0)
	}
}

def main = fun {
	print (to-string (leibniz 8000 0.0 4.0 1.0))
}
