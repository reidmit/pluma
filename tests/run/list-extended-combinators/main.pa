# Exercises the extended list combinators, with particular attention to the
# `where (ord b)` defs (sort-by/min-by/max-by), whose trait-dict passing is the
# interesting case for the WASM backend.
use std.list
use std.string

def main = fun {
	print (list.take-while [2, 4, 5, 6] fun n {
		n % 2 == 0
	})
	print (list.drop-while [2, 4, 5, 6] fun n {
		n % 2 == 0
	})
	let (evens, odds) = list.partition [1, 2, 3, 4, 5] fun n {
		n % 2 == 0
	}
	print evens
	print odds
	print (list.unique [1, 2, 1, 3, 2, 3])
	print (list.enumerate ["a", "b", "c"])
	print (list.chunk [1, 2, 3, 4, 5] 2)
	print (list.intersperse [1, 2, 3] 0)
	print (list.sort-by ["bbb", "a", "cc"] string.length)
	print (list.min-by [3, 1, 4, 1, 5] fun n {
		n
	})
	print (list.max-by [3, 1, 4, 1, 5] fun n {
		n
	})
}
