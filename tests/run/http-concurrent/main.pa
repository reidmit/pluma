# Two clients hit one std/sys/http server at the same time, and the handler is
# rigged so it can only finish once *both* requests are in flight: on entry
# it bumps a shared counter, then waits for that counter to reach 2 before
# replying "paired". A sequential server -- one connection handled to
# completion before the next is even accepted -- can never satisfy that:
# the first handler would wait alone while the second connection sits
# unaccepted. So a run that prints "paired" for both requests is proof the
# two connections were handled concurrently.
#
# The wait is bounded (`await-pair` gives up after a generous spin), so a
# regression to sequential serving still terminates the run -- with a
# different but equally deterministic snapshot ("alone ...") instead of
# hanging.
use std/bytes
use std/list
use std/string
use std/task
use std/sys/http
use std/sys/net

# Spin until a second handler is also in flight (`gate` has reached 2).
# `fuel` bounds the wait so a sequential server -- where the second handler
# never starts -- ends the run rather than spinning forever.
def await-pair :: fun (ref int) int -> task bool = fun gate fuel {
	if ref.get gate >= 2 {
		task.return true
	} else if fuel <= 0 {
		task.return false
	} else {
		try _ = task.sleep 5ms
		await-pair gate (fuel - 1)
	}
}

# Read until the server closes the connection (Connection: close). `task.unwrap` joins the
# raw net read's in-task `result` onto this task's failure channel so the loop reads linearly.
def drain :: fun net.connection bytes -> task bytes string = fun conn acc {
	try chunk = task.unwrap (net.read conn 4096)
	if bytes.is-empty chunk {
		task.return acc
	} else {
		drain conn (bytes.concat acc chunk)
	}
}

# Send one GET and return just the response body (past the blank line).
def client :: fun string string -> task string = fun addr path {
	try conn = task.unwrap (net.connect addr)
	try _ = task.unwrap (net.write conn (string.to-bytes ("GET " ++ path ++ " HTTP/1.1\r\nHost: x\r\nConnection: close\r\n\r\n")))
	try raw = drain conn (string.to-bytes "")
	let _ = net.close conn
	let body = bytes.to-string raw ?? "<bad utf8>"
	task.return (list.head (list.drop (string.split body "\r\n\r\n") 1) ?? "<no body>")
}

def main = fun {
	if net.listen "127.0.0.1:0" is ok server {
		if net.local-addr server is ok addr {
			# Shared across both handler invocations: each bumps it on entry,
			# and only replies "paired" once it sees the other has arrived too.
			let gate = ref.new 0
			let handler :: fun http.request -> task http.response = fun req {
				let n = ref.get gate
				let _ = ref.set gate (n + 1)
				try paired = await-pair gate 400
				if paired {
					task.return (http.text 200 ("paired " ++ req.path))
				} else {
					task.return (http.text 200 ("alone " ++ req.path))
				}
			}
			scope as s {
				let _ = s.spawn (http.serve-on server handler)
				let ca = s.spawn (client addr "/a")
				let cb = s.spawn (client addr "/b")
				try a = ca
				try b = cb
				let bodies = list.sort [a, b] ord.compare
				print (list.get bodies 0)
				print (list.get bodies 1)
				s.cancel ()
				task.return 0
			}
		} else {
			print "local-addr failed"
			task.return 1
		}
	} else {
		print "listen failed"
		task.return 1
	}
}
