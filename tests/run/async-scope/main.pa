# Async scheduler stress: build a list of cold tasks (each with two await
# suspension points), then run them all concurrently in one scope and sum the
# results. Exercises the CPS state machine, fiber spawn/schedule, and the
# activation-stack snapshot/restore on every suspension.

use std.task
use std.list

def worker = fun n {
	try a = task.return n
	try b = task.return (n * 3)
	task.return (a + b)
}

def main = fun {
	let tasks = list.build 400 fun i {
		worker i
	}
	try results = task.all tasks
	let total = list.fold results 0 fun acc x {
		acc + x
	}
	print (to-string total)
	task.return 0
}
