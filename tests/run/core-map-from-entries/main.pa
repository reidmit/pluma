use core.map

def main = fun {
	# from-entries materializes a map from a list of (k, v) tuples.
	# Duplicate keys are right-wins.
	let m = map.from-entries [("a", 1), ("b", 2), ("a", 99), ("c", 3)]
	print (map.size m)
	when (map.lookup m "a") is some n { print n } is none { print -1 }
	when (map.lookup m "b") is some n { print n } is none { print -1 }
	when (map.lookup m "c") is some n { print n } is none { print -1 }
	# entries round-trips back to the same shape (insertion order preserved).
	print (map.entries m)
}
