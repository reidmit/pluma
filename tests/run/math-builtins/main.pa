use core.math

def main = fun {
  print (math.to-float 5)
  print (math.to-float 0)
  print (math.to-int 3.7)
  print (math.to-int (-3.7))
  print (math.sqrt 16.0)
  print (math.sqrt 2.0)
  print (math.abs (-7))
  print (math.abs 7)

  # roundtrip
  let x = math.to-int (math.sqrt (math.to-float 25))
  print x
}
