use std.sys.io
use std.sys.fs

def show-result = fun r {
	when r is ok _ {
		print "ok"
	} is err _ {
		# OS error messages aren't portable — just signal err
		print "err"
	}
}

def main = fun {
	let path = "target/pluma-io-append-delete.txt"

	# ensure known starting state: write empty (creates or truncates)
	show-result (fs.write-file path "")

	# append three lines
	show-result (fs.append-file path "one\n")
	show-result (fs.append-file path "two\n")
	show-result (fs.append-file path "three\n")

	# read it back
	when fs.read-file path is ok contents {
		let _ = io.write contents
	} is err msg {
		print "read err: $(msg)"
	}

	# delete it
	show-result (fs.delete-file path)
	print (fs.file-exists path)

	# deleting again should err
	show-result (fs.delete-file path)
}
