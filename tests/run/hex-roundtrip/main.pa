use std/error
use std/hex

def show = fun r {
	when r is ok b {
		print b
	} is err m {
		print "err: $(describe m)"
	}
}

def main = fun {
	print (hex.encode 'hello')
	print (hex.encode '\x00\xff\x10')
	print (hex.encode '')

	show (hex.decode "414243")
	show (hex.decode "ff")
	show (hex.decode "AbCd")
	show (hex.decode "")
	show (hex.decode "abc")
	show (hex.decode "zz")
}
