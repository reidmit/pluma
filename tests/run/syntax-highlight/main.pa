use std/list
use std/string
use std/syntax

# `syntax.highlight` tokenizes Pluma source into class-tagged spans for
# highlighting. Concatenating the spans' text reproduces the input exactly;
# unclassified runs come back with an empty class.

def show :: fun syntax.span -> nothing = fun s {
	print "$(s.class)\t| $(s.text)"
}

def run :: fun string -> nothing = fun src {
	print "--- $(src)"
	list.each (syntax.highlight src) show
	# Round-trip: joining the span texts must equal the input.
	let joined = string.join (list.map (syntax.highlight src) fun s { s.text }) ""
	print "roundtrip: $(to-string (joined == src))"
	print ""
}

def main = fun {
	run "def fact = fun n { if n <= 1 { 1 } else { n * fact (n - 1) } }"
	run "let xs :: list int = [1, 0xff, 2m20s]"
	run "# a comment\nprint \"hi \$(name)\""
	run "list.map xs fun x { x + 1 }"
	run "def pi :: float = 3.14 and done == false"
	run "let s = \"\"\"\nhi \"there\"\n\"\"\""
}
