# Fail-fast `scope`: spawn children, await their handles, block on exit. The
# values are deterministic regardless of how the children interleave.
use core.task

def both = fun t1 t2 {
	scope as s {
		let h1 = s.spawn t1
		let h2 = s.spawn t2
		try a = h1
		try b = h2
		task.return (a, b)
	}
}

# A child failing fails the whole scope (fail-fast); `??` recovers it.
def boom = fun {
	scope as s {
		let h1 = s.spawn (task.fail "kaboom")
		let h2 = s.spawn (task.return 2)
		try a = h1
		try b = h2
		task.return (a + b)
	}
}

def main = fun {
	try pair = both (task.return 1) (task.return 2)
	print (to-string pair)
	try recovered = boom () ?? task.return 999
	print (to-string recovered)
	task.return 0
}
