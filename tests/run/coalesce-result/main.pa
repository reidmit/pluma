# `??` on `result`: `ok` yields its payload, `err` yields the default
# (the error value is discarded). Desugars to `result.or-else`.

def parse = fun ok-it {
	if ok-it {
		ok 42
	} else {
		err "bad input"
	}
}

def main = fun {
	print (parse true ?? 0)
	print (parse false ?? 0)

	# the discarded error type can differ from the payload type
	print (ok "value" ?? "default")
	print (err 404 ?? "default")
}
