use core.string

def heading-level = fun line {
	if string.starts-with line "###### " {
		6
	} else if string.starts-with line "##### " {
		5
	} else if string.starts-with line "#### " {
		4
	} else if string.starts-with line "### " {
		3
	} else if string.starts-with line "## " {
		2
	} else if string.starts-with line "# " {
		1
	} else {
		0
	}
}

def main = fun {
	print (to-string (heading-level "# Title"))
	print (to-string (heading-level "### Sub"))
	print (to-string (heading-level "###### Deep"))
	print (to-string (heading-level "no heading"))
}
