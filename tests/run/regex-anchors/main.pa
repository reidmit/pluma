use core.regex

# `^` — start anchor
def starts-with-hello = /^ "hello"/

# `$` — end anchor
def is-pa-file = /"." "pa" $/

# `^` and `$` together — exact match
def exactly-yes = /^ "yes" $/

# Anchors with classes and quantifiers
def all-digits = /^ digit+ $/

# Alternation framed by anchors
def http-verb = /^ ("GET" | "POST" | "PUT" | "DELETE") $/

# `%` — word boundary, both sides
def word-cat = /% "cat" %/

# Boundary with a class — does any word start with a digit?
def word-starts-with-digit = /% digit/

def main = fun {
	# ^ at start of string
	print (regex.matches starts-with-hello "hello world")
	print (regex.matches starts-with-hello "say hello")

	# $ at end of string
	print (regex.matches is-pa-file "main.pa")
	print (regex.matches is-pa-file "main.pa.bak")

	# ^...$ exact match
	print (regex.matches exactly-yes "yes")
	print (regex.matches exactly-yes "yes!")
	print (regex.matches exactly-yes " yes")

	# anchored class+quantifier
	print (regex.matches all-digits "12345")
	print (regex.matches all-digits "12a45")
	print (regex.matches all-digits "")

	# anchored vocabulary
	print (regex.matches http-verb "GET")
	print (regex.matches http-verb "GETS")
	print (regex.matches http-verb "POST")

	# % word boundary
	print (regex.matches word-cat "the cat sat")
	print (regex.matches word-cat "category")
	print (regex.matches word-cat "cat")

	# % at one edge
	print (regex.matches word-starts-with-digit "abc 42")
	print (regex.matches word-starts-with-digit "abc4")
}
