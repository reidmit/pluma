def main = fun {
	let x = some 5
	let r = ok 5
	let c = color.red
	let n = 3

	# Two-arm constructor dispatch on one subject → suggest when. (fires)
	let a = if r is ok v { v } else if r is err e { 0 }

	# Three links, same subject — fires ONCE (not once per else-if link).
	let b = if c is color.red { 1 } else if c is color.green { 2 } else if c is color.blue { 3 }

	# Integer-literal dispatch with a trailing else → suggest when. (fires)
	let d = if n is 0 { "zero" } else if n is 1 { "one" } else { "many" }

	# Boolean chain: each link tests a DIFFERENT subject, not one value. Left alone.
	let e = if n > 10 { "big" } else if n > 5 { "mid" } else { "small" }

	# Single if-let (one pattern + plain else): a test, not a dispatch. Left alone.
	let f = if x is some v { v } else { 0 }

	# Nested dispatch in a branch body is analyzed on its own — the chain mark must
	# not leak past the head into branch bodies. The outer is a lone if-let (left
	# alone); the inner two-link chain fires.
	let g = if x is some v {
		if c is color.red { 1 } else if c is color.green { 2 }
	} else {
		0
	}

	# A bare nullary variant (`none`) is indistinguishable from a binding before
	# name resolution, so a chain whose arm is bare-nullary reads as a catch-all
	# and is left alone (qualified variants like `color.red` are recognized).
	let h = if x is some v { v } else if x is none { 0 }

	[a, b, d, e, f, g, h]
}
