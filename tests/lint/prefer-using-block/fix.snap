---
source: tests/lint_fix.rs
expression: output
---
use std/css
use std/view

# Fires: four `css.` projections — wrap in `using css`.
def card-style = fun {
	using css {
		.global [.at ".card" [.background (.hex "fff"), .padding (.px 8.0), .color (.hex "111")]]
	}
}

# Fires: three `view.` projections — wrap in `using view`.
def panel = fun title {
	using view { .element "div" [.attr "class" "panel", .text title] }
}

# Fires: a non-function def whose value projects off `css` four times — wrap
# the value in `using css`.
def item :: css.ruleset = using css {
	.rule [
		.property "border-top" "1px solid #e9e4dc",
		.property "padding-top" "1.6rem",
		.property "margin-top" "1.8rem",
	]
}

# Does not fire: only two `css.` projections, below the threshold.
def thin = fun {
	css.at ".x" [css.padding "1px"]
}

# Does not fire: a non-function def below the threshold.
def one-off :: css.ruleset = css.rule [css.property "color" "red"]

# Does not fire: the projections are already inside a matching `using css`, and
# written as the bare `.member` form the block enables.
def wrapped = fun {
	using css { .at ".y" [.background (.hex "000"), .padding (.px 2.0)] }
}

# Does not fire: both `css` and `view` reach the threshold, so a suggestion would
# stack two `using` blocks — left to the author.
def mixed = fun {
	view.element "div" [
		view.attr "class" "card",
		view.text "hi",
		view.styled (css.rule [css.color (css.hex "fff"), css.padding (css.px 4.0)]),
	]
}

# Does not fire: this closure is nested inside an enclosing `using css`. Its css
# projections are already wrapped, and the view projections would only stack a
# second `using` block on top.
def nested = fun {
	using css {
		run fun {
			.reset ()
			view.button
			[view.styled (.rule [.color (.hex "fff")])]
			[view.text "Save"]
		}
	}
}

# Does not fire: `view` here is a local value, not the imported namespace.
def shadowed = fun view {
	view.element [view.attr, view.text]
}
