# Evaluator: walk an `expr` against the variable environment.
#
# The environment is a `ref (dict string num)` — a single mutable cell
# holding the name→value dict. `eval` only reads it; the REPL driver in
# main.pa is what writes assignments back. Threading the ref (rather
# than the dict) means a future feature that mutates mid-expression
# wouldn't change this signature.
#
# Everything returns `result num string`, so the first undefined name,
# divide-by-zero, or unknown function short-circuits with a message.

use std/dict
use std/list
use std/math
use parser
use value

public def eval = fun env e {
	when e is parser.expr.lit n {
		ok n
	} is parser.expr.var name {
		when dict.lookup (ref.get env) name is some v {
			ok v
		} is none {
			err "undefined name '$(name)'"
		}
	} is parser.expr.neg inner {
		try v = eval env inner
		ok (value.num-neg v)
	} is parser.expr.bin op l r {
		try lv = eval env l
		try rv = eval env r
		apply-op op lv rv
	} is parser.expr.call name args {
		eval-call env name args
	}
}

# Dispatch a binary operator to the tower. Division and modulo guard
# against a zero divisor before delegating.
public def apply-op = fun op a b {
	if op == "+" {
		ok (value.num-add a b)
	} else if op == "-" {
		ok (value.num-sub a b)
	} else if op == "*" {
		ok (value.num-mul a b)
	} else if op == "/" {
		if value.is-zero b {
			err "division by zero"
		} else {
			ok (value.num-div a b)
		}
	} else if op == "%" {
		if value.is-zero b {
			err "modulo by zero"
		} else {
			ok (value.num-mod a b)
		}
	} else if op == "^" {
		ok (value.num-pow a b)
	} else {
		err "unknown operator '$(op)'"
	}
}

# ---------------------------------------------------------------------
# Function calls
# ---------------------------------------------------------------------

public def eval-call = fun env name args {
	try vals = eval-args env args []
	apply-fn name vals
}

# Evaluate every argument left to right, collecting the values (or the
# first error).
public def eval-args = fun env args acc {
	when args is [] {
		ok (list.reverse acc)
	} is [a, ...rest] {
		try v = eval env a
		eval-args env rest [v, ...acc]
	}
}

# Resolve a function by name and arity. `log` is overloaded: one
# argument is base-10, two arguments is log-base-y.
public def apply-fn = fun name vals {
	when vals is [x] {
		apply-unary name x
	} is [x, y] {
		apply-binary name x y
	} else {
		err "$(name): unknown function or wrong number of arguments"
	}
}

public def apply-unary = fun name x {
	if name == "sqrt" {
		ok (value.num.float-val (math.sqrt (value.as-float x)))
	} else if name == "sin" {
		ok (value.num.float-val (math.sin (value.as-float x)))
	} else if name == "cos" {
		ok (value.num.float-val (math.cos (value.as-float x)))
	} else if name == "tan" {
		ok (value.num.float-val (math.tan (value.as-float x)))
	} else if name == "ln" {
		ok (value.num.float-val (math.log (value.as-float x)))
	} else if name == "log" {
		ok (value.num.float-val (math.log10 (value.as-float x)))
	} else if name == "log2" {
		ok (value.num.float-val (math.log2 (value.as-float x)))
	} else if name == "exp" {
		ok (value.num.float-val (math.exp (value.as-float x)))
	} else if name == "abs" {
		ok (num-abs x)
	} else if name == "floor" {
		ok (value.num.int-val (math.floor (value.as-float x)))
	} else if name == "ceil" {
		ok (value.num.int-val (math.ceil (value.as-float x)))
	} else if name == "round" {
		ok (value.num.int-val (math.round (value.as-float x)))
	} else if name == "int" {
		ok (value.num.int-val (math.to-int (value.as-float x)))
	} else if name == "float" {
		ok (value.num.float-val (value.as-float x))
	} else {
		err "$(name): unknown function or wrong number of arguments"
	}
}

public def apply-binary = fun name x y {
	if name == "pow" {
		ok (value.num-pow x y)
	} else if name == "max" {
		ok (num-max x y)
	} else if name == "min" {
		ok (num-min x y)
	} else if name == "log" {
		ok (value.num.float-val (math.log (value.as-float x) / math.log (value.as-float y)))
	} else {
		err "$(name): unknown function or wrong number of arguments"
	}
}

# Tower-aware helpers the math module doesn't cover directly: `math.abs`
# is int-only, and max/min should keep the winning operand's own type.
public def num-abs = fun n {
	when n is value.num.int-val i {
		value.num.int-val (math.abs i)
	} is value.num.float-val f {
		if f < 0.0 {
			value.num.float-val (negate f)
		} else {
			value.num.float-val f
		}
	}
}

public def num-max = fun a b {
	if value.as-float a < value.as-float b {
		b
	} else {
		a
	}
}

public def num-min = fun a b {
	if value.as-float a < value.as-float b {
		a
	} else {
		b
	}
}
