# Parser: a `list token` becomes one statement.
#
# The grammar is the usual arithmetic precedence ladder, lowest to
# highest:
#
#   line   := name '=' expr            assignment
#           | expr                     bare expression
#   expr   := term   (('+' | '-') term)*
#   term   := power  (('*' | '/' | '%') power)*
#   power  := unary  ('^' power)?      right-associative
#   unary  := ('-' | '+') unary | atom
#   atom   := number
#           | name                     variable
#           | name '(' args ')'        function call
#           | '(' expr ')'
#   args   := expr (',' expr)* | <empty>
#
# Each parse step consumes a prefix of the token list and hands back
# the unconsumed remainder, threaded through `parsed`. There is no
# index to track — the remaining `list token` *is* the position, and
# list patterns (`[t-op op, ...rest]`) read it directly.

use std/list
use lexer
use value

public enum expr {
	lit value.num
	var string
	neg expr
	bin string expr expr
	call string (list expr)
}

public enum stmt {
	assign string expr
	bare expr
}

# A successful parse carries the node plus the tokens still to consume;
# `perr` carries a message. (Like `result`, but the ok arm is a pair.)
public enum parsed a {
	ok-at a (list lexer.token)
	perr string
}

# ---------------------------------------------------------------------
# Entry point: tokenize, then parse a single statement.
# ---------------------------------------------------------------------

public def parse = fun src {
	when lexer.tokenize src is err e {
		err e
	} is ok toks {
		parse-stmt toks
	}
}

# An assignment is exactly a name, then `=`, then an expression. Any
# other shape is a bare expression — including `pi` or `x` on its own.
public def parse-stmt = fun toks {
	when toks is [lexer.token.t-name name, lexer.token.t-op eqtok, ...rest] {
		if eqtok == "=" {
			finish fun e { stmt.assign name e } (parse-expr rest)
		} else {
			finish-bare toks
		}
	} else {
		finish-bare toks
	}
}

public def finish-bare = fun toks {
	finish fun e { stmt.bare e } (parse-expr toks)
}

# Wrap a parsed expression in `build`, but only if it consumed every
# token — trailing input (`1 2`, `x = 3 +`) is an error.
public def finish = fun build result {
	when result is parsed.ok-at e remaining {
		when remaining is [] {
			ok (build e)
		} else {
			err "unexpected trailing input"
		}
	} is parsed.perr m {
		err m
	}
}

# ---------------------------------------------------------------------
# The precedence ladder. Each level parses a higher-precedence operand,
# then folds in as many same-level operators as follow.
# ---------------------------------------------------------------------

public def parse-expr = fun toks {
	when parse-term toks is parsed.ok-at left rest {
		expr-rest left rest
	} is parsed.perr m {
		parsed.perr m
	}
}

public def expr-rest = fun left toks {
	when toks is [lexer.token.t-op op, ...rest] {
		if op == "+" or op == "-" {
			when parse-term rest is parsed.ok-at right rest2 {
				expr-rest (expr.bin op left right) rest2
			} is parsed.perr m {
				parsed.perr m
			}
		} else {
			parsed.ok-at left toks
		}
	} else {
		parsed.ok-at left toks
	}
}

public def parse-term = fun toks {
	when parse-power toks is parsed.ok-at left rest {
		term-rest left rest
	} is parsed.perr m {
		parsed.perr m
	}
}

public def term-rest = fun left toks {
	when toks is [lexer.token.t-op op, ...rest] {
		if op == "*" or op == "/" or op == "%" {
			when parse-power rest is parsed.ok-at right rest2 {
				term-rest (expr.bin op left right) rest2
			} is parsed.perr m {
				parsed.perr m
			}
		} else {
			parsed.ok-at left toks
		}
	} else {
		parsed.ok-at left toks
	}
}

# `^` binds tighter than `* /` and is right-associative, so the
# exponent recurses back into `parse-power` rather than looping.
public def parse-power = fun toks {
	when parse-unary toks is parsed.ok-at base rest {
		when rest is [lexer.token.t-op op, ...rest2] {
			if op == "^" {
				when parse-power rest2 is parsed.ok-at exp rest3 {
					parsed.ok-at (expr.bin "^" base exp) rest3
				} is parsed.perr m {
					parsed.perr m
				}
			} else {
				parsed.ok-at base rest
			}
		} else {
			parsed.ok-at base rest
		}
	} is parsed.perr m {
		parsed.perr m
	}
}

public def parse-unary = fun toks {
	when toks is [lexer.token.t-op op, ...rest] {
		if op == "-" {
			when parse-unary rest is parsed.ok-at e rest2 {
				parsed.ok-at (expr.neg e) rest2
			} is parsed.perr m {
				parsed.perr m
			}
		} else if op == "+" {
			parse-unary rest
		} else {
			parse-atom toks
		}
	} else {
		parse-atom toks
	}
}

# Split the list before matching the token, so the `when` is exhaustive
# over both the list shape (empty / non-empty) and the token variants.
public def parse-atom = fun toks {
	when toks is [] {
		parsed.perr "unexpected end of input"
	} is [first, ...rest] {
		when first is lexer.token.t-num n {
			parsed.ok-at (expr.lit n) rest
		} is lexer.token.t-name name {
			when rest is [lexer.token.t-op p, ...rest2] {
				if p == "(" {
					parse-call name rest2
				} else {
					parsed.ok-at (expr.var name) rest
				}
			} else {
				parsed.ok-at (expr.var name) rest
			}
		} is lexer.token.t-op p {
			if p == "(" {
				parse-paren rest
			} else {
				parsed.perr "unexpected operator '$(p)'"
			}
		}
	}
}

# Just consumed `(`: parse the inner expression and require a `)`.
public def parse-paren = fun toks {
	when parse-expr toks is parsed.ok-at e rest {
		when rest is [lexer.token.t-op q, ...rest2] {
			if q == ")" {
				parsed.ok-at e rest2
			} else {
				parsed.perr "expected ')'"
			}
		} else {
			parsed.perr "expected ')'"
		}
	} is parsed.perr m {
		parsed.perr m
	}
}

# Just consumed `name (`: parse the comma-separated argument list and
# the closing `)`. Handles the empty list (`now()`-style) up front.
public def parse-call = fun name toks {
	when toks is [lexer.token.t-op p, ...rest] {
		if p == ")" {
			parsed.ok-at (expr.call name []) rest
		} else {
			parse-args name toks []
		}
	} else {
		parse-args name toks []
	}
}

public def parse-args = fun name toks acc {
	when parse-expr toks is parsed.ok-at arg rest {
		when rest is [lexer.token.t-op p, ...rest2] {
			if p == "," {
				parse-args name rest2 [arg, ...acc]
			} else if p == ")" {
				parsed.ok-at (expr.call name (list.reverse [arg, ...acc])) rest2
			} else {
				parsed.perr "expected ',' or ')' in arguments"
			}
		} else {
			parsed.perr "expected ')' to close arguments"
		}
	} is parsed.perr m {
		parsed.perr m
	}
}
