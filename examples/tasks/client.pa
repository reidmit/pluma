# The client half — boots the browser app by *hydrating* the server-rendered DOM.
# `render.hydrate` walks `ui.page` alongside the existing DOM, attaching listeners
# and reactive effects to the server's nodes instead of rebuilding them.

use std/web/dom
use std/web/render
use ui

def main = fun {
	render.hydrate (dom.body ()) ui.page
}
