# Sort a pseudo-random integer list with the stdlib stable merge sort, then fold
# an order-sensitive checksum over the result.

use core.list

def main = fun {
	let xs = list.build 100000 fun i { (i * 2654435761) % 100003 }
	let sorted = list.sort xs ord.compare
	let checksum = list.fold sorted 0 fun acc v {
		((acc * 31) + v) % 1000000007
	}
	print (to-string (list.length sorted))
	print (to-string checksum)
}
