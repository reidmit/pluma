# String round-trip: build many parts, join them, split back, uppercase — text
# throughput across concat, join, split, and case mapping.

use std.list
use std.string

def main = fun {
	let parts = list.build 50000 fun i {
		"item-" ++ to-string i
	}
	let joined = string.join parts ","
	let back = string.split joined ","
	let upper = string.to-upper joined
	print (to-string (list.length back))
	print (to-string (string.length joined))
	print (to-string (string.length upper))
}
