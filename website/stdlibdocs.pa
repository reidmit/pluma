	{
		name: "std/bit",
		namespace: "bit",
		blocks: [
			{
				kind: "p",
				text: "Bitwise operations on whole numbers. A Pluma `int` is a 64-bit signed integer (two's complement), and these functions treat it as a flat row of 64 bits -- handy for flags, masks, packing several small values into one number, and low-level byte twiddling.",
			},
			{
				kind: "p",
				text: "Each function also has operator syntax: `&` (and), `|` (or), `^` (xor), `<<` (shift-left), `>>` (shift-right), `>>>` (shift-right-unsigned), and the prefix `~` (not). So `x & mask | flag` is `bit.or (bit.and x mask) flag`. The operators bind tighter than comparison (so `x & mask == 0` means `(x & mask) == 0`); the functions stay useful for `|>` chains and passing a bit op as a value.",
			},
		],
		items: [
			{
				name: "and",
				signature: "int int -> int",
				blocks: [
					{
						kind: "p",
						text: "Bitwise AND: a 1 in the result wherever *both* inputs have a 1. The usual tool for masking -- keeping only the bits a mask selects.",
					},
					{
						kind: "code",
						text: "bit.and 12 10   # => 8     (1100 & 1010 = 1000)\nbit.and 0xFF 5  # => 5",
					},
				],
			},
			{
				name: "or",
				signature: "int int -> int",
				blocks: [
					{
						kind: "p",
						text: "Bitwise OR: a 1 in the result wherever *either* input has a 1. The usual tool for setting flags.",
					},
					{kind: "code", text: "bit.or 12 10   # => 14    (1100 | 1010 = 1110)"},
				],
			},
			{
				name: "xor",
				signature: "int int -> int",
				blocks: [
					{
						kind: "p",
						text: "Bitwise XOR (\"exclusive or\"): a 1 wherever the inputs *differ*. Toggles the bits that the second operand has set.",
					},
					{kind: "code", text: "bit.xor 12 10   # => 6    (1100 ^ 1010 = 0110)"},
				],
			},
			{
				name: "not",
				signature: "int -> int",
				blocks: [
					{
						kind: "p",
						text: "Bitwise NOT: flips every bit. Because ints are two's complement, this is the same as `0 - n - 1`, so `not 0` is -1 and `not 5` is -6.",
					},
					{kind: "code", text: "bit.not 0   # => -1\nbit.not 5   # => -6"},
				],
			},
			{
				name: "shift-left",
				signature: "int int -> int",
				blocks: [
					{
						kind: "p",
						text: "Shift the bits left by `n` places, filling the low end with zeros. Each step doubles the value, so a left shift by `n` multiplies by 2^n.",
					},
					{
						kind: "code",
						text: "bit.shift-left 1 4   # => 16\nbit.shift-left 3 2   # => 12",
					},
				],
			},
			{
				name: "shift-right",
				signature: "int int -> int",
				blocks: [
					{
						kind: "p",
						text: "Shift the bits right by `n` places, *preserving the sign* (the high bit is copied in). This is an arithmetic shift: for non-negative numbers it divides by 2^n rounding toward negative infinity, and negatives stay negative.",
					},
					{
						kind: "code",
						text: "bit.shift-right 256 2   # => 64\nbit.shift-right -8 1    # => -4",
					},
				],
			},
			{
				name: "shift-right-unsigned",
				signature: "int int -> int",
				blocks: [
					{
						kind: "p",
						text: "Shift the bits right by `n` places, filling the high end with zeros (a logical shift). Treats the number as an unsigned 64-bit pattern, so a negative input becomes a large positive result.",
					},
					{
						kind: "code",
						text: "bit.shift-right-unsigned 256 2   # => 64\nbit.shift-right-unsigned -1 60    # => 15",
					},
				],
			},
		],
	},
	{
		name: "std/bytes",
		namespace: "bytes",
		blocks: [
			{
				kind: "p",
				text: "Working with raw bytes. A `bytes` is a sequence of 8-bit values (0-255 each) -- the form data takes on disk and over the network. It's the right tool for binary content (an image, a compressed file, a network frame) or for text whose encoding you don't control.",
			},
			{
				kind: "p",
				text: "Write a bytes literal with single quotes, using `\\xNN` to give a byte by its two-digit hex value: `'hello'`, `'\\x00\\xff'`. (Double quotes make a `string` instead.) When the bytes happen to be UTF-8 text, `to-string` decodes them; `string.to-bytes` goes the other way.",
			},
			{kind: "p", text: "Like strings and lists, bytes never change in place."},
		],
		items: [
			{
				name: "length",
				signature: "bytes -> int",
				blocks: [
					{kind: "p", text: "How many bytes are in the sequence."},
					{
						kind: "code",
						text: "bytes.length 'hello'       # => 5\nbytes.length '\\x00\\xff'    # => 2",
					},
				],
			},
			{
				name: "is-empty",
				signature: "bytes -> bool",
				blocks: [
					{kind: "p", text: "True when there are no bytes at all."},
					{
						kind: "code",
						text: "bytes.is-empty ''    # => true\nbytes.is-empty 'x'   # => false",
					},
				],
			},
			{
				name: "at",
				signature: "bytes int -> option int",
				blocks: [
					{
						kind: "p",
						text: "The byte at position `i` (counting from 0), as an int in 0-255 wrapped in `some`. `none` if `i` is out of range.",
					},
					{
						kind: "code",
						text: "bytes.at 'ABC' 0    # => some 65\nbytes.at 'ABC' 9    # => none",
					},
				],
			},
			{
				name: "get",
				signature: "bytes int -> int",
				blocks: [
					{
						kind: "p",
						text: "The byte at position `i`, as an int in 0-255. The unchecked primitive the byte operations below build on: partial, so a position outside `0 <= i < length` stops the program. Use `at` when `i` might be out of range -- it returns an `option` instead.",
					},
					{kind: "code", text: "bytes.get 'ABC' 0   # => 65"},
				],
			},
			{
				name: "build",
				signature: "int (int -> int) -> bytes",
				blocks: [
					{
						kind: "p",
						text: "Builds an `n`-byte sequence by calling `f` with each index `0..n-1`; `f`'s int result is taken mod 256. One O(n) pass -- the byte-buffer counterpart to `list.build`, and what the builders below ride on.",
					},
					{kind: "code", text: "bytes.build 3 (fun i { 65 + i })   # => 'ABC'"},
				],
			},
			{
				name: "concat",
				signature: "bytes bytes -> bytes",
				blocks: [
					{kind: "p", text: "Joins two byte sequences end to end into a new one."},
					{kind: "code", text: "bytes.concat 'foo' 'bar'   # => 'foobar'"},
				],
			},
			{
				name: "slice",
				signature: "bytes int int -> bytes",
				blocks: [
					{
						kind: "p",
						text: "The slice from position `start` (counted in) up to `end` (counted out). Positions past either end are pulled back to that end rather than erroring.",
					},
					{kind: "code", text: "bytes.slice 'hello' 1 4   # => 'ell'"},
				],
			},
			{
				name: "contains",
				signature: "bytes bytes -> bool",
				blocks: [
					{
						kind: "p",
						text: "True when `needle` appears somewhere inside `haystack`. Scans for the first match the way `split` does (`matches-at`, below), stopping early.",
					},
					{kind: "code", text: "bytes.contains 'hello world' 'world'   # => true"},
				],
			},
			{
				name: "starts-with",
				signature: "bytes bytes -> bool",
				blocks: [
					{
						kind: "p",
						text: "True when the bytes begin with `prefix`. Handy for spotting a file by its magic number -- a PNG starts with byte 0x89 then \"PNG\".",
					},
					{kind: "code", text: "bytes.starts-with '\\x89PNG' '\\x89'   # => true"},
				],
			},
			{
				name: "ends-with",
				signature: "bytes bytes -> bool",
				blocks: [
					{kind: "p", text: "True when the bytes end with `suffix`."},
					{kind: "code", text: "bytes.ends-with 'hello\n' '\n'   # => true"},
				],
			},
			{
				name: "repeat",
				signature: "bytes int -> bytes",
				blocks: [
					{kind: "p", text: "Repeats the bytes `n` times, joined into one sequence."},
					{kind: "code", text: "bytes.repeat 'ab' 3   # => 'ababab'"},
				],
			},
			{
				name: "reverse",
				signature: "bytes -> bytes",
				blocks: [
					{kind: "p", text: "Returns the bytes in reverse order."},
					{kind: "code", text: "bytes.reverse 'abc'   # => 'cba'"},
				],
			},
			{
				name: "to-list",
				signature: "bytes -> list int",
				blocks: [
					{
						kind: "p",
						text: "Spreads the bytes out into a list of ints, one per byte (each 0-255).",
					},
					{kind: "code", text: "bytes.to-list 'AB'   # => [65, 66]"},
				],
			},
			{
				name: "from-list",
				signature: "(list int) -> result bytes string",
				blocks: [
					{
						kind: "p",
						text: "Packs a list of ints back into bytes. Each int has to fit in a byte (0-255); `err` if one doesn't.",
					},
					{
						kind: "code",
						text: "bytes.from-list [72, 105]   # => ok 'Hi'\nbytes.from-list [256]       # => err \"byte out of range (0..256): 256\"",
					},
				],
			},
			{
				name: "join",
				signature: "(list bytes) bytes -> bytes",
				blocks: [
					{
						kind: "p",
						text: "Glues a list of byte sequences together, dropping `separator` between each pair.",
					},
					{kind: "code", text: "bytes.join ['a', 'b', 'c'] '-'   # => 'a-b-c'"},
				],
			},
			{
				name: "split",
				signature: "bytes bytes -> list bytes",
				blocks: [
					{
						kind: "p",
						text: "Breaks the bytes into pieces at every occurrence of `separator`.",
					},
					{kind: "code", text: "bytes.split 'a,b,c' ','   # => ['a', 'b', 'c']"},
				],
			},
			{
				name: "to-string",
				signature: "bytes -> result string string",
				blocks: [
					{
						kind: "p",
						text: "Decodes the bytes as UTF-8 text. `ok s` on success, `err` if the bytes aren't valid UTF-8.",
					},
					{kind: "code", text: "bytes.to-string 'hi'   # => ok \"hi\""},
				],
			},
		],
