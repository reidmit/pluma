			{
				name: "file-info",
				signature: "alias file-info",
				blocks: [
					{
						kind: "code",
						text: "alias file-info {size :: int, kind :: file-kind, modified :: instant}",
					},
					{
						kind: "p",
						text: "Metadata about a path, from `fs.stat`: its size in bytes, what kind of entry it is, and when it was last modified.",
					},
