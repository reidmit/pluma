# std/test — declarative test trees that `pluma test` runs.
#
# A test file (`*.test.pa`) exports a single `tests :: test.suite` — a list of
# test nodes. Build them with the constructors below; each `case` body returns a
# `result` (`ok ()` to pass, `err msg` to fail), which is exactly what the
# `std/assert` checks produce.
#
#     use std/test
#     use std/assert
#
#     def tests :: test.suite = [
#         test.case "adds" (fun { assert.equals (2 + 3) 5 }),
#
#         test.group "edge cases" [
#             test.case "zero" (fun { assert.equals (0 + 0) 0 }),
#             test.skip (test.case "flaky" (fun { assert.is-true false })),
#         ],
#
#         test.todo "handles overflow",
#     ]
#
# The runner (`run-all`) flattens the tree, then prints and executes each case;
# `pluma test` synthesizes the call. There is no registrar and no mutation — a
# suite is a plain value you can build, map over, and pass around.

use std/bytes
use std/list
use std/string
use std/task

# --- inlined ANSI styling --------------------------------------------------
# `std/test` is a shared module (it runs under V8 on both the `sys` and `web`
# targets), so it cannot depend on the `sys`-only `std/sys/terminal`. The few
# styling helpers the runner needs are inlined here instead — kept byte-for-byte
# in sync with `std/sys/terminal`'s `styled`/wrappers.

# ESC (0x1b) as a one-character string. Built from a byte since string literals
# don't carry a `\x` escape; `build`/`to-string` for code 27 never fails.
def esc :: string = bytes.to-string (bytes.build 1 fun _i { 27 }) ?? ""

# Wrap `s` in the given SGR codes, closed by a single reset (1 = bold, 2 = dim,
# 31 = red, …), so colored output composes without an early-reset bug.
def styled :: fun (list int) string -> string = fun codes s {
	let nums = string.join (list.map codes to-string) ";"
	"$(esc)[$(nums)m$(s)$(esc)[0m"
}

def bold :: fun string -> string = fun s {
	styled [1] s
}

def dim :: fun string -> string = fun s {
	styled [2] s
}

def bold-red :: fun string -> string = fun s {
	styled [1, 31] s
}

def bold-green :: fun string -> string = fun s {
	styled [1, 32] s
}

def bold-dim :: fun string -> string = fun s {
	styled [2, 1] s
}

# A node in a test tree. Opaque: build one only through the constructors below
# (`test.case`, `test.group`, `test.skip`, `test.focus`, `test.todo`) — a suite
# is data you assemble, never inspect. `skip`/`focus` mark a whole subtree.
opaque enum test {
	leaf string (fun nothing -> task nothing string)
	nest string (list test)
	omit test
	only test
	pend string
}

# What a `*.test.pa` file exports as `tests`.
public alias suite list test

# --- constructors (the public surface) ---------------------------------------

# A single case: a name and a task that succeeds to pass / fails (`task.fail msg`,
# or a failing assertion) to fail. The body is a task, so a case can `try` async
# work directly; a purely synchronous body is just an instantaneous task (the
# `assert.*` checks already return one).
public def case :: fun string (fun nothing -> task nothing string) -> test = test.leaf

# A named group of nested cases/groups.
public def group :: fun string (list test) -> test = test.nest

# Mark a case or group as skipped — registered and reported, never run.
public def skip :: fun test -> test = test.omit

# Mark a case or group as focused — if anything is focused, only focused runs.
public def focus :: fun test -> test = test.only

# A pending case: a name with no body yet.
public def todo :: fun string -> test = test.pend

# --- flattening --------------------------------------------------------------

# How a case was marked when the tree was flattened. `pending` is a `todo`.
enum run-status {
	normal
	skipped
	focused
	pending
}

# One flattened case: its enclosing group names (outermost first), its name, how
# it was marked, and the function to run.
alias entry {
	path :: list string,
	name :: string,
	status :: run-status,
	body :: fun nothing -> task nothing string,
}

# Flatten one node into entries, threading the enclosing group `path` and the
# inherited skip/focus `stat` (innermost mark wins).
def flatten-node :: fun (list string) run-status test -> list entry = fun path stat node {
	when node is test.leaf name body {
		[{path, name, status: stat, body}]
	} is test.pend name {
		[{path, name, status: run-status.pending, body: fun { task.return () }}]
	} is test.nest name children {
		list.flat-map children fun child {
			flatten-node [...path, name] stat child
		}
	} is test.omit inner {
		flatten-node path run-status.skipped inner
	} is test.only inner {
		flatten-node path run-status.focused inner
	}
}

# Flatten a whole suite into a flat, depth-first list of entries.
def flatten :: fun (list test) -> list entry = fun nodes {
	list.flat-map nodes fun n {
		flatten-node [] run-status.normal n
	}
}

def is-focused :: fun run-status -> bool = fun s {
	if s is run-status.focused {
		true
	} else {
		false
	}
}

# --- the runner --------------------------------------------------------------

# Running totals across every module's cases.
alias acc {passed :: int, failed :: int, skipped :: int, todo :: int}

def zero-acc :: fun nothing -> acc = fun {
	{passed: 0, failed: 0, skipped: 0, todo: 0}
}

# Apply `f` to `s` only when color is on; otherwise leave it bare.
def paint :: fun bool (fun string -> string) string -> string = fun color f s {
	if color {
		f s
	} else {
		s
	}
}

# `n` levels of two-space indentation.
def spaces :: fun int -> string = fun n {
	string.join (list.build n fun _i { "  " }) ""
}

# Length of the longest shared prefix of two paths.
def common-len :: fun (list string) (list string) -> int = fun a b {
	let pairs = list.zip a b
	list.length (list.take-while pairs fun p {
		p.0 == p.1
	})
}

# Print group headers for any segments of `path` not yet printed (depth-indented),
# and return `path` as the new printed prefix.
def emit-headers :: fun bool (list string) (list string) -> list string = fun color printed path {
	let common = common-len printed path
	list.each (list.enumerate (list.drop path common)) fun ie {
		print (spaces (common + ie.0 + 1) ++ paint color bold-dim ie.1)
	}
	path
}

# Print each line of a failure message under the case, extra-indented.
def print-msg :: fun string string -> nothing = fun indent msg {
	list.each (string.split msg "\n") fun line {
		print (indent ++ "    " ++ line)
	}
}

# Fold `f` left-to-right over `items`, threading `acc`, where each step yields a
# task — the sequential, accumulator-threading async fold the runner is built on
# (`list.fold` can't await). Each step is awaited before the next begins, so cases
# run one at a time and their output never interleaves.
def task-fold :: fun (list b) a (fun a b -> task a e) -> task a e = fun items acc f {
	when items is [] {
		task.return acc
	} is [first, ...rest] {
		try next = f acc first
		task-fold rest next f
	}
}

# What running (or declining to run) one case produced. Distinct from
# `run-status`: that's how the tree *marked* a case; this is what *happened*.
enum outcome {
	ok-case
	failed string
	did-skip
	is-todo
}

# One case paired with its outcome — the unit the reporter prints from.
alias case-result {path :: list string, name :: string, kind :: outcome}

# Run one case body to completion. The body is a task; `attempt` reifies its
# outcome so a failing case (or a trapping assertion) is reported, not propagated.
def run-body :: fun entry -> task outcome e = fun e {
	try res = task.attempt (e.body ())
	when res is ok _u {
		task.return outcome.ok-case
	} is err msg {
		task.return (outcome.failed msg)
	}
}

# Decide and run one entry: todo/skip short-circuit, a focused case always runs,
# and a normal case runs unless something else in the module is focused.
def run-entry :: fun bool entry -> task outcome e = fun any-focused e {
	when e.status is run-status.pending {
		task.return outcome.is-todo
	} is run-status.skipped {
		task.return outcome.did-skip
	} is run-status.focused {
		run-body e
	} is run-status.normal {
		if any-focused {
			task.return outcome.did-skip
		} else {
			run-body e
		}
	}
}

# Run one module's flattened entries, collecting (but not printing) each result.
# The reporter decides what to show — a clean module collapses to a single line,
# a failing one expands. Cases still run one at a time (see `task-fold`).
def run-entries :: fun bool (list entry) -> task (list case-result) e = fun any-focused entries {
	task-fold entries [] fun results e {
		try kind = run-entry any-focused e
		task.return [...results, {path: e.path, name: e.name, kind}]
	}
}

# --- reporting ---------------------------------------------------------------

def kind-is-pass :: fun outcome -> bool = fun o {
	if o is outcome.ok-case {
		true
	} else {
		false
	}
}

def kind-is-fail :: fun outcome -> bool = fun o {
	if o is outcome.failed _m {
		true
	} else {
		false
	}
}

def kind-is-skip :: fun outcome -> bool = fun o {
	if o is outcome.did-skip {
		true
	} else {
		false
	}
}

def kind-is-todo :: fun outcome -> bool = fun o {
	if o is outcome.is-todo {
		true
	} else {
		false
	}
}

def count-kind :: fun (list case-result) (fun outcome -> bool) -> int = fun results pred {
	list.length (list.filter results fun r {
		pred r.kind
	})
}

# "N passed" with any non-zero failed/skipped/todo counts appended, comma-joined —
# the parenthetical that trails a module's one-line report.
def counts-text :: fun int int int int -> string = fun passed failed skipped todo {
	let p0 = if failed > 0 {
		["$(to-string failed) failed"]
	} else {
		[]
	}
	let p1 = [...p0, "$(to-string passed) passed"]
	let p2 = if skipped > 0 {
		[...p1, "$(to-string skipped) skipped"]
	} else {
		p1
	}
	let p3 = if todo > 0 {
		[...p2, "$(to-string todo) todo"]
	} else {
		p2
	}
	string.join p3 ", "
}

# Print only the failing cases of a module, each under its group path with the
# failure message — the detail that matters when a module isn't clean.
def print-failures :: fun bool (list case-result) -> nothing = fun color results {
	let failures = list.filter results fun r {
		kind-is-fail r.kind
	}
	let _printed = list.fold failures [] fun printed r {
		let printed2 = emit-headers color printed r.path
		let indent = spaces (list.length r.path + 1)
		print (indent ++ paint color bold-red "✗" ++ " " ++ r.name)
		if r.kind is outcome.failed msg {
			print-msg indent msg
		} else {
			()
		}
		printed2
	}
	()
}

# Report one module: a clean module is a single green line; a failing one leads
# with a red line, then expands its failing cases.
def report-module :: fun bool string (list case-result) -> nothing = fun color name results {
	let passed = count-kind results kind-is-pass
	let failed = count-kind results kind-is-fail
	let skipped = count-kind results kind-is-skip
	let todo = count-kind results kind-is-todo
	let detail = paint color dim "($(counts-text passed failed skipped todo))"
	if failed == 0 {
		print (paint color bold-green "✓" ++ "  " ++ paint color bold name ++ " " ++ detail)
	} else {
		print (paint color bold-red "✗" ++ "  " ++ paint color bold name ++ " " ++ detail)
		print-failures color results
	}
}

# Render the final summary line, colored by overall pass/fail.
def summary-line :: fun bool acc -> string = fun color a {
	let total = a.passed + a.failed
	let base = "$(to-string a.passed) of $(to-string total) passed"
	let with-skip = if a.skipped > 0 {
		base ++ ", $(to-string a.skipped) skipped"
	} else {
		base
	}
	let full = if a.todo > 0 {
		with-skip ++ ", $(to-string a.todo) todo"
	} else {
		with-skip
	}
	if a.failed == 0 {
		paint color bold-green full
	} else {
		paint color bold-red full
	}
}

# Run every suite: print each module's tree, then a summary. The returned task
# yields `ok ()` if nothing failed, else `err ""` (the report is already printed;
# the host maps this to a non-zero exit). `color` enables ANSI styling. Cases are
# tasks awaited one at a time, so async cases drive their work to completion (and
# any `io.capture` around it stays correct) without interleaving.
public def run-all :: fun bool (list {
	name :: string,
	tests :: list test,
}) -> task (result nothing string) e = fun color suites {
	try final = run-suites color suites
	print ""
	print (summary-line color final)
	if final.failed == 0 {
		task.return (ok ())
	} else {
		task.return (err "")
	}
}

# Run each suite (printing its module tree) and fold the per-module counts into
# one running total. Shared by `run-all` (which then prints the summary) and the
# sharded runner (which reports its slice's counts back to the host instead).
def run-suites :: fun bool (list {
	name :: string,
	tests :: list test,
}) -> task acc e = fun color suites {
	task-fold suites (zero-acc ()) fun a suite {
		let entries = flatten suite.tests
		let any-focused = list.any entries fun e {
			is-focused e.status
		}
		try results = run-entries any-focused entries
		report-module color suite.name results
		task.return {
			passed: a.passed + count-kind results kind-is-pass,
			failed: a.failed + count-kind results kind-is-fail,
			skipped: a.skipped + count-kind results kind-is-skip,
			todo: a.todo + count-kind results kind-is-todo,
		}
	}
}

# `run-all`, but shardable across parallel processes. The test entry passes a
# shard descriptor (`"<id> <count>"`, set by the host when `pluma test` fans out
# across isolates); this process then runs only the suites whose index is `id`
# modulo `count` and reports its slice's counts back instead of a summary. Absent
# a descriptor -- the ordinary single-process run -- it is exactly `run-all` over
# every suite.
public def run-all-sharded :: fun bool (option string) (list {
	name :: string,
	tests :: list test,
}) -> task (result nothing string) e = fun color shard suites {
	if shard-of shard is some sh {
		try final = run-suites color (every-nth suites sh.id sh.count)
		# Report this slice's counts to the host (which sums every shard's line
		# into one summary) rather than printing a per-shard summary.
		print (shard-counts-line final)
		if final.failed == 0 {
			task.return (ok ())
		} else {
			task.return (err "")
		}
	} else {
		run-all color suites
	}
}

# A machine-readable `<RS>passed failed skipped todo` line. The RS control byte
# (0x1e) prefixes it so the parallel host can pick it out of captured output and
# strip it before printing — test output never contains a bare RS.
def shard-counts-line :: fun acc -> string = fun a {
	"$(rs)$(to-string a.passed) $(to-string a.failed) $(to-string a.skipped) $(to-string a.todo)"
}

# RS (0x1e) as a one-character string, built from its byte like `esc`.
def rs :: string = bytes.to-string (bytes.build 1 fun _i { 30 }) ?? ""

# Parse an `"<id> <count>"` shard descriptor (the host's `PLUMA_TEST_SHARD` value)
# into `{id, count}`. A missing descriptor (`none`) or a malformed one is `none`,
# so the caller runs every suite.
def shard-of :: fun (option string) -> option {id :: int, count :: int} = fun shard {
	if shard is some s {
		let parts = string.split s " "
		if list.length parts >= 2 {
			let id = string.to-int (list.get parts 0) ?? 0 - 1
			let count = string.to-int (list.get parts 1) ?? 0
			if count > 0 and id >= 0 {
				some {id, count}
			} else {
				none
			}
		} else {
			none
		}
	} else {
		none
	}
}

# Every `count`-th element of `xs` starting at index `id` -- the suites this
# shard owns, in original order.
def every-nth :: fun (list a) int int -> list a = fun xs id count {
	every-nth-go xs id count (list.length xs) []
}

def every-nth-go :: fun (list a) int int int (list a) -> list a = fun xs i count n acc {
	if i >= n {
		list.reverse acc
	} else {
		every-nth-go xs (i + count) count n [list.get xs i, ...acc]
	}
}
