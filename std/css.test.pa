# The pure value layer of styling. These pin the
# serialization -- color/length rendering, the `.0`-stripping number format, inline
# declaration joining -- plus the `std/view` integration helpers (`style-of`,
# `classes`) via `view.to-string`. All pure, so they run headless under V8.

use std/assert
use std/css
use std/list
use std/string
use std/test
use std/view

def tests :: test.suite = using css {
	[
		test.case "hex color keeps an existing leading hash" fun {
			assert.equals (.inline [.color (.hex "#e11")]) "color: #e11"
		},
		test.case "hex color adds a missing leading hash" fun {
			assert.equals (.inline [.color (.hex "2563eb")]) "color: #2563eb"
		},
		test.case "rgb renders comma-separated channels" fun {
			assert.equals (.inline [.color (.rgb 37 99 235)]) "color: rgb(37, 99, 235)"
		},
		test.case "rgba renders the alpha, dropping a whole .0" fun {
			assert.equals (.inline [.background (.rgba 0 0 0 0.5)]) "background: rgba(0, 0, 0, 0.5)"
		},
		test.case "named color passes through" fun {
			assert.equals (.inline [.color (.named "rebeccapurple")]) "color: rebeccapurple"
		},
		test.case "whole-number length drops the trailing .0" fun {
			assert.equals (.inline [.padding (.px 16.0)]) "padding: 16px"
		},
		test.case "fractional length keeps its decimals" fun {
			assert.equals (.inline [.font-size (.rem 1.5)]) "font-size: 1.5rem"
		},
		test.case "percent and viewport units render their suffix" fun {
			assert.equals (.inline [
				.width (.pct 50.0),
				.height (.vh 100.0),
			]) "width: 50%; height: 100vh"
		},
		test.case "opacity renders as a bare number" fun {
			assert.equals (.inline [.opacity 0.5]) "opacity: 0.5"
		},
		test.case "z-index renders an int" fun {
			assert.equals (.inline [.z-index 10]) "z-index: 10"
		},
		test.case "tab-size renders an int" fun {
			assert.equals (.inline [css.tab-size 2]) "tab-size: 2"
		},
		test.case "directional padding and margin name their edge" fun {
			assert.equals (.inline [
				.padding-top (.rem 1.0),
				.padding-left (.px 8.0),
				.margin-bottom (.rem 0.5),
			]) "padding-top: 1rem; padding-left: 8px; margin-bottom: 0.5rem"
		},
		test.case "min/max-height and scroll-margin-top take a length" fun {
			assert.equals (.inline [
				.min-height (.rem 22.0),
				.max-height (.vh 100.0),
				.scroll-margin-top (.rem 1.5),
			]) "min-height: 22rem; max-height: 100vh; scroll-margin-top: 1.5rem"
		},
		test.case "letter-spacing renders a negative em" fun {
			assert.equals (.inline [.letter-spacing (.em (-0.02))]) "letter-spacing: -0.02em"
		},
		test.case "logical axis builders name the block and inline axes" fun {
			assert.equals (.inline [
				.padding-block (.rem 1.4),
				.padding-inline (.rem 1.5),
				.margin-block (.px 0.0),
			]) "padding-block: 1.4rem; padding-inline: 1.5rem; margin-block: 0px"
		},
		test.case "auto renders as the auto keyword" fun {
			assert.equals (.inline [
				.margin-inline .auto,
				.width .auto,
			]) "margin-inline: auto; width: auto"
		},
		test.case "keyword properties take a string value" fun {
			assert.equals (.inline [
				.display "flex",
				.justify-content "center",
			]) "display: flex; justify-content: center"
		},
		test.case "the generic property escape hatch" fun {
			assert.equals (.inline [
				.property "grid-template-columns" "1fr 1fr",
			]) "grid-template-columns: 1fr 1fr"
		},
		test.case "multiple declarations join with '; '" fun {
			let s = .inline [.color (.hex "#fff"), .padding (.rem 1.0), .gap (.px 8.0)]
			assert.equals s "color: #fff; padding: 1rem; gap: 8px"
		},
		test.case "style-of renders a typed style attribute" fun {
			let v = view.div [view.style-of [.color (.hex "#e11"), .padding (.rem 1.0)]] []
			assert.equals (view.to-string v) "<div style=\"color: #e11; padding: 1rem\"></div>"
		},
		test.case "classes keeps only the enabled names" fun {
			let v = view.span [view.classes [("btn", true), ("active", false), ("lg", true)]] []
			assert.equals (view.to-string v) "<span class=\"btn lg\"></span>"
		},
		test.case "class-list is the bare joined string" fun {
			assert.equals (view.class-list [("a", true), ("b", false), ("c", true)]) "a c"
		},
		test.case "var references a custom property" fun {
			assert.equals (.inline [.background (.var "accent")]) "background: var(--accent)"
		},
		test.case "class-of is stable and content-addressed" fun {
			let a = .rule [.color (.hex "#fff")]
			let b = .rule [.color (.hex "#fff")]
			let c = .rule [.color (.hex "#000")]
			assert.all [
				assert.equals (.class-of a) (.class-of b),
				assert.is-true (string.starts-with (.class-of a) "c"),
				assert.not-equals (.class-of a) (.class-of c),
			]
		},
		test.case "render emits base, pseudo, and media blocks under the hashed class" fun {
			.reset ()
			let r = .rule [
				.color (.hex "#fff"),
				.padding (.rem 1.0),
				.on "hover" [.background (.hex "#1e51c8")],
				.media "(max-width: 600px)" [.padding (.rem 0.5)],
			]
			let cls = .class-of r
			assert.equals (.collect ()) ".$(cls){color: #fff; padding: 1rem}.$(cls):hover{background: #1e51c8}@media (max-width: 600px){.$(cls){padding: 0.5rem}}"
		},
		test.case "the collector dedups identical rules and keeps distinct ones" fun {
			.reset ()
			let r = .rule [.color (.hex "#fff")]
			let s = .rule [.color (.hex "#000")]
			let _a = .class-of r
			let _b = .class-of r
			let _c = .class-of s
			# r registered twice but collapses to one entry; s is the second.
			assert.equals (list.length (string.split (.collect ()) "\n")) 2
		},
		test.case "revision bumps for a new rule but not a re-register" fun {
			.reset ()
			let start = .revision ()
			let r = .rule [.color (.hex "#fff")]
			let s = .rule [.color (.hex "#000")]
			let _a = .class-of r
			let after-first = .revision ()
			let _b = .class-of r
			let after-dup = .revision ()
			let _c = .class-of s
			let after-second = .revision ()
			assert.all [
				# a brand-new rule advances the revision...
				assert.equals after-first (start + 1),
				# ...re-registering the same rule leaves it untouched...
				assert.equals after-dup after-first,
				# ...and a distinct rule advances it again.
				assert.equals after-second (after-first + 1),
			]
		},
		test.case "reset advances the revision" fun {
			let _r = .class-of (.rule [.color (.hex "#fff")])
			let before = .revision ()
			.reset ()
			assert.equals (.revision ()) (before + 1)
		},
		test.case "compose concatenates declarations into one new class" fun {
			.reset ()
			let bg = .rule [.background (.hex "#2563eb")]
			let fg = .rule [.color (.hex "#fff")]
			let merged = .compose [bg, fg]
			let cls = .class-of merged
			# both rules' declarations gather into the one composed class's block, in source order
			assert.equals (.collect ()) ".$(cls){background: #2563eb; color: #fff}"
		},
		test.case "view.styled registers the rule and yields its class" fun {
			.reset ()
			let primary = .rule [.color (.hex "#fff")]
			let v = view.button [view.styled primary] [view.text "Save"]
			let cls = .class-of primary
			assert.all [
				assert.equals (view.to-string v) "<button class=\"$(cls)\">Save</button>",
				assert.equals (.collect ()) ".$(cls){color: #fff}",
			]
		},
		test.case "style-tag wraps the collected CSS" fun {
			.reset ()
			let r = .rule [.color (.hex "#fff")]
			let cls = .class-of r
			assert.equals (.style-tag ()) "<style>.$(cls){color: #fff}</style>"
		},
		test.case "css-var renders its initial value into the inline style" fun {
			let v = view.div [view.css-var "accent" fun { "#e11" }] []
			assert.equals (view.to-string v) "<div style=\"--accent: #e11\"></div>"
		},
		test.case "several custom properties merge into one style attribute" fun {
			let v = view.div [view.css-var "a" fun { "1" }, view.css-var "b" fun { "2" }] []
			assert.equals (view.to-string v) "<div style=\"--a: 1; --b: 2\"></div>"
		},
		test.case "an inline style and custom properties merge, not collide" fun {
			let v = view.div [
				view.style-of [.color (.hex "#fff")],
				view.css-var "accent" fun { "#e11" },
			] []
			assert.equals (view.to-string v) "<div style=\"color: #fff; --accent: #e11\"></div>"
		},
		test.case "css-var coexists with non-style attributes" fun {
			let v = view.div [view.id "box", view.css-var "accent" fun { "#e11" }] []
			assert.equals (view.to-string v) "<div id=\"box\" style=\"--accent: #e11\"></div>"
		},
		test.case "global registers an unscoped selector rule" fun {
			.reset ()
			let _g = .global [.at ":root" [.property "--brand" "#2563eb"]]
			assert.equals (.collect ()) ":root{--brand: #2563eb}"
		},
		test.case "global handles several rules incl. at-rules" fun {
			.reset ()
			let _g = .global [
				.at "body" [.margin (.px 0.0)],
				.at "@font-face" [.property "font-family" "\"X\"", .property "src" "url(x.woff2)"],
			]
			let out = .collect ()
			assert.all [
				assert.is-true (string.contains out "body{margin: 0px}"),
				assert.is-true (string.contains out "@font-face{font-family: \"X\"; src: url(x.woff2)}"),
			]
		},
		test.case "animation registers @keyframes and names the decl to match" fun {
			.reset ()
			let spin = .keyframes [
				.frame "from" [.property "opacity" "0"],
				.frame "to" [.property "opacity" "1"],
			]
			let decl-str = .inline [.animation spin "1s linear infinite"]
			let out = .collect ()
			assert.all [
				assert.is-true (string.starts-with decl-str "animation: k"),
				assert.is-true (string.contains out "@keyframes k"),
				assert.is-true (string.contains out "{from{opacity: 0}to{opacity: 1}}"),
			]
		},
		test.case "identical keyframes dedup to one @keyframes block" fun {
			.reset ()
			let pulse = .keyframes [
				.frame "0%" [.property "transform" "scale(1)"],
				.frame "100%" [.property "transform" "scale(2)"],
			]
			let a1 = .inline [.animation pulse "2s"]
			let a2 = .inline [.animation pulse "5s"]
			assert.all [
				assert.not-equals a1 a2,
				assert.equals (list.length (string.split (.collect ()) "\n")) 1,
			]
		},
		test.case "a rule using an animation registers both the class and its keyframes" fun {
			# different timing => different decls...
			# ...but the same keyframes => one registered @keyframes block
			.reset ()
			let spin = .keyframes [
				.frame "from" [.property "transform" "rotate(0deg)"],
				.frame "to" [.property "transform" "rotate(360deg)"],
			]
			let spinner = .rule [.animation spin "1s linear infinite"]
			let cls = .class-of spinner
			let out = .collect ()
			assert.all [
				assert.is-true (string.contains out ".$(cls){animation: k"),
				assert.is-true (string.contains out "@keyframes k"),
			]
		},
	]
}
