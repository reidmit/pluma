# --- attribute builders ----------------------------------------------------

# A raw attribute: `html.attr "data-id" "42"`. The escape hatch for any
# attribute without its own builder below (e.g. `data-*` and `aria-*`).
public def attr :: fun string string -> attribute msg = fun k v {
	attribute.a-set k v
}

# A raw DOM *property*: `html.property "value" model.text`. Sets `node[name] =
# value`, not an attribute -- reach for this (and `bool-property`) for live input
# state. Most apps want the named `value`/`checked`/... helpers below.
public def property :: fun string string -> attribute msg = fun k v {
	attribute.a-prop-str k v
}

# A raw boolean DOM property: `html.bool-property "checked" model.done`.
public def bool-property :: fun string bool -> attribute msg = fun k v {
	attribute.a-prop-bool k v
}

# An event handler attribute (usually you'll reach for `std.web.events`):
# `html.on "click" (fun _e { Save })`.
public def on :: fun string (fun dom.event -> msg) -> attribute msg = fun name handler {
	attribute.a-on name handler
}

public def class :: fun string -> attribute msg = fun v {
	attribute.a-set "class" v
}

public def id :: fun string -> attribute msg = fun v {
	attribute.a-set "id" v
}

# An inline CSS string: `html.style "color: red; padding: 1rem"`.
public def style :: fun string -> attribute msg = fun v {
	attribute.a-set "style" v
}

public def title :: fun string -> attribute msg = fun v {
	attribute.a-set "title" v
}

public def lang :: fun string -> attribute msg = fun v {
	attribute.a-set "lang" v
}

public def dir :: fun string -> attribute msg = fun v {
