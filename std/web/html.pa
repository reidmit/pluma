# --- attributes: forms & inputs --------------------------------------------

# An input's text. Set as the live `.value` *property* (not the attribute), so a
# model-driven value authoritatively overrides what the user has typed -- the
# defining behaviour of a controlled input.
public def value :: fun string -> attribute msg = fun v {
	attribute.a-prop-str "value" v
}

public def placeholder :: fun string -> attribute msg = fun v {
	attribute.a-set "placeholder" v
}

# `type` is best avoided as a plain name; the DOM attribute, spelled out.
public def input-type :: fun string -> attribute msg = fun v {
	attribute.a-set "type" v
}

public def name :: fun string -> attribute msg = fun v {
	attribute.a-set "name" v
}

# A `<label for=...>` association (and any other element's `for` attribute).
public def for :: fun string -> attribute msg = fun v {
	attribute.a-set "for" v
}

public def action :: fun string -> attribute msg = fun v {
	attribute.a-set "action" v
}

public def method :: fun string -> attribute msg = fun v {
	attribute.a-set "method" v
}

public def min :: fun string -> attribute msg = fun v {
	attribute.a-set "min" v
}

public def max :: fun string -> attribute msg = fun v {
	attribute.a-set "max" v
}

public def step :: fun string -> attribute msg = fun v {
	attribute.a-set "step" v
}

public def pattern :: fun string -> attribute msg = fun v {
	attribute.a-set "pattern" v
}

public def accept :: fun string -> attribute msg = fun v {
	attribute.a-set "accept" v
}

public def autocomplete :: fun string -> attribute msg = fun v {
	attribute.a-set "autocomplete" v
}

public def cols :: fun string -> attribute msg = fun v {
	attribute.a-set "cols" v
}

public def rows :: fun string -> attribute msg = fun v {
	attribute.a-set "rows" v
}

public def colspan :: fun string -> attribute msg = fun v {
	attribute.a-set "colspan" v
}

public def rowspan :: fun string -> attribute msg = fun v {
	attribute.a-set "rowspan" v
}

# --- attributes: boolean (properties) --------------------------------------
#
# Boolean state is set as a DOM *property* (`node.disabled = flag`), taking a
# `bool` -- so it tracks live state and toggles both ways, the way a controlled
# checkbox needs. (`checked`/`selected` as *attributes* would set only the
# initial state.) The DOM property name isn't always the attribute name, e.g.
# `readonly` -> `readOnly`.

public def disabled :: fun bool -> attribute msg = fun b {
	attribute.a-prop-bool "disabled" b
}

public def required :: fun bool -> attribute msg = fun b {
	attribute.a-prop-bool "required" b
}

public def checked :: fun bool -> attribute msg = fun b {
	attribute.a-prop-bool "checked" b
}

public def selected :: fun bool -> attribute msg = fun b {
	attribute.a-prop-bool "selected" b
}

public def readonly :: fun bool -> attribute msg = fun b {
	attribute.a-prop-bool "readOnly" b
}

public def multiple :: fun bool -> attribute msg = fun b {
	attribute.a-prop-bool "multiple" b
}

public def autofocus :: fun bool -> attribute msg = fun b {
	attribute.a-prop-bool "autofocus" b
}

public def hidden :: fun bool -> attribute msg = fun b {
	attribute.a-prop-bool "hidden" b
}

# --- mapping ---------------------------------------------------------------

# Re-tag every message a tree emits, turning an `html a` into an `html b`.
# Lets a parent embed a child component and lift its messages into its own.
#
#     html.map (fun c { Child c }) (child-view model.child)
public def map :: fun (fun a -> b) (html a) -> html b = fun f node {
	when node is html.el tag attrs kids {
		html.el tag (list.map attrs fun a { map-attr f a }) (list.map kids fun k {
			map f k
		})
	} is html.txt s {
		html.txt s
	}
}

def map-attr :: fun (fun a -> b) (attribute a) -> attribute b = fun f a {
	when a is attribute.a-set k v {
		attribute.a-set k v
	} is attribute.a-prop-str k v {
		attribute.a-prop-str k v
	} is attribute.a-prop-bool k v {
		attribute.a-prop-bool k v
	} is attribute.a-on name handler {
		attribute.a-on name fun e {
			f (handler e)
		}
	}
}
