# std.web.html -- a virtual DOM: your UI described as plain data.
#
# Instead of poking at the real page (that's `std.web.dom`), you build an
# `html msg` value -- a tree of elements and text -- and hand it to the
# `std.web.app` runtime, which makes the real DOM match it. Because it's just
# data, `view` stays a pure function of your model.
#
# The `msg` type parameter is the message an element's event handlers emit:
# a `button [events.on-click Increment] [...]` produces an `html increment-msg`.
# The runtime feeds those messages back into your `update`.
#
# Build trees with the element helpers (`html.div`, `html.button`,
# `html.text`, ...), attach attributes with the attribute helpers
# (`html.class`, `html.value`, ...), and add event handlers from `std.web.events`.
#
# There is a named builder for (almost) every standard HTML tag, mirroring
# Elm's `Html` module. Every element builder has the same shape -- it takes a
# list of attributes and a list of children -- so void elements like `img` and
# `br` still take a (usually empty) child list. For a tag without a builder,
# reach for the generic `html.element "tag" attrs kids`.

use std.web.dom
use std.list

# A virtual DOM node. The constructors are internal (`el`/`txt`); build nodes
# with the helpers below so the public API is all qualified (`html.div`,
# `html.text`) rather than bare variant names.
public enum html msg {
	el string (list (attribute msg)) (list (html msg))
	txt string
}

# One of: an HTML attribute (`a-set name value`), a DOM property (`a-prop-str` /
# `a-prop-bool name value`), or an event handler (`a-on name handler`). Attributes
# and properties differ in what they touch -- `set-attribute` vs `node[name] = …`;
# properties are what controlled inputs need (live `value`/`checked`, not the
# initial-state attribute). Internal constructors; build with the helpers below +
# `std.web.events`.
public enum attribute msg {
	a-set string string
	a-prop-str string string
	a-prop-bool string bool
	a-on string (fun dom.event -> msg)
}

# --- the generic builders --------------------------------------------------

# A run of text.
public def text :: fun string -> html msg = fun s {
	html.txt s
}

# A generic element: `html.element "section" attrs children`. The escape hatch
# for any tag without its own builder below.
public def element :: fun string (list (attribute msg)) (list (html msg)) -> html msg = fun tag attrs kids {
	html.el tag attrs kids
}

