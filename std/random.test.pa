use std/assert
use std/bytes
use std/list
use std/random
use std/test

def tests :: test.suite = [
	test.case "int returns non-negative" fun {
		# Most random functions can't be asserted to specific values; the
		# tests verify shape, ranges, and error paths.

		# --- int ---

		let n = random.int ()
		assert.is-true (n >= 0)
	},
	test.case "float lies in [0, 1)" fun {
		# --- float ---

		let x = random.float ()
		assert.all [assert.is-true (x >= 0.0), assert.is-true (x < 1.0)]
	},
	test.case "bytes of length 0 is empty" fun {
		# --- bytes ---

		when random.bytes 0 is ok b {
			assert.equals (bytes.length b) 0
		} is err _msg {
			assert.is-true false
		}
	},
	test.case "bytes of length 16 has 16 bytes" fun {
		when random.bytes 16 is ok b {
			assert.equals (bytes.length b) 16
		} is err _msg {
			assert.is-true false
		}
	},
	test.case "bytes rejects negative length" fun {
		when random.bytes (-1) is ok _b {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	},
	test.case "int-range stays within bounds" fun {
		# --- int-range ---

		when random.int-range 10 20 is ok n {
			assert.all [assert.is-true (n >= 10), assert.is-true (n < 20)]
		} is err _msg {
			assert.is-true false
		}
	},
	test.case "int-range with low == high is err" fun {
		when random.int-range 5 5 is ok _n {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	},
	test.case "int-range with low > high is err" fun {
		when random.int-range 10 5 is ok _n {
			assert.is-true false
		} is err _msg {
			assert.is-true true
		}
	},
	test.case "int-range with width 1 is deterministic" fun {
		when random.int-range 7 8 is ok n {
			assert.equals n 7
		} is err _msg {
			assert.is-true false
		}
	},
	test.case "bool returns a bool" fun {
		# --- bool ---

		let b = random.bool ()
		# Confirms the call resolves to a bool — both arms succeed.
		when b is true {
			assert.is-true true
		} is false {
			assert.is-true true
		}
	},
	test.case "choice of empty list is none" fun {
		# --- choice ---

		when random.choice [] is some _x {
			assert.is-true false
		} is none {
			assert.is-true true
		}
	},
	test.case "choice of singleton picks that element" fun {
		when random.choice [42] is some x {
			assert.equals x 42
		} is none {
			assert.is-true false
		}
	},
	test.case "choice always picks a list element" fun {
		let xs = [10, 20, 30, 40]
		when random.choice xs is some x {
			assert.is-true (list.contains xs x)
		} is none {
			assert.is-true false
		}
	},
]
