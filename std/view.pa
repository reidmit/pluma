# std/view -- your UI as a value: a tree of elements bound to signals.
#
# This is the post-MVU view layer. You describe the page by building a `view`
# (with `view.div`, `view.button`, `view.text`, ...), bind the reactive parts to
# signals (`view.text-of`, `view.bind`), and attach effectful event handlers
# (`view.on-click`, `view.on-input`). A component is just a function returning a
# `view`; local state is a `signal.new` inside it -- drop `counter 0` and
# `counter 100` side by side with zero plumbing.
#
#     def counter = fun start {
#         let n = signal.new start
#         view.div [] [
#             view.button [view.on-click (fun { signal.update n (fun x { x - 1 }) })] [view.text "-"],
#             view.text-of (fun { to-string (signal.get n) }),
#             view.button [view.on-click (fun { signal.update n (fun x { x + 1 }) })] [view.text "+"],
#         ]
#     }
#
# A `view` is *pure data* -- it never touches the DOM. Two consumers turn it into
# output: `std/web/render`'s `mount` builds real DOM and wires effects (browser),
# and `to-string` here renders HTML (server-side rendering, and headless tests).
# That split is what lets the same view render on both server and client. The
# `event` a handler receives comes from the tier-neutral `std/event` (not
# `std/web/dom`), so `std/view` builds on the server profile too -- the only DOM
# the server ever needs is the handler *type*, never the DOM itself.

use std/css
use std/event
use std/list
use std/signal
use std/string

# An attribute, property, reactive attribute, or event handler on an element.
# `static`/`dynamic` set HTML attributes; `prop-str`/`prop-bool` set live DOM
# properties (what controlled inputs need); `handler` is an effectful listener.
# Public (not opaque) so the `render` consumer can destructure it; build with the
# helpers below rather than naming variants.
public enum attribute {
	static string string
	prop-str string string
	prop-bool string bool
	dynamic string (fun nothing -> string)
	prop-str-of string (fun nothing -> string)
	prop-bool-of string (fun nothing -> bool)
	handler string (fun event -> nothing)
	style-var string (fun nothing -> string)
	styled-when string (fun nothing -> bool)
	prop-bind-str string (fun nothing -> string) string (fun event -> nothing)
	prop-bind-bool string (fun nothing -> bool) string (fun event -> nothing)
	on-mount (fun nothing -> nothing)
}

# A node in the view tree: an element, static text, a reactive text node, or
# reactive control flow. `dyn-node` carries one function producing the
# current subtree -- the renderer re-runs it (and swaps the built DOM) when
# a signal it read changes, so a plain `if`/`when` inside chooses what to
# show. `for-node` carries a function
# producing the current keyed children. Each child is a `(key, fun nothing -> view)`
# pair -- a *deferred* builder, not a built view, so the renderer can run it once per
# new key (inside that row's owner) and skip it entirely for a surviving key. (The
# generic element type is erased into the functions so `view` stays monomorphic.)
public enum view {
	el string (list attribute) (list view)
	txt string
	dynamic-text (fun nothing -> string)
	dyn-node (fun nothing -> view)
	for-node (fun nothing -> list (string, (fun nothing -> view)))
}

# --- core builders ----------------------------------------------------------

# A run of static text (HTML-escaped on render).
public def text :: fun string -> view = view.txt

# A reactive text node: `view.text-of (fun { to-string (signal.get n) })`. On the
# browser the function re-runs (and patches the node) when its signals change; in
# `to-string` it's called once.
public def text-of :: fun (fun nothing -> string) -> view = view.dynamic-text

# A generic element -- the escape hatch for any tag without its own builder.
public def element :: fun string (list attribute) (list view) -> view = view.el

# --- reactive control flow --------------------------------------------------

# A reactive subtree: re-run `f` (and swap the mounted DOM, disposing the old
# subtree's effects) whenever a signal it read changes. The function is the reactive
# boundary -- Pluma builds the view tree by evaluating it once, so a region that must
# re-render on a signal change has to be deferred, exactly as `text-of`/`each` are.
# Inside, a plain `if`/`when`/`else if` chooses what to show, with `view.empty` for
# "nothing":
#
#     view.dyn (fun {
#         if signal.get loading { spinner () } else { content () }
#     })
public def dyn :: fun (fun nothing -> view) -> view = view.dyn-node

# The empty view -- renders nothing. The `else` branch of a `view.dyn` when one case
# shows nothing.
public def empty :: view = view.txt ""

# Mount `child ()` while `cond ()` is true, render nothing when it's false -- the
# terse hide/show case, sugar for a `view.dyn` whose `else` is `view.empty`.
# `view.show (fun { signal.get open }) (fun { panel () })`
public def show :: fun (fun nothing -> bool) (fun nothing -> view) -> view = fun cond child {
	view.dyn-node fun {
		if cond () {
			child ()
		} else {
			empty
		}
	}
}

# Render one child per item, reconciled by a stable key. When the list changes,
# rows with surviving keys are *reused* (their DOM and local state are kept);
# new keys are built, vanished keys are disposed, and the order is updated.
# `items` is a function, so it tracks whatever signal it reads. (Named
# `each`, not `for`, since `for` is the `<label for=...>` attribute builder.)
#
#     view.each (fun { signal.get todos }) (fun t { t.id }) (fun t { row t })
#
# `render item` is wrapped in a function, NOT called here: the renderer runs it once
# per new key inside that row's owner, so a `signal.new` in the row is created
# under the row's identity (its key) and reused -- not rebuilt -- on a list change.
public def each :: fun (fun nothing -> list a) (fun a -> string) (fun a -> view) -> view = fun items key render {
	view.for-node fun {
		list.map (items ()) fun item {
			(key item, fun { render item })
		}
	}
}

# --- generic attribute builders ---------------------------------------------

# A raw attribute: `view.attr "data-id" "42"`.
public def attr :: fun string string -> attribute = attribute.static

# A raw live DOM string property (controlled-input `value`, etc.).
public def property :: fun string string -> attribute = attribute.prop-str

# A raw boolean DOM property.
public def bool-property :: fun string bool -> attribute = attribute.prop-bool

# A reactive attribute: re-read the function and re-set the attribute when its signals
# change. `view.bind-attr "class" (fun { if signal.get active { "on" } else { "off" } })`.
# (The two-way `view.bind` below is for form-control *properties* tied to a signal;
# this is the one-way reactive *attribute* dual of `view.attr`.)
public def bind-attr :: fun string (fun nothing -> string) -> attribute = attribute.dynamic

# A reactive live DOM *string property* -- the property dual of `bind-attr`. Use this for
# what a controlled input needs (`value`, `value` of a `select`/`textarea`): the
# property, not the attribute, is what the browser reflects after the user has
# edited the field, so `view.bind-attr "value"` (an attribute write) is silently ignored
# once typing starts. `view.value-of (fun { signal.get draft })` keeps the field's
# text in sync with -- and resettable from -- a signal.
public def bind-property :: fun string (fun nothing -> string) -> attribute = attribute.prop-str-of

# A reactive live DOM *boolean property* (`checked`, `disabled`, ...). The reactive
# dual of `bool-property`; `view.checked-of (fun { signal.get on })` for a controlled
# checkbox.
public def bind-bool-property :: fun string (fun nothing -> bool) -> attribute = attribute.prop-bool-of

# Reactive `value` property of a controlled input: `view.value-of (fun { signal.get draft })`.
public def value-of :: fun (fun nothing -> string) -> attribute = fun f {
	attribute.prop-str-of "value" f
}

# Reactive `checked` property of a controlled checkbox/radio: `view.checked-of (fun { signal.get on })`.
public def checked-of :: fun (fun nothing -> bool) -> attribute = fun f {
	attribute.prop-bool-of "checked" f
}

# --- two-way binding --------------------------------------------------------
#
# A two-way binder ties a form-control *property* to a signal in both directions:
# the live DOM property tracks the signal (a reactive write) AND the user's edits
# write the signal back (an event listener). `view.value draft` replaces the
# `value-of` + `on-input` pair with a single declaration -- in a `using view` block,
# `.value draft`. The `-of` builders above are the one-way (display-only) duals, for
# when the DOM should follow the signal but not the reverse. Only a couple of
# properties round-trip, so this is just `value`/`checked`, not an entry per
# attribute.

# Two-way bind a controlled input/textarea/select `value` to a string signal: the
# field shows the signal and every keystroke (`input`) writes it back.
public def value :: fun (signal string) -> attribute = fun s {
	attribute.prop-bind-str "value" fun { signal.get s } "input" fun e {
		signal.set s (event.target-value e)
	}
}

# Two-way bind a checkbox/radio `checked` to a bool signal: the box reflects the
# signal and toggling it (`change`) writes the new state back.
public def checked :: fun (signal bool) -> attribute = fun s {
	attribute.prop-bind-bool "checked" fun { signal.get s } "change" fun e {
		signal.set s (event.target-checked e)
	}
}

# --- event handlers (effectful) ---------------------------------------------

# Run `handler` (which receives the raw event) when the named event fires.
public def on :: fun string (fun event -> nothing) -> attribute = attribute.handler

# Run `handler` on click (the event is ignored -- it takes no arguments).
public def on-click :: fun (fun nothing -> nothing) -> attribute = fun handler {
	attribute.handler "click" fun _e {
		handler ()
	}
}

# Run `handler` with the input's current text on every keystroke.
public def on-input :: fun (fun string -> nothing) -> attribute = fun handler {
	attribute.handler "input" fun e {
		handler (event.target-value e)
	}
}

# Like `on-input`, but on the `change` event (commit: blur / Enter / select).
public def on-change :: fun (fun string -> nothing) -> attribute = fun handler {
	attribute.handler "change" fun e {
		handler (event.target-value e)
	}
}

# Run `handler` on submit, suppressing the browser's full-page reload.
public def on-submit :: fun (fun nothing -> nothing) -> attribute = fun handler {
	attribute.handler "submit" fun e {
		event.prevent-default e
		handler ()
	}
}

# Run `action` once, on the client, when this element is mounted -- the analog of
# SolidJS's `onMount`, and the lifecycle dual of the event handlers above. It is
# *server-skipped*: `to-string` drops it (no markup, nothing run), while `build` and
# `hydrate` run it once (untracked, so a signal it reads doesn't make it re-run). That
# makes it the home for client-only setup the SSR'd HTML doesn't need -- most usefully
# an initial data fetch, which would otherwise run during SSR if placed in the view
# body. Sits in the element's attribute list alongside `id`/`styled`; call
# `signal.on-cleanup` inside `action` to tear down when the element unmounts.
#
#     view.div [view.id "app", view.on-mount (fun {
#         task.spawn (task.map (api.list-todos ()) fun board { signal.set todos board })
#     })] [...]
public def on-mount :: fun (fun nothing -> nothing) -> attribute = attribute.on-mount

# --- to-string: render a view to an HTML string (SSR / headless) -------------
#
# Pure: never touches the DOM. Static text and attribute values are HTML-escaped
# (the output trust boundary); reactive functions are evaluated once; event handlers
# are dropped (re-attached on the client at hydration). Void elements self-close.

# Void (self-closing) elements: no closing tag, no children rendered.
def void-tags :: list string = [
	"area",
	"base",
	"br",
	"col",
	"embed",
	"hr",
	"img",
	"input",
	"link",
	"meta",
	"param",
	"source",
	"track",
	"wbr",
]

def is-void :: fun string -> bool = fun tag {
	list.contains void-tags tag
}

# HTML-escape text content (`& < >`) and attribute values (also `"`) in one pass
# over the bytes -- one allocation, no intermediate strings, versus a chain of
# `string.replace` split+joins.
def escape-text :: fun string -> string = built-in "html-escape-text"

def escape-attr :: fun string -> string = built-in "html-escape-attr"

# Render one attribute, EXCEPT the `style`- and `class`-contributing ones -- those
# are gathered separately (`style-fragment` / `class-fragment`) and merged into a
# single `style="..."` / `class="..."` by `render-attrs`, so a node with several of
# either doesn't emit duplicate attributes.
def render-attr :: fun attribute -> string = fun a {
	when a is attribute.static k v {
		if k == "style" or k == "class" {
			""
		} else {
			" $(k)=\"$(escape-attr v)\""
		}
	} is attribute.prop-str k v {
		" $(k)=\"$(escape-attr v)\""
	} is attribute.prop-bool k flag {
		if flag {
			" $(k)"
		} else {
			""
		}
	} is attribute.dynamic k f {
		if k == "style" or k == "class" {
			""
		} else {
			" $(k)=\"$(escape-attr (f ()))\""
		}
	} is attribute.prop-str-of k f {
		" $(k)=\"$(escape-attr (f ()))\""
	} is attribute.prop-bool-of k f {
		if f () {
			" $(k)"
		} else {
			""
		}
	} is attribute.handler _name _h {
		""
	} is attribute.style-var _name _f {
		""
	} is attribute.styled-when _name _cond {
		""
	} is attribute.prop-bind-str k read _evt _write {
		" $(k)=\"$(escape-attr (read ()))\""
	} is attribute.prop-bind-bool k read _evt _write {
		if read () {
			" $(k)"
		} else {
			""
		}
	} is attribute.on-mount _action {
		# Server-skipped: a client-only mount effect, no markup.
		""
	}
}

# The `class` token an attribute contributes, if any: a `class` attribute's value
# (static or reactive, the function run once) or a `styled-when` rule whose condition
# holds. These merge into one `class` so a node can stack a base `styled` rule and
# several conditional ones.
def class-fragment :: fun attribute -> option string = fun a {
	when a is attribute.static k v {
		if k == "class" {
			some v
		} else {
			none
		}
	} is attribute.dynamic k f {
		if k == "class" {
			some (f ())
		} else {
			none
		}
	} is attribute.styled-when name cond {
		if cond () {
			some name
		} else {
			none
		}
	} else {
		none
	}
}

# The `style` text an attribute contributes, if any: a `style` attribute's value
# (static or reactive, the function run once), or a `--name: value` custom property.
# Everything else contributes nothing. These merge into one `style` attribute so a
# node can carry both an inline style and custom properties without a duplicate attr.
def style-fragment :: fun attribute -> option string = fun a {
	when a is attribute.static k v {
		if k == "style" {
			some v
		} else {
			none
		}
	} is attribute.dynamic k f {
		if k == "style" {
			some (f ())
		} else {
			none
		}
	} is attribute.style-var name f {
		some "--$(name): $(f ())"
	} is attribute.prop-str _k _v {
		none
	} is attribute.prop-bool _k _flag {
		none
	} is attribute.prop-str-of _k _f {
		none
	} is attribute.prop-bool-of _k _f {
		none
	} is attribute.handler _name _h {
		none
	} is attribute.styled-when _name _cond {
		none
	} is attribute.prop-bind-str _k _r _e _w {
		none
	} is attribute.prop-bind-bool _k _r _e _w {
		none
	} is attribute.on-mount _action {
		none
	}
}

# Collect, in order, the `some` values an attribute-to-fragment function yields.
def fragments :: fun (list attribute) (fun attribute -> option string) -> list string = fun attrs frag {
	let out :: list string = []
	list.each attrs fun a {
		when frag a is some s {
			list.push out s
		} else {
			()
		}
	}
	out
}

def render-attrs :: fun (list attribute) -> string = fun attrs {
	if list.is-empty attrs {
		""
	} else {
		render-attrs-nonempty attrs
	}
}

def render-attrs-nonempty :: fun (list attribute) -> string = fun attrs {
	let class-frags = fragments attrs class-fragment
	let style-frags = fragments attrs style-fragment
	# Fast path -- the overwhelmingly common case: at most one `class` and at most
	# one `style` contributor, so nothing needs merging. Render each attribute in
	# order with its sole `class`/`style` inlined, skipping the `first-contributor`
	# scans and the `enumerate` the merge path below needs. Output is identical:
	# joining a single fragment is that fragment.
	if list.length class-frags < 2 and list.length style-frags < 2 {
		string.join (list.map attrs render-attr-solo) ""
	} else {
		let first-class = first-contributor attrs class-fragment
		let first-style = first-contributor attrs style-fragment
		# Render in source order: each attribute emits its own markup, EXCEPT the merged
		# `class`/`style`, which lands once at its first contributor (later contributors --
		# and the gathered handlers -- emit nothing via `render-attr`). No single attribute
		# feeds both, so the two first-contributor positions never collide.
		string.join (list.map (list.enumerate attrs) fun p {
			if at-index first-class p.0 {
				" class=\"$(escape-attr (string.join class-frags " "))\""
			} else if at-index first-style p.0 {
				" style=\"$(escape-attr (string.join style-frags "; "))\""
			} else {
				render-attr p.1
			}
		}) ""
	}
}

# Render one attribute with a sole `class`/`style` contributor inlined (the fast
# path, where there's at most one of each so no merging applies). A non-class/style
# attribute falls through to `render-attr`.
def render-attr-solo :: fun attribute -> string = fun a {
	when class-fragment a is some v {
		" class=\"$(escape-attr v)\""
	} else {
		when style-fragment a is some s {
			" style=\"$(escape-attr s)\""
		} else {
			render-attr a
		}
	}
}

# The index of the first attribute that contributes a `class`/`style` fragment, if any.
def first-contributor :: fun (list attribute) (fun attribute -> option string) -> option int = fun attrs frag {
	list.find-index attrs fun a {
		when frag a is some _ {
			true
		} else {
			false
		}
	}
}

def at-index :: fun (option int) int -> bool = fun oi i {
	when oi is some j {
		j == i
	} else {
		false
	}
}

# Renders a view to an HTML string. This is server-side rendering: the
# same view that the browser mounts as live DOM becomes plain HTML here,
# so a page can be sent fully-formed on first load and then hydrated.
#
# Reactive parts are rendered at their current value, with text escaped.
public def to-string :: fun view -> string = fun v {
	when v is view.txt s {
		escape-text s
	} is view.dynamic-text f {
		escape-text (f ())
	} is view.el tag attrs kids {
		let attr-str = render-attrs attrs
		if is-void tag {
			"<$(tag)$(attr-str)>"
		} else {
			let kids-str = string.join (list.map kids to-string) ""
			"<$(tag)$(attr-str)>$(kids-str)</$(tag)>"
		}
	} is view.dyn-node f {
		# Wrap in the same `display: contents` host the browser renderer uses, so the
		# server DOM and the client's build/hydrate agree structurally (one node per
		# control-flow point). `display: contents` is layout-neutral.
		"<span style=\"display: contents\">$(to-string (f ()))</span>"
	} is view.for-node thunk {
		let inner = string.join (list.map (thunk ()) fun pair {
			let (_key, mk) = pair
			to-string (mk ())
		}) ""
		"<span style=\"display: contents\">$(inner)</span>"
	}
}

# Element builders -- one per standard HTML tag. Each takes a list of
# attributes and a list of child views and returns the matching element:
#
#     view.section [view.class "hero"] [view.h1 [] [view.text "Welcome"]]

# The `<h1>` element: a level-1 (top) heading.
public def h1 :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "h1" attrs kids
}

# The `<h2>` element: a level-2 heading.
public def h2 :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "h2" attrs kids
}

# The `<h3>` element: a level-3 heading.
public def h3 :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "h3" attrs kids
}

# The `<h4>` element: a level-4 heading.
public def h4 :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "h4" attrs kids
}

# The `<h5>` element: a level-5 heading.
public def h5 :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "h5" attrs kids
}

# The `<h6>` element: a level-6 (deepest) heading.
public def h6 :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "h6" attrs kids
}

# The `<hgroup>` element: a heading grouped with related taglines.
public def hgroup :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "hgroup" attrs kids
}

# The `<header>` element: introductory or navigational content.
public def header :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "header" attrs kids
}

# The `<footer>` element: footer content for its nearest section.
public def footer :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "footer" attrs kids
}

# The `<main>` element: the document's main content.
public def main :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "main" attrs kids
}

# The `<section>` element: a thematic grouping of content.
public def section :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "section" attrs kids
}

# The `<nav>` element: a block of navigation links.
public def nav :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "nav" attrs kids
}

# The `<article>` element: a self-contained, independently distributable piece of content.
public def article :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "article" attrs kids
}

# The `<aside>` element: content tangential to what surrounds it (a sidebar or callout).
public def aside :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "aside" attrs kids
}

# The `<address>` element: contact information for its article or document.
public def address :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "address" attrs kids
}

# The `<div>` element: a generic block-level container with no inherent meaning.
public def div :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "div" attrs kids
}

# The `<p>` element: a paragraph of text.
public def p :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "p" attrs kids
}

# The `<hr>` element: a thematic break between paragraphs.
public def hr :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "hr" attrs kids
}

# The `<pre>` element: preformatted text, rendered with whitespace preserved.
public def pre :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "pre" attrs kids
}

# The `<blockquote>` element: a section quoted from another source.
public def blockquote :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "blockquote" attrs kids
}

# The `<figure>` element: self-contained content with an optional caption.
public def figure :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "figure" attrs kids
}

# The `<figcaption>` element: a caption for its figure.
public def figcaption :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "figcaption" attrs kids
}

# The `<ol>` element: an ordered (numbered) list.
public def ol :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "ol" attrs kids
}

# The `<ul>` element: an unordered (bulleted) list.
public def ul :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "ul" attrs kids
}

# The `<li>` element: an item in a list.
public def li :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "li" attrs kids
}

# The `<dl>` element: a description list of term/description pairs.
public def dl :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "dl" attrs kids
}

# The `<dt>` element: a term in a description list.
public def dt :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "dt" attrs kids
}

# The `<dd>` element: the description for the preceding term.
public def dd :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "dd" attrs kids
}

# The `<span>` element: a generic inline container with no inherent meaning.
public def span :: fun (list attribute) (list view) -> view = fun attrs kids {
	view.el "span" attrs kids
}

