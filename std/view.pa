# Attribute builders -- one per common HTML attribute. Each takes the
# attribute's value and returns an `attribute` for an element's first list:
#
#     view.a [view.href "/docs", view.class "link"] [view.text "Docs"]

# The `class` attribute: the CSS classes applied to the element.
public def class :: fun string -> attribute = fun v {
	attribute.static "class" v
}

# The `id` attribute: a unique identifier for the element.
public def id :: fun string -> attribute = fun v {
	attribute.static "id" v
}

# The `style` attribute: inline CSS as a raw string (see `style-of` for
# a typed `std/css` declaration list).
public def style :: fun string -> attribute = fun v {
	attribute.static "style" v
}

# A conditional `class` attribute: keep each class whose flag is true.
# `view.classes [("btn", true), ("active", signal.get on)]` => `class="btn active"`
# when `on`. For a *reactive* class that re-renders as a signal changes, wrap the
# string form in `bind`: `view.bind-attr "class" (fun { view.class-list [...] })`.
public def classes :: fun (list (string, bool)) -> attribute = fun pairs {
	attribute.static "class" (class-list pairs)
}

# The space-joined class string from `(name, on)` pairs -- the value behind
# `classes`, exposed for use inside a reactive `bind`.
public def class-list :: fun (list (string, bool)) -> string = fun pairs {
	let on = list.filter pairs fun pair {
		let (_name, flag) = pair
		flag
	}
	string.join (list.map on fun pair {
		let (name, _flag) = pair
		name
	}) " "
}

# A typed inline `style` attribute from a `std/css` declaration list:
# `view.style-of [css.color (css.hex "#e11"), css.padding (css.rem 1.0)]`. For a
# reactive style, wrap `css.inline` in `bind`: `view.bind-attr "style" (fun { css.inline [...] })`.
public def style-of :: fun (list css.declaration) -> attribute = fun decls {
	attribute.static "style" (css.inline decls)
}

# Apply an extracted `css.ruleset` as a `class` attribute: yields the rule's hashed
# class name and registers its CSS in `std/css`'s collector, so server-side
# `css.style-tag`/`collect` (or a build-time extraction) emits exactly the rules a
# render actually used. The full power of CSS -- `:hover`, `@media`, etc. -- that an
# inline `style` can't express.
public def styled :: fun css.ruleset -> attribute = fun r {
	attribute.static "class" (css.class-of r)
}

# Apply an extracted `css.ruleset` reactively: its hashed class is on the element
# while `cond ()` holds and removed when it doesn't, re-evaluated when the signals
# `cond` reads change. The reactive companion to `styled` -- the idiomatic way to
# express a state-dependent style (`.active`, `.done`) without an inline `style`
# string. Composes with `styled` and other class attributes on the same node: all
# of them merge into one `class` (like `style`/`css-var` already do), so a base rule
# and any number of conditional ones stack. The rule is registered up front (so the
# stylesheet always carries it), only its presence on the element is conditional.
public def styled-when :: fun css.ruleset (fun nothing -> bool) -> attribute = fun r cond {
	attribute.styled-when (css.class-of r) cond
}

# A reactive CSS custom property on this element: `view.css-var "accent" (fun {
# theme.color (signal.get theme) })` sets `--accent`, re-applying when its signals
# change. This is the dynamic boundary: a static extracted `css.rule` reads the value
# with `css.var "accent"`, and this supplies the live value -- so the rule stays
# cacheable while the value tracks a signal. (Named `css-var`, not `var`, since `var`
# is the `<var>` element builder.) Multiple custom properties on one node merge into
# its `style`; on the server `to-string` renders the initial value into the inline
# style, and the client re-applies it via `node.style.setProperty`.
public def css-var :: fun string (fun nothing -> string) -> attribute = attribute.style-var

