{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Pluma",
	"scopeName": "source.pluma",
	"fileTypes": ["pa"],
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#triple-strings" },
		{ "include": "#strings" },
		{ "include": "#bytes" },
		{ "include": "#regex" },
		{ "include": "#numbers" },
		{ "include": "#use-declaration" },
		{ "include": "#enum-declaration" },
		{ "include": "#alias-declaration" },
		{ "include": "#trait-declaration" },
		{ "include": "#implement-declaration" },
		{ "include": "#def-declaration" },
		{ "include": "#let-binding" },
		{ "include": "#type-annotation" },
		{ "include": "#keywords" },
		{ "include": "#constants" },
		{ "include": "#builtin-types" },
		{ "include": "#operators" },
		{ "include": "#identifiers" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.number-sign.pluma",
					"begin": "#",
					"end": "$",
					"beginCaptures": {
						"0": { "name": "punctuation.definition.comment.pluma" }
					}
				}
			]
		},
		"triple-strings": {
			"name": "string.quoted.triple.pluma",
			"begin": "\"\"\"",
			"end": "\"\"\"",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.pluma" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.pluma" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.pluma",
					"match": "\\\\\\$\\("
				},
				{ "include": "#interpolation" }
			]
		},
		"strings": {
			"name": "string.quoted.double.pluma",
			"begin": "\"",
			"end": "\"",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.pluma" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.pluma" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.pluma",
					"match": "\\\\."
				},
				{ "include": "#interpolation" }
			]
		},
		"interpolation": {
			"name": "meta.embedded.line.interpolation.pluma",
			"begin": "\\$\\(",
			"end": "\\)",
			"beginCaptures": {
				"0": { "name": "punctuation.section.interpolation.begin.pluma" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.interpolation.end.pluma" }
			},
			"patterns": [{ "include": "$self" }]
		},
		"bytes": {
			"name": "string.quoted.single.pluma",
			"begin": "'",
			"end": "'",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.pluma" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.pluma" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.pluma",
					"match": "\\\\(x[0-9A-Fa-f]{2}|.)"
				}
			]
		},
		"regex": {
			"name": "string.regexp.pluma",
			"begin": "`",
			"end": "`",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.regex.begin.pluma" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.regex.end.pluma" }
			},
			"patterns": [
				{
					"name": "string.quoted.double.pluma",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{ "name": "constant.character.escape.pluma", "match": "\\\\." }
					]
				},
				{
					"name": "support.constant.character-class.regex.pluma",
					"match": "(?<![A-Za-z0-9_-])(digit|letter|word|whitespace|any)(?![A-Za-z0-9_-])"
				},
				{
					"name": "keyword.control.anchor.regex.pluma",
					"match": "[$%^]"
				},
				{
					"name": "keyword.operator.regex.pluma",
					"match": "[|?*+(){}]"
				},
				{
					"name": "constant.numeric.regex.pluma",
					"match": "\\d+"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.hex.pluma",
					"match": "(?<![A-Za-z0-9_])0[xX][0-9A-Fa-f][0-9A-Fa-f_]*"
				},
				{
					"name": "constant.numeric.octal.pluma",
					"match": "(?<![A-Za-z0-9_])0[oO][0-7][0-7_]*"
				},
				{
					"name": "constant.numeric.binary.pluma",
					"match": "(?<![A-Za-z0-9_])0[bB][01][01_]*"
				},
				{
					"name": "constant.numeric.duration.pluma",
					"match": "(?<![A-Za-z0-9_])[0-9][0-9_]*(?:ns|us|ms|s|m|h|d)(?:[0-9_]+(?:ns|us|ms|s|m|h|d))*(?![A-Za-z0-9_])"
				},
				{
					"name": "constant.numeric.float.pluma",
					"match": "(?<![A-Za-z0-9_])[0-9][0-9_]*\\.[0-9][0-9_]*"
				},
				{
					"name": "constant.numeric.decimal.pluma",
					"match": "(?<![A-Za-z0-9_])[0-9][0-9_]*"
				}
			]
		},
		"use-declaration": {
			"begin": "(?<![A-Za-z0-9_-])(use)(?![A-Za-z0-9_-])",
			"beginCaptures": {
				"1": { "name": "keyword.control.import.pluma" }
			},
			"end": "(?=$|#)",
			"patterns": [
				{
					"name": "keyword.control.import.pluma",
					"match": "(?<![A-Za-z0-9_-])as(?![A-Za-z0-9_-])"
				},
				{
					"name": "punctuation.separator.namespace.pluma",
					"match": "/"
				},
				{
					"name": "entity.name.namespace.pluma",
					"match": "[A-Za-z_][A-Za-z0-9_-]*"
				}
			]
		},
		"enum-declaration": {
			"match": "(?<![A-Za-z0-9_-])(enum)\\s+([A-Za-z_][A-Za-z0-9_-]*)",
			"captures": {
				"1": { "name": "keyword.declaration.enum.pluma" },
				"2": { "name": "entity.name.type.enum.pluma" }
			}
		},
		"alias-declaration": {
			"match": "(?<![A-Za-z0-9_-])(alias)\\s+([A-Za-z_][A-Za-z0-9_-]*)",
			"captures": {
				"1": { "name": "keyword.declaration.alias.pluma" },
				"2": { "name": "entity.name.type.alias.pluma" }
			}
		},
		"trait-declaration": {
			"match": "(?<![A-Za-z0-9_-])(trait)\\s+([A-Za-z_][A-Za-z0-9_-]*)",
			"captures": {
				"1": { "name": "keyword.declaration.trait.pluma" },
				"2": { "name": "entity.name.type.interface.pluma" }
			}
		},
		"implement-declaration": {
			"match": "(?<![A-Za-z0-9_-])(implement)\\s+([A-Za-z_][A-Za-z0-9_-]*)\\s+([A-Za-z_][A-Za-z0-9_-]*)",
			"captures": {
				"1": { "name": "keyword.declaration.implement.pluma" },
				"2": { "name": "entity.name.type.interface.pluma" },
				"3": { "name": "entity.name.type.pluma" }
			}
		},
		"def-declaration": {
			"match": "(?<![A-Za-z0-9_-])(def)\\s+([A-Za-z_][A-Za-z0-9_-]*)",
			"captures": {
				"1": { "name": "keyword.declaration.def.pluma" },
				"2": { "name": "entity.name.function.pluma" }
			}
		},
		"let-binding": {
			"match": "(?<![A-Za-z0-9_-])(let)\\s+([A-Za-z_][A-Za-z0-9_-]*)",
			"captures": {
				"1": { "name": "keyword.declaration.let.pluma" },
				"2": { "name": "variable.other.binding.pluma" }
			}
		},
		"type-annotation": {
			"begin": "::",
			"end": "(?=$|=|[,)}\\]])",
			"beginCaptures": {
				"0": { "name": "keyword.operator.type-annotation.pluma" }
			},
			"patterns": [
				{ "include": "#builtin-types" },
				{ "include": "#keywords" },
				{
					"match": "\\b([A-Za-z_][A-Za-z0-9_-]*)\\.([A-Za-z_][A-Za-z0-9_-]*)",
					"captures": {
						"1": { "name": "entity.name.namespace.pluma" },
						"2": { "name": "entity.name.type.pluma" }
					}
				},
				{
					"name": "entity.name.type.pluma",
					"match": "\\b[A-Za-z_][A-Za-z0-9_-]*\\b"
				},
				{ "include": "#operators" }
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.pluma",
					"match": "(?<![A-Za-z0-9_-])(if|else|when|while|is|in|try|defer|scope|using)(?![A-Za-z0-9_-])"
				},
				{
					"name": "keyword.declaration.pluma",
					"match": "(?<![A-Za-z0-9_-])(def|let|alias|enum|trait|implement|where|use|as|fun|test|public|opaque|manual|remote)(?![A-Za-z0-9_-])"
				},
				{
					"name": "keyword.other.builtin.pluma",
					"match": "(?<![A-Za-z0-9_-])built-in(?![A-Za-z0-9_-])"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.pluma",
					"match": "(?<![A-Za-z0-9_-])(true|false)(?![A-Za-z0-9_-])"
				}
			]
		},
		"builtin-types": {
			"patterns": [
				{
					"name": "support.type.primitive.pluma",
					"match": "(?<![A-Za-z0-9_-])(int|float|string|bool|regex|bytes|nothing)(?![A-Za-z0-9_.-])"
				},
				{
					"name": "support.type.builtin.pluma",
					"match": "(?<![A-Za-z0-9_-])(list|option|result|pair|ref|dict)(?![A-Za-z0-9_.-])"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.arrow.pluma",
					"match": "->"
				},
				{
					"name": "keyword.operator.comparison.pluma",
					"match": "==|!=|<=|>=|<|>"
				},
				{
					"name": "keyword.operator.logical.pluma",
					"match": "(?<![A-Za-z0-9_-])(and|or)(?![A-Za-z0-9_-])"
				},
				{
					"name": "keyword.operator.logical.pluma",
					"match": "!"
				},
				{
					"name": "keyword.operator.coalesce.pluma",
					"match": "\\?\\?"
				},
				{
					"name": "keyword.operator.concat.pluma",
					"match": "\\+\\+"
				},
				{
					"name": "keyword.operator.spread.pluma",
					"match": "\\.\\.\\."
				},
				{
					"name": "keyword.operator.range.pluma",
					"match": "\\.\\."
				},
				{
					"name": "keyword.operator.pipe.pluma",
					"match": "\\|"
				},
				{
					"name": "keyword.operator.exponent.pluma",
					"match": "\\*\\*"
				},
				{
					"name": "keyword.operator.arithmetic.pluma",
					"match": "[+\\-*/%]"
				},
				{
					"name": "keyword.operator.assignment.pluma",
					"match": "="
				}
			]
		},
		"identifiers": {
			"patterns": [
				{
					"match": "\\b([A-Za-z_][A-Za-z0-9_-]*)\\.([A-Za-z_][A-Za-z0-9_-]*)",
					"captures": {
						"1": { "name": "entity.name.namespace.pluma" },
						"2": { "name": "variable.other.property.pluma" }
					}
				},
				{
					"name": "variable.other.pluma",
					"match": "\\b[A-Za-z_][A-Za-z0-9_-]*\\b"
				}
			]
		}
	}
}
