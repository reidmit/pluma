{
	"name": "pluma-language-client",
	"publisher": "reidmit",
	"version": "0.0.1",
	"categories": [
		"Other"
	],
	"keywords": [
		"language-server",
		"pluma-lsp",
		"pluma"
	],
	"repository": {
		"url": "https://github.com/reidmit/pluma"
	},
	"main": "./dist/extension.js",
	"engines": {
		"vscode": "^1.91.0"
	},
	"scripts": {
		"test": "node --test test/*.test.mjs"
	},
	"activationEvents": [
		"onLanguage:pluma"
	],
	"contributes": {
		"commands": [],
		"languages": [
			{
				"id": "pluma",
				"aliases": [
					"Pluma",
					"pluma"
				],
				"extensions": [
					".pa"
				]
			}
		],
		"grammars": [
			{
				"language": "pluma",
				"scopeName": "source.pluma",
				"path": "./syntaxes/pluma.tmLanguage.json"
			}
		],
		"semanticTokenScopes": [
			{
				"language": "pluma",
				"scopes": {
					"function": ["entity.name.function.pluma"],
					"parameter": ["variable.other.pluma"],
					"property": ["variable.other.property.pluma"],
					"type": ["entity.name.type.pluma"],
					"enum": ["entity.name.type.enum.pluma"],
					"enumMember": ["variable.other.property.pluma"],
					"namespace": ["entity.name.namespace.pluma"],
					"interface": ["entity.name.type.interface.pluma"],
					"typeParameter": ["entity.name.type.pluma"]
				}
			}
		]
	},
	"dependencies": {
		"vscode-languageclient": "9.0.1"
	},
	"devDependencies": {
		"@types/node": "^20.14.11",
		"@types/vscode": "1.91.0",
		"esbuild": "^0.23.0",
		"typescript": "5.5.3",
		"vscode-oniguruma": "^2.0.1",
		"vscode-textmate": "^9.1.0"
	}
}
