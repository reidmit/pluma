{
  "grammars": [
    {
      "name": "pluma",
      "camelcase": "Pluma",
      "scope": "source.pluma",
      "path": ".",
      "file-types": [
        "pa"
      ],
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Pluma language",
    "links": {
      "repository": "https://github.com/reidmit/pluma"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
